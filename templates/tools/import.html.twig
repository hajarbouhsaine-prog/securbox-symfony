{% extends 'base.html.twig' %}
{% block title %}Import{% endblock %}
{% block body %}
<h1>Import</h1>
<div style="max-width:900px;">
    <div style="background:#161b27; border:1px solid #2a2f3e; border-radius:12px; padding:18px;">
        <form method="post" enctype="multipart/form-data">
            <div style="margin-bottom:12px;">
                <label class="form-label">Vault (required)</label>
                <select name="vault" class="form-select">
                    {% for col in collections %}
                    <option value="{{ col.id }}">{{ col.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div style="margin-bottom:12px;">
                <label class="form-label">File format</label>
                <select name="format" class="form-select">
                    <option value="json">.json</option>
                    <option value="csv">.csv</option>
                </select>
            </div>
            <div style="margin-bottom:12px;">
                <label class="form-label">Select the import file</label>
                <input type="file" name="import_file" class="form-control" />
            </div>
            <div style="margin-bottom:12px;">
                <label class="form-label">or copy/paste the import file contents</label>
                <textarea name="paste" class="form-control" rows="6"></textarea>
            </div>
            <button class="btn btn-primary" type="submit">Import</button>
        </form>
    </div>
</div>
{% endblock %}
