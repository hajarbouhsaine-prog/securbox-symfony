{% extends 'base.html.twig' %}

{% block title %}Paramètres{% endblock %}

{% block body %}
<div class="sb-settings">

    {# ── Flash messages ── #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
        <div class="sb-flash sb-flash--{{ label == 'error' ? 'danger' : 'success' }}">
            <i class="fas fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }}"></i>
            {{ message }}
        </div>
        {% endfor %}
    {% endfor %}

    {# ══════════════════════════════════════════
       HERO — profile card
    ══════════════════════════════════════════ #}
    <div class="sb-hero">
        <div class="sb-hero__left">
            <h1 class="sb-hero__title">Mon compte</h1>
        </div>

        <div class="sb-profile-card sb-profile-card--hero">
            <div class="sb-profile-card__top">
                <div class="sb-avatar">{{ app.user.email|first|upper }}</div>
                <div>
                    <div class="sb-profile-card__name">{{ app.user.email|split('@')[0]|capitalize }}</div>
                    <div class="sb-profile-card__email">{{ app.user.email }}</div>
                </div>
            </div>
            <div class="sb-profile-card__actions">
                <button type="button" class="sb-btn sb-btn--ghost">Personnaliser</button>
            </div>
        </div>
    </div>

    {# ══════════════════════════════════════════
       SECTION 1 — Informations générales (Nom)
    ══════════════════════════════════════════ #}
    <div class="sb-section">
        <form method="post" action="{{ path('app_settings') }}" id="formName" novalidate>
            <input type="hidden" name="action" value="update_name">

            <div class="sb-section__row">
                <div class="sb-field sb-field--inline">
                    <label for="profile_name">Nom</label>
                    <input id="profile_name" name="new_name" type="text" class="sb-input"
                           value="{{ app.user.email|split('@')[0]|capitalize }}" required>
                    <span class="sb-field__err" id="nameErr"></span>
                </div>

                <div class="sb-field sb-field--inline">
                    <label for="profile_email_display">Email</label>
                    <input id="profile_email_display" type="email" class="sb-input"
                           value="{{ app.user.email }}" readonly>
                </div>

                <div class="sb-section__action">
                    <button type="submit" class="sb-btn sb-btn--primary">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                </div>
            </div>
        </form>
    </div>

    {# ══════════════════════════════════════════
       SECTION 2 — Changer l'adresse email
    ══════════════════════════════════════════ #}
    <div class="sb-section">
        <h2 class="sb-section__title">Changer l'adresse email</h2>
        <p class="sb-section__desc">Pour modifier votre email, confirmez d'abord votre mot de passe actuel.</p>

        <form method="post" action="{{ path('app_settings') }}" id="formEmail" novalidate>
            <input type="hidden" name="action" value="update_email">

            {# Step 1: master password — always visible #}
            <div id="emailStep1">
                <div class="sb-field">
                    <label for="profile_current_password">
                        Mot de passe actuel <span class="sb-required">(requis)</span>
                    </label>
                    <div class="sb-input-wrap">
                        <input id="profile_current_password" name="current_password"
                               type="password" class="sb-input" placeholder="••••••••" required autocomplete="current-password">
                        <button type="button" class="sb-eye" onclick="togglePwd('profile_current_password', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="sb-field__err" id="emailPwdErr"></span>
                </div>

                {# Step 2: new email — revealed after password is entered #}
                <div id="emailStep2" class="sb-step2" aria-hidden="true">
                    <div class="sb-field">
                        <label for="profile_new_email">
                            Nouvel email <span class="sb-required">(requis)</span>
                        </label>
                        <input id="profile_new_email" name="new_email" type="email" class="sb-input"
                               placeholder="nouveau@exemple.com">
                        <span class="sb-field__err" id="emailErr"></span>
                    </div>
                </div>

                <button type="button" class="sb-btn sb-btn--secondary" id="emailContinueBtn" onclick="revealEmailStep()">
                    <i class="fas fa-arrow-right"></i> Continuer
                </button>

                <button type="submit" class="sb-btn sb-btn--primary sb-hidden" id="emailSaveBtn">
                    <i class="fas fa-save"></i> Enregistrer l'email
                </button>
            </div>
        </form>
    </div>

    {# ══════════════════════════════════════════
       SECTION 3 — Zone dangereuse
    ══════════════════════════════════════════ #}
    <div class="sb-section sb-section--danger">
        <h2 class="sb-section__title sb-section__title--danger">
            <i class="fas fa-exclamation-triangle"></i> Zone dangereuse
        </h2>
        <p class="sb-danger-desc">
            Ces actions sont <strong>irréversibles</strong>. Un mot de passe vous sera demandé pour confirmer.
        </p>

        <div class="sb-danger-inline">
            <button class="sb-btn sb-btn--outline-danger"
                    onclick="openDangerModal('deauthorize_sessions','Déconnecter toutes les sessions',
                        'Cela révoquera toutes vos sessions actives. Vous serez redirigé vers la page de connexion.')">
                <i class="fas fa-sign-out-alt"></i> Déconnecter les sessions
            </button>
            <button class="sb-btn sb-btn--outline-danger"
                    onclick="openDangerModal('purge_vault','Vider le coffre-fort',
                        'Tous vos secrets (mots de passe, clés API, identités, notes) seront définitivement supprimés.')">
                <i class="fas fa-trash-alt"></i> Vider le coffre
            </button>
            <button class="sb-btn sb-btn--solid-danger"
                    onclick="openDangerModal('delete_account','Supprimer le compte',
                        'Votre compte et toutes vos données seront supprimés définitivement.')">
                <i class="fas fa-user-slash"></i> Supprimer le compte
            </button>
        </div>
    </div>

</div>{# /sb-settings #}


{# ══════════════════════════════════════════
   DANGER MODAL
══════════════════════════════════════════ #}
<div id="dangerModal" class="sb-modal" aria-hidden="true">
    <div class="sb-modal__backdrop" onclick="closeDangerModal()"></div>
    <div class="sb-modal__dialog" role="dialog" aria-modal="true">
        <div class="sb-modal__header">
            <span>
                <i class="fas fa-exclamation-triangle" style="color:#f87171; margin-right:8px;"></i>
                <span id="dangerModalTitle">Confirmation</span>
            </span>
            <button class="sb-modal__close" onclick="closeDangerModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <form method="post" action="{{ path('app_settings') }}" id="dangerForm">
            <input type="hidden" name="action" id="dangerAction" value="">
            <div class="sb-modal__body">
                <p id="dangerModalDesc" class="sb-modal__desc"></p>
                <div class="sb-field">
                    <label for="dangerPassword">Confirmez avec votre mot de passe</label>
                    <div class="sb-input-wrap">
                        <input id="dangerPassword" name="confirm_password" type="password"
                               class="sb-input" placeholder="••••••••" required autocomplete="current-password">
                        <button type="button" class="sb-eye" onclick="togglePwd('dangerPassword', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="sb-field__err" id="dangerPwdErr"></span>
                </div>
            </div>
            <div class="sb-modal__footer">
                <button type="button" class="sb-btn sb-btn--ghost" onclick="closeDangerModal()">Annuler</button>
                <button type="submit" class="sb-btn sb-btn--solid-danger" id="dangerConfirmBtn">Confirmer</button>
            </div>
        </form>
    </div>
</div>


<style>
/* ══════════════════════════════════════════
   SETTINGS PAGE — VAULTWARDEN-STYLE FLOW
══════════════════════════════════════════ */

.sb-settings {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 28px 64px;
}

/* ── Flash ── */
.sb-flash {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
    font-size: 0.92rem; font-weight: 500;
}
.sb-flash--success { background: #1a2e1a; border: 1px solid #4dd4ac; color: #4dd4ac; }
.sb-flash--danger  { background: #2e1a1a; border: 1px solid #f87171; color: #f87171; }

/* ── Hero ── */
.sb-hero {
    display: flex; justify-content: space-between; align-items: center;
    gap: 24px; flex-wrap: wrap; margin-bottom: 28px;
}
.sb-hero__title { font-size: 2.2rem; font-weight: 700; color: #e0e0e0; margin: 0; line-height: 1.1; }

/* Profile card */
.sb-profile-card {
    background: #141b27; border: 1px solid #252d3d;
    border-radius: 16px; padding: 20px;
    min-width: 260px; max-width: 340px; width: 100%;
}
.sb-profile-card__top { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
.sb-profile-card__name  { color: #e0e0e0; font-weight: 700; font-size: 1rem; }
.sb-profile-card__email { color: #9ca3af; font-size: 0.83rem; }
.sb-profile-card__actions { display: flex; justify-content: flex-end; }

.sb-avatar {
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg, #6fbfff, #4dd4ac);
    display: flex; align-items: center; justify-content: center;
    color: #0f1117; font-weight: 700; font-size: 1.15rem; flex-shrink: 0;
}

/* ── Sections ── */
.sb-section {
    background: #141b27;
    border: 1px solid #252d3d;
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 20px;
}
.sb-section--danger {
    background: rgba(248,113,113,0.04);
    border-color: rgba(248,113,113,0.25);
}

.sb-section__title {
    font-size: 1rem; font-weight: 700; color: #e0e0e0;
    margin: 0 0 4px; display: flex; align-items: center; gap: 8px;
}
.sb-section__title--danger { color: #f87171; margin-bottom: 6px; }
.sb-section__desc {
    color: #6b7280; font-size: 0.87rem; margin: 0 0 18px; line-height: 1.55;
}

/* Inline row for name + email + button */
.sb-section__row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    align-items: end;
    gap: 16px;
}
.sb-field--inline { margin-bottom: 0; }
.sb-section__action {
    display: flex;
    align-items: center;
    /* align with input bottom */
    padding-bottom: 0;
}

/* ── Fields ── */
.sb-field { margin-bottom: 16px; }
.sb-field label {
    display: block; color: #7a8a9a; font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 7px;
}
.sb-required { color: #f87171; font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.78rem; }
.sb-field__err { display: block; color: #f87171; font-size: 0.8rem; margin-top: 5px; min-height: 16px; }

.sb-input {
    width: 100%; padding: 11px 14px;
    background: #1a2030; border: 1px solid #2a3040;
    color: #e0e0e0; border-radius: 10px; font-size: 0.92rem;
    outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
}
.sb-input:focus { border-color: #6fbfff; box-shadow: 0 0 0 3px rgba(111,191,255,0.12); }
.sb-input[readonly] { opacity: 0.45; cursor: not-allowed; }
.sb-input::placeholder { color: #3d4a5c; }

.sb-input-wrap { position: relative; }
.sb-input-wrap .sb-input { padding-right: 44px; }
.sb-eye {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: #6b7280; cursor: pointer;
    font-size: 0.88rem; padding: 4px; transition: color 0.15s;
}
.sb-eye:hover { color: #6fbfff; }

/* ── Step 2 reveal animation ── */
.sb-step2 {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease, margin 0.3s ease;
    margin-top: 0;
}
.sb-step2.revealed {
    max-height: 120px;
    opacity: 1;
    margin-top: 4px;
}
.sb-hidden { display: none !important; }

/* ── Danger inline ── */
.sb-danger-desc {
    color: #9a7060; font-size: 0.88rem; margin-bottom: 20px; line-height: 1.6;
}
.sb-danger-desc strong { color: #f87171; }

.sb-danger-inline {
    display: flex; flex-wrap: wrap; gap: 12px; align-items: center;
}

/* ── Buttons ── */
.sb-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 10px; font-size: 0.88rem; font-weight: 600;
    cursor: pointer; border: none; transition: all 0.15s; text-decoration: none;
    white-space: nowrap;
}

.sb-btn--primary {
    background: linear-gradient(135deg, #6fbfff, #4dd4ac);
    color: #0f1117;
}
.sb-btn--primary:hover { opacity: 0.85; transform: translateY(-1px); }

.sb-btn--secondary {
    background: #1e2a3a; color: #9ca3af;
    border: 1px solid #2a3a4a;
}
.sb-btn--secondary:hover { color: #e0e0e0; border-color: #4a6a8a; }

.sb-btn--ghost {
    background: transparent; color: #9a7a60;
    border: 1px solid #3a2e1a;
}
.sb-btn--ghost:hover { color: #E8D5B5; border-color: #C97B2E; }

/* Danger — outline style (for sessions & vault) */
.sb-btn--outline-danger {
    background: transparent; color: #f87171;
    border: 1px solid rgba(248,113,113,0.4);
}
.sb-btn--outline-danger:hover {
    background: rgba(248,113,113,0.08);
    border-color: #f87171;
}

/* Danger — solid style (for delete account) */
.sb-btn--solid-danger {
    background: rgba(248,113,113,0.15); color: #f87171;
    border: 1px solid rgba(248,113,113,0.5);
}
.sb-btn--solid-danger:hover { background: rgba(248,113,113,0.25); }

/* ── Modal ── */
.sb-modal {
    display: none; position: fixed; inset: 0; z-index: 9999;
    align-items: center; justify-content: center; padding: 20px;
}
.sb-modal.open { display: flex; }
.sb-modal__backdrop {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.78);
    backdrop-filter: blur(4px);
}
.sb-modal__dialog {
    position: relative; z-index: 1;
    background: #141b27; border: 1px solid #252d3d;
    border-radius: 18px; width: 100%; max-width: 460px;
    box-shadow: 0 28px 80px rgba(0,0,0,0.6);
    animation: modalIn 0.22s ease;
}
@keyframes modalIn {
    from { transform: translateY(18px) scale(0.97); opacity: 0; }
    to   { transform: none; opacity: 1; }
}
.sb-modal__header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px; border-bottom: 1px solid rgba(248,113,113,0.2);
    color: #E8D5B5; font-weight: 700; font-size: 0.93rem;
}
.sb-modal__close {
    background: none; border: none; color: #9a7a60; cursor: pointer;
    font-size: 1rem; padding: 4px 8px; border-radius: 6px; transition: color 0.15s;
}
.sb-modal__close:hover { color: #E8D5B5; }
.sb-modal__body { padding: 24px; }
.sb-modal__desc { color: #9a7060; font-size: 0.9rem; margin-bottom: 20px; line-height: 1.6; }
.sb-modal__footer {
    display: flex; justify-content: flex-end; gap: 10px;
    padding: 16px 24px; border-top: 1px solid rgba(248,113,113,0.15);
}

/* ── Responsive ── */
@media (max-width: 640px) {
    .sb-settings { padding: 20px 16px 48px; }
    .sb-section { padding: 18px 16px; }
    .sb-section__row {
        grid-template-columns: 1fr;
    }
    .sb-danger-inline { flex-direction: column; align-items: stretch; }
    .sb-danger-inline .sb-btn { justify-content: center; }
    .sb-hero__title { font-size: 1.7rem; }
}
</style>

<script>
/* ── Show/hide password ── */
function togglePwd(id, btn) {
    const inp  = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (inp.type === 'password') {
        inp.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        inp.type = 'password';
        icon.className = 'fas fa-eye';
    }
}

/* ── Email change: 2-step reveal ── */
function revealEmailStep() {
    const pwdField = document.getElementById('profile_current_password');
    const err      = document.getElementById('emailPwdErr');
    err.textContent = '';

    if (!pwdField.value.trim()) {
        err.textContent = 'Veuillez saisir votre mot de passe actuel.';
        pwdField.focus();
        return;
    }

    // Reveal new-email field
    const step2 = document.getElementById('emailStep2');
    step2.classList.add('revealed');
    step2.setAttribute('aria-hidden', 'false');

    // Swap buttons
    document.getElementById('emailContinueBtn').classList.add('sb-hidden');
    document.getElementById('emailSaveBtn').classList.remove('sb-hidden');

    // Focus new email
    setTimeout(() => document.getElementById('profile_new_email').focus(), 320);
}

/* ── Client-side validation: name form ── */
document.getElementById('formName')?.addEventListener('submit', function(e) {
    const name = document.getElementById('profile_name');
    document.getElementById('nameErr').textContent = '';
    if (!name.value.trim()) {
        document.getElementById('nameErr').textContent = 'Le nom ne peut pas être vide.';
        e.preventDefault();
    }
});

/* ── Client-side validation: email form ── */
document.getElementById('formEmail')?.addEventListener('submit', function(e) {
    let ok = true;
    const email = document.getElementById('profile_new_email');
    const pwd   = document.getElementById('profile_current_password');
    document.getElementById('emailErr').textContent    = '';
    document.getElementById('emailPwdErr').textContent = '';

    if (!pwd.value) {
        document.getElementById('emailPwdErr').textContent = 'Mot de passe requis.';
        ok = false;
    }
    if (!email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
        document.getElementById('emailErr').textContent = 'Email invalide.';
        ok = false;
    }
    if (!ok) e.preventDefault();
});

/* ── Danger modal ── */
function openDangerModal(action, title, desc) {
    document.getElementById('dangerAction').value           = action;
    document.getElementById('dangerModalTitle').textContent = title;
    document.getElementById('dangerModalDesc').textContent  = desc;
    document.getElementById('dangerPassword').value         = '';
    document.getElementById('dangerPwdErr').textContent     = '';
    document.getElementById('dangerModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(() => document.getElementById('dangerPassword').focus(), 100);
}

function closeDangerModal() {
    document.getElementById('dangerModal').classList.remove('open');
    document.body.style.overflow = '';
}

document.getElementById('dangerForm')?.addEventListener('submit', function(e) {
    const pwd = document.getElementById('dangerPassword');
    document.getElementById('dangerPwdErr').textContent = '';
    if (!pwd.value) {
        document.getElementById('dangerPwdErr').textContent = 'Mot de passe requis pour confirmer.';
        e.preventDefault();
    }
});

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDangerModal();
});
</script>
{% endblock %}
