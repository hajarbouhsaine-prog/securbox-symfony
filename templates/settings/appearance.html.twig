{% extends 'base.html.twig' %}

{% block title %}Apparence{% endblock %}

{% block body %}
<div class="sb-settings">
    <div class="sb-hero">
        <div class="sb-hero__left">
            <div class="sb-hero__badge">APPARENCE</div>
            <h1 class="sb-hero__title">Personnalisez votre interface</h1>
            <p class="sb-hero__sub">Choisissez un thème, une langue et vos préférences d’affichage.</p>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="sb-flash sb-flash--{{ label == 'error' ? 'danger' : 'success' }}">
                <i class="fas fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }}"></i>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="sb-grid">
        <div class="sb-card">
            <div class="sb-card__header">
                <span class="sb-card__icon sb-card__icon--blue"><i class="fas fa-palette"></i></span>
                <div>
                    <h3>Thème et langues</h3>
                    <p class="sb-card__desc">Sélectionnez le thème et la langue de l’application.</p>
                </div>
            </div>

            <form method="post" action="{{ path('app_settings_appearance') }}" novalidate>
                <input type="hidden" name="action" value="save_appearance">

                <div class="sb-field">
                    <label for="theme">Thème</label>
                    <select id="theme" name="theme" class="sb-input">
                        <option value="system" {{ app.session.get('settings_appearance_theme', 'system') == 'system' ? 'selected' : '' }}>Utiliser le thème du système</option>
                        <option value="light" {{ app.session.get('settings_appearance_theme', 'system') == 'light' ? 'selected' : '' }}>Clair</option>
                        <option value="dark" {{ app.session.get('settings_appearance_theme', 'system') == 'dark' ? 'selected' : '' }}>Sombre</option>
                    </select>
                </div>

                <div class="sb-field">
                    <label for="language">Langue</label>
                    <select id="language" name="language" class="sb-input">
                        <option value="fr" {{ app.request.locale == 'fr' ? 'selected' : '' }}>Français</option>
                        <option value="en" {{ app.request.locale == 'en' ? 'selected' : '' }}>Anglais</option>
                        <option value="ar" {{ app.request.locale == 'ar' ? 'selected' : '' }}>Arabe</option>
                    </select>
                </div>

                <div class="sb-field sb-checkbox-field">
                    <label for="show_website_icons">
                        <input id="show_website_icons" name="show_website_icons" type="checkbox"
                               value="1" {{ app.session.get('settings_appearance_show_icons', true) ? 'checked' : '' }}>
                        Afficher les icônes des sites et récupérer les URL de changement de mot de passe
                    </label>
                </div>

                <button type="submit" class="sb-btn sb-btn--primary">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </form>
        </div>

        <div class="sb-card sb-card--danger">
            <div class="sb-card__header">
                <span class="sb-card__icon sb-card__icon--red"><i class="fas fa-info-circle"></i></span>
                <div>
                    <h3>Conseils d’apparence</h3>
                    <p class="sb-card__desc">Votre sélection améliore votre confort de lecture et adapte l’interface à votre style.</p>
                </div>
            </div>

            <ul class="sb-list">
                <li>Choisissez le thème sombre pour un affichage plus doux en faible luminosité.</li>
                <li>Utilisez la langue française pour une expérience complète en français.</li>
                <li>Activez les icônes des sites pour retrouver plus rapidement vos identifiants.</li>
            </ul>
        </div>
    </div>
</div>

<style>
    .sb-list {
        margin: 18px 0 0 0;
        padding-left: 20px;
        color: #cbd5e1;
        line-height: 1.7;
    }
    .sb-list li {
        margin-bottom: 10px;
    }
    .sb-checkbox-field {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin: 16px 0 24px;
    }
    .sb-checkbox-field label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.94rem;
        color: #d1d5db;
    }
    .sb-checkbox-field input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: #4dd4ac;
    }
</style>
{% endblock %}
