{% extends app.request.query.get('modal') == '1' or app.request.headers.get('X-Requested-With') == 'XMLHttpRequest' ? 'modal_base.html.twig' : 'base.html.twig' %}
{% block title %}Nouveau Secret{% endblock %}
{% block body %}

<style>
/* ── Use theme variables instead of hardcoded dark colors ── */
.nv-card        { background: var(--bg-card-alt); border-color: var(--border-main); }
.nv-row         { border-bottom-color: var(--border-subtle); }
.nv-row:focus-within { background: var(--bg-hover); }
.nv-field label { color: var(--text-muted); }
.nv-field input,
.nv-field textarea { color: var(--text-primary); }
.nv-section-head { color: var(--text-muted); }
.nv-banner      { background: var(--bg-active); border-color: var(--border-input); color: var(--text-accent); }
.nv-hint-row    { color: var(--text-muted); border-bottom-color: var(--border-subtle); }
.nv-check-row   { color: var(--text-secondary); border-bottom-color: var(--border-subtle); }
.nv-check-row:hover { background: var(--bg-hover); }
.nv-add-link    { color: var(--accent-blue); border-top-color: var(--border-subtle); }
.nv-add-link:hover { background: var(--bg-hover); }
.nv-attach-trigger { color: var(--accent-blue); border-bottom-color: var(--border-subtle); }
.nv-attach-trigger:hover { background: var(--bg-hover); }
.nv-strength    { background: var(--border-subtle); }
.nv-header h1   { color: var(--text-primary); }
.nv-cancel      { border-color: var(--border-main); color: var(--text-muted); }
.nv-cancel:hover { background: var(--bg-hover); color: var(--text-primary); }
.nv-select-wrap .nv-select-label { color: var(--text-muted); }
.nv-select-wrap .nv-select-value { color: var(--text-primary); }
.nv-field-split { border-left-color: var(--border-subtle); }

/* ── Page layout ── */
.nv-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 0 48px;
}
.nv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
}
.nv-header h1 {
    color: var(--text-primary);
    font-size: 1.35rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
}
.nv-header h1 i { color: var(--accent-blue); }
.nv-fav {
    background: none; border: none;
    color: var(--text-muted); font-size: 1.2rem;
    cursor: pointer; transition: color 0.2s; padding: 4px 6px;
    border-radius: 6px;
}
.nv-fav:hover { color: #fbbf24; background: var(--bg-input); }
.nv-fav.active { color: #fbbf24; }

/* ── Section ── */
.nv-section { margin-bottom: 24px; }
.nv-section-head {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    padding-left: 2px;
}
.nv-card {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-main);
    border-radius: 10px;
    overflow: hidden;
}

/* ── Field row ── */
.nv-row {
    display: flex;
    align-items: stretch;
    min-height: 56px;
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
    transition: background 0.12s;
}
.nv-row:last-child { border-bottom: none; }
.nv-row:focus-within { background: var(--bg-hover); }

/* ── Floating label field ── */
.nv-field {
    position: relative;
    flex: 1;
    min-width: 0;
}
.nv-field label {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: var(--text-muted);
    pointer-events: none;
    transition: all 0.15s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: calc(100% - 32px);
}
.nv-field input,
.nv-field textarea {
    width: 100%;
    height: 100%;
    min-height: 56px;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-size: 0.92rem;
    padding: 24px 16px 8px;
    font-family: inherit;
    line-height: 1.4;
}
.nv-field textarea {
    resize: vertical;
    min-height: 100px;
    padding-top: 28px;
}
.nv-field input::placeholder,
.nv-field textarea::placeholder { color: transparent; }

/* Float label when focused or has value */
.nv-field input:focus ~ label,
.nv-field input:not(:placeholder-shown) ~ label,
.nv-field textarea:focus ~ label,
.nv-field textarea:not(:placeholder-shown) ~ label {
    top: 10px;
    transform: none;
    font-size: 0.7rem;
    letter-spacing: 0.01em;
    color: var(--text-muted);
}
.nv-field input:focus ~ label,
.nv-field textarea:focus ~ label { color: var(--accent-blue); }

/* ── Custom select ── */
.nv-select-wrap {
    position: relative;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 10px 16px 10px;
    cursor: pointer;
}
.nv-select-wrap .nv-select-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    margin-bottom: 3px;
    pointer-events: none;
}
.nv-select-wrap .nv-select-value {
    font-size: 0.92rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    pointer-events: none;
}
.nv-select-wrap .nv-select-arrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.8rem;
    pointer-events: none;
    transition: transform 0.2s;
}
.nv-select-wrap select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    font-size: 1rem;
}
.nv-select-wrap:focus-within { background: var(--bg-hover); }
.nv-select-wrap:focus-within .nv-select-arrow { color: var(--accent-blue); transform: translateY(-50%) rotate(180deg); }
.nv-select-wrap:focus-within .nv-select-label { color: var(--accent-blue); }

/* ── Row actions ── */
.nv-actions {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0 10px 0 4px;
    flex-shrink: 0;
}
.nv-btn {
    width: 34px; height: 34px;
    background: none; border: none;
    border-radius: 7px;
    color: var(--text-muted);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    transition: all 0.15s;
    flex-shrink: 0;
}
.nv-btn:hover { color: var(--text-secondary); background: var(--border-main); }
.nv-btn.danger:hover { color: #f87171; }
.nv-btn.success { color: var(--accent-teal); }

/* ── Hint row ── */
.nv-hint-row {
    padding: 8px 16px 10px;
    font-size: 0.78rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    gap: 6px;
}
.nv-hint-row:last-child { border-bottom: none; }

/* ── Strength bar ── */
.nv-strength {
    height: 2px;
    background: var(--border-subtle);
    margin: 0 16px 0;
    border-radius: 2px;
    overflow: hidden;
}
.nv-strength-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.3s, background 0.3s;
    width: 0;
}

/* ── Checkbox row ── */
.nv-check-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    color: var(--text-secondary);
    font-size: 0.88rem;
    cursor: pointer;
    border-bottom: 1px solid var(--border-subtle);
    user-select: none;
    transition: background 0.12s;
}
.nv-check-row:hover { background: var(--bg-hover); }
.nv-check-row:last-child { border-bottom: none; }
.nv-check-row input[type="checkbox"] {
    width: 16px; height: 16px;
    accent-color: var(--accent-blue);
    cursor: pointer;
    flex-shrink: 0;
}

/* ── Add link ── */
.nv-add-link {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    color: var(--accent-blue);
    font-size: 0.85rem;
    cursor: pointer;
    background: none;
    border: none;
    border-top: 1px solid var(--border-subtle);
    width: 100%;
    transition: color 0.15s, background 0.12s;
    font-family: inherit;
}
.nv-add-link:hover { color: var(--accent-teal); background: var(--bg-hover); }

/* ── Split row ── */
.nv-field-split { border-left: 1px solid var(--border-subtle); }

/* ── Banner ── */
.nv-banner {
    background: var(--bg-active);
    border: 1px solid var(--border-input);
    border-radius: 10px;
    padding: 12px 40px 12px 14px;
    margin-bottom: 24px;
    font-size: 0.84rem;
    color: var(--accent-blue);
    position: relative;
    line-height: 1.55;
}
.nv-banner strong { color: var(--accent-blue); }
.nv-banner-close {
    position: absolute; top: 9px; right: 11px;
    background: none; border: none; color: var(--text-muted);
    cursor: pointer; font-size: 1rem; padding: 2px;
}
.nv-banner-close:hover { color: var(--text-muted); }

/* ── Type sections ── */
.type-section { display: none; }
.type-section.active { display: block; }

/* ── Footer ── */
.nv-footer {
    display: flex;
    gap: 10px;
    margin-top: 28px;
}
.nv-save {
    background: linear-gradient(135deg, #6fbfff, #4dd4ac);
    border: none; border-radius: 8px;
    color: #0f1117; font-weight: 700; font-size: 0.9rem;
    padding: 11px 32px; cursor: pointer; transition: opacity 0.2s;
    font-family: inherit;
}
.nv-save:hover { opacity: 0.88; }
.nv-cancel {
    background: none; border: 1px solid var(--border-main); border-radius: 8px;
    color: var(--text-muted); font-size: 0.9rem; padding: 11px 24px;
    cursor: pointer; text-decoration: none; display: flex; align-items: center;
    transition: all 0.15s; font-family: inherit;
}
.nv-cancel:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border-main); }
.modal-mode .nv-header { display: none; }

/* ══════════════════════════════════════════
   ── CHAMP PERSONNALISÉ — Tooltip & exemples ──
══════════════════════════════════════════ */
.nv-section-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    padding: 0 0 8px 2px;
    line-height: 1.5;
}

/* Bouton "?" discret à côté du titre de section */
.nv-section-head-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
}
.nv-help-btn {
    background: none;
    border: 1px solid var(--border-main);
    border-radius: 50%;
    width: 18px; height: 18px;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
    line-height: 1;
}
.nv-help-btn:hover {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: #fff;
}

/* Tooltip/popup d'aide */
.nv-help-popup {
    display: none;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-main);
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 10px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.6;
    animation: fadeInDown 0.18s ease;
}
.nv-help-popup.visible { display: block; }
@keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
}
.nv-help-popup strong { color: var(--text-primary); }
.nv-help-popup .nv-example-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
}
.nv-chip {
    background: var(--bg-active);
    border: 1px solid var(--border-main);
    border-radius: 20px;
    padding: 4px 11px;
    font-size: 0.75rem;
    color: var(--accent-blue);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 5px;
}
.nv-chip:hover {
    background: var(--accent-blue);
    color: #0f1117;
    border-color: var(--accent-blue);
}

/* ══════════════════════════════════════════
   ── PIÈCE JOINTE — redesign ──
══════════════════════════════════════════ */
.nv-attach-zone {
    border: 2px dashed var(--border-main);
    border-radius: 10px;
    margin: 4px 16px 14px;
    padding: 18px 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.18s;
    background: transparent;
}
.nv-attach-zone:hover,
.nv-attach-zone.drag-over {
    border-color: var(--accent-blue);
    background: var(--bg-active);
}
.nv-attach-zone-icon {
    font-size: 1.6rem;
    color: var(--accent-blue);
    margin-bottom: 8px;
}
.nv-attach-zone-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
}
.nv-attach-zone-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
}
.nv-attach-zone-sub span {
    color: var(--accent-blue);
    font-weight: 500;
}
/* Exemples d'utilisation pièce jointe */
.nv-attach-examples {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-top: 12px;
}
.nv-attach-ex {
    background: var(--bg-input);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    padding: 3px 9px;
    font-size: 0.72rem;
    color: var(--text-muted);
    white-space: nowrap;
}

/* Liste des fichiers joints */
.nv-attach-list {
    padding: 0 16px 4px;
}
.nv-attach-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-subtle);
}
.nv-attach-item:last-child { border-bottom: none; }
.nv-attach-thumb {
    width: 42px; height: 42px;
    border-radius: 6px;
    object-fit: cover;
    background: var(--border-main);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    color: var(--text-muted);
    overflow: hidden;
}
.nv-attach-thumb img { width: 100%; height: 100%; object-fit: cover; }
.nv-attach-info { flex: 1; min-width: 0; }
.nv-attach-name {
    background: var(--bg-input);
    border: 1px solid var(--border-main);
    border-radius: 7px;
    padding: 6px 12px;
    color: var(--text-primary);
    font-size: 0.88rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.nv-attach-size {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 3px;
    padding-left: 2px;
}
/* Avertissement taille dépassée */
.nv-attach-warn {
    font-size: 0.72rem;
    color: #f97316;
    margin-top: 2px;
    padding-left: 2px;
    display: none;
}
.nv-attach-warn.show { display: block; }

.nv-attach-delete {
    background: none; border: none;
    color: var(--text-muted); cursor: pointer;
    font-size: 1rem; padding: 4px 6px;
    border-radius: 6px; flex-shrink: 0;
    transition: color 0.15s;
}
.nv-attach-delete:hover { color: #f87171; }

/* Compteur & limite */
.nv-attach-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px 14px;
    font-size: 0.75rem;
    color: var(--text-muted);
}
.nv-attach-footer .nv-attach-limit { color: var(--text-muted); }
.nv-attach-footer .nv-attach-count { font-weight: 600; color: var(--accent-blue); }

/* drag-over on options card */
.nv-card.drag-over { border-color: var(--accent-blue); background: var(--bg-active); }
</style>


<div class="nv-wrap{% if app.request.query.get('modal') == '1' or app.request.headers.get('X-Requested-With') == 'XMLHttpRequest' %} modal-mode{% endif %}">

{# ── Header ── #}
<div class="nv-header">
    <h1><i class="fas fa-plus-circle"></i> Nouveau Secret</h1>
    <button type="button" class="nv-fav" id="favBtn" onclick="toggleFavorite()" title="Ajouter aux favoris">
        <i class="fas fa-star"></i>
    </button>
</div>

<form method="post"
      id="secretForm"
      action="{{ path('app_vault_new', {'type': app.request.query.get('type', 'password')}) }}"
      enctype="multipart/form-data">
<input type="hidden" name="_token" value="{{ csrf_token('new_secret') }}">

{# ── Autofill banner ── #}
<div class="nv-banner" id="autofillBanner">
    <button type="button" class="nv-banner-close" onclick="this.parentElement.style.display='none'">×</button>
    <i class="fas fa-info-circle me-1"></i>
    Ajoutez un <strong>site web (URI)</strong> pour que ce secret apparaisse comme suggestion lors de la navigation.
</div>

{# ══════════════════════════════════════════
   SECTION 1 — Détails de l'élément
══════════════════════════════════════════ #}
<div class="nv-section">
    <div class="nv-section-head">
        <i class="fas fa-info-circle me-1"></i> Détails de l'élément
    </div>
    <div class="nv-card">

        {# Nom #}
        <div class="nv-row">
            <div class="nv-field">
                <input type="text" name="name" id="nameInput" placeholder=" " required>
                <label for="nameInput">Nom de l'élément (requis)</label>
            </div>
        </div>

        {# Collection #}
        <div class="nv-row">
            <div class="nv-select-wrap">
                <div class="nv-select-label">Collection (requis)</div>
                <div class="nv-select-value" id="collectionDisplay">
                    <i class="fas fa-layer-group fa-fw" style="color:var(--text-muted); font-size:0.85rem;"></i>
                    <span id="collectionText">
                        {% if currentCollection is defined and currentCollection %}
                            {{ currentCollection.name }}
                        {% else %}
                            -- Sélectionner --
                        {% endif %}
                    </span>
                </div>
                <i class="fas fa-chevron-down nv-select-arrow"></i>
                <select name="collection_id" required onchange="updateCollectionDisplay(this)">
                    <option value="">-- Sélectionner --</option>
                    {% for col in collections %}
                    <option value="{{ col.id }}"
                        {% if currentCollection is defined and currentCollection and currentCollection.id == col.id %}selected{% endif %}>
                        {{ col.name }}
                    </option>
                    {% endfor %}
                </select>
            </div>
        </div>

        {# Type #}
        <div class="nv-row">
            <div class="nv-select-wrap">
                <div class="nv-select-label">Type de secret</div>
                <div class="nv-select-value" id="typeDisplay">
                    <span id="typeText">🔑 Mot de passe</span>
                </div>
                <i class="fas fa-chevron-down nv-select-arrow"></i>
                <select name="type" id="typeSelect" onchange="onTypeChange(this.value); updateDisplay('type', this)">
                    <option value="password" {{ defaultType == 'password' ? 'selected' : '' }}>🔑 Mot de passe</option>
                    <option value="api_key"  {{ defaultType == 'api_key'  ? 'selected' : '' }}>⚙️ Clé API</option>
                    <option value="note"     {{ defaultType == 'note'     ? 'selected' : '' }}>📝 Note sécurisée</option>
                    <option value="identity" {{ defaultType == 'identity' ? 'selected' : '' }}>👤 Identité</option>
                </select>
            </div>
        </div>

    </div>
</div>

{# ══ SECTION PASSWORD ══ #}
<div id="section-password" class="type-section">
    <div class="nv-section">
        <div class="nv-section-head">
            <i class="fas fa-key me-1"></i> Identifiants de connexion
        </div>
        <div class="nv-card">
            <div class="nv-row">
                <div class="nv-field">
                    <input type="text" name="username" id="usernameInput" placeholder=" ">
                    <label for="usernameInput">Nom d'utilisateur</label>
                </div>
                <div class="nv-actions">
                    <button type="button" class="nv-btn" title="Générer un nom" onclick="generateUsername()">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
            </div>
            <div class="nv-row">
                <div class="nv-field">
                    <input type="password" name="password" id="passwordInput" placeholder=" ">
                    <label for="passwordInput">Mot de passe</label>
                </div>
                <div class="nv-actions">
                    <button type="button" class="nv-btn" title="Afficher / Masquer" onclick="togglePwdVisibility()">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                    <button type="button" class="nv-btn" title="Générer un mot de passe fort" onclick="generatePassword()">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
            </div>
            <div class="nv-strength" id="strengthBarWrap" style="display:none;">
                <div class="nv-strength-fill" id="strengthFill"></div>
            </div>
            <div class="nv-hint-row">
                <i class="fas fa-sync-alt" style="font-size:0.75rem;"></i>
                Utilisez le générateur pour créer un mot de passe unique et fort
            </div>
            <div class="nv-row">
                <div class="nv-field">
                    <input type="text" name="totp" id="totpInput" placeholder=" ">
                    <label for="totpInput">Code d'authentification (TOTP)</label>
                </div>
                <div class="nv-actions">
                    <button type="button" class="nv-btn" title="C'est quoi le TOTP ?"
                            onclick="alert('Le TOTP (Time-based One-Time Password) est le code 6 chiffres généré par une app comme Google Authenticator. Collez ici la clé secrète (otpauth://).')">
                        <i class="fas fa-question-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="nv-section">
        <div class="nv-section-head">
            <i class="fas fa-globe me-1"></i> Remplissage automatique
        </div>
        <div class="nv-card">
            <div class="nv-row">
