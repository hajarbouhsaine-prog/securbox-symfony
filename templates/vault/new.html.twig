<script>
(function() {

/* ═══════════════════════════════════
   AIDE CONTEXTUELLE
═══════════════════════════════════ */
function toggleHelp(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle('visible');
}

/* ═══════════════════════════════════
   TYPE SWITCHING
═══════════════════════════════════ */
const NV_TYPE_TITLES = {
    password: '🔑 Nouveau Mot de passe',
    api_key:  '⚙️ Nouvelle Clé API',
    note:     '📝 Nouvelle Note sécurisée',
    identity: '👤 Nouvelle Identité'
};

function onTypeChange(type) {
    ['password','api_key','note','identity'].forEach(t => {
        document.getElementById('section-' + t)?.classList.toggle('active', t === type);
    });
    const banner = document.getElementById('autofillBanner');
    if (banner) banner.style.display = (type === 'password') ? 'block' : 'none';

    // Met à jour les chips selon le type
    updateChipsForType(type);

    const titleEl = document.getElementById('vaultModalTitle');
    if (titleEl && NV_TYPE_TITLES[type]) {
        titleEl.textContent = NV_TYPE_TITLES[type];
    }
}

/* Chips contextuels selon le type de secret */
function updateChipsForType(type) {
    const container = document.getElementById('customChips');
    if (!container) return;
    const sets = {
        password: [
            { label: 'Serveur VPN',        icon: 'fa-network-wired', name: 'Serveur VPN',        val: '' },
            { label: 'Port',               icon: 'fa-plug',          name: 'Port',               val: '1194' },
            { label: 'Code PIN',           icon: 'fa-lock',          name: 'Code PIN',           val: '' },
            { label: 'Question secrète',   icon: 'fa-question',      name: 'Question secrète',   val: '' },
            { label: 'Date d\'expiration', icon: 'fa-calendar-alt',  name: 'Date d\'expiration', val: '' },
        ],
        api_key: [
            { label: 'Quota / Limite',     icon: 'fa-tachometer-alt', name: 'Quota mensuel', val: '' },
            { label: 'Clé publique',       icon: 'fa-key',            name: 'Clé publique',  val: '' },
            { label: 'Webhook URL',        icon: 'fa-link',           name: 'Webhook URL',   val: '' },
            { label: 'Token expiration',   icon: 'fa-hourglass-half', name: 'Expiration',    val: '' },
        ],
        identity: [
            { label: 'N° Passeport',       icon: 'fa-passport',       name: 'N° Passeport',  val: '' },
            { label: 'N° Sécurité sociale',icon: 'fa-id-badge',       name: 'N° SS',         val: '' },
            { label: 'Date de naissance',  icon: 'fa-birthday-cake',  name: 'Né(e) le',      val: '' },
        ],
        note: [
            { label: 'Source / Référence', icon: 'fa-book',           name: 'Source',         val: '' },
            { label: 'Catégorie',          icon: 'fa-tag',            name: 'Catégorie',      val: '' },
            { label: 'Valide jusqu\'au',   icon: 'fa-calendar-check', name: 'Valide jusqu\'au', val: '' },
        ],
    };
    const chips = sets[type] || sets.password;
    container.innerHTML = chips.map(c =>
        `<span class="nv-chip" onclick="addCustomFieldWithValues('${c.name}', '${c.val}')">
            <i class="fas ${c.icon}"></i> ${c.label}
         </span>`
    ).join('');
}

/* ── Custom select display ── */
function updateDisplay(which, sel) {
    const text = sel.options[sel.selectedIndex].text;
    if (which === 'type') document.getElementById('typeText').textContent = text;
}
function updateCollectionDisplay(sel) {
    document.getElementById('collectionText').textContent = sel.options[sel.selectedIndex].text;
}

document.addEventListener('DOMContentLoaded', () => {
    const sel = document.getElementById('typeSelect');
    if (sel) {
        onTypeChange(sel.value);
        updateDisplay('type', sel);
    }
});
(function() {
    const sel = document.getElementById('typeSelect');
    if (sel) { onTypeChange(sel.value); updateDisplay('type', sel); }
})();

/* ── Password visibility ── */
function togglePwdVisibility() {
    const inp = document.getElementById('passwordInput');
    const ico = document.getElementById('eyeIcon');
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    ico.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
}
function toggleApiVisibility() {
    const inp = document.getElementById('apiKeyInput');
    const ico = document.getElementById('apiEyeIcon');
    if (!inp) return;
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    ico.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
}

/* ── Copy API key ── */
function copyApiKey() {
    const inp = document.getElementById('apiKeyInput');
    const ico = document.getElementById('apiCopyIcon');
    if (inp?.value) {
        navigator.clipboard.writeText(inp.value);
        ico.className = 'fas fa-check';
        ico.closest('.nv-btn').style.color = '#4dd4ac';
        setTimeout(() => { ico.className = 'fas fa-copy'; ico.closest('.nv-btn').style.color = ''; }, 1600);
    }
}

/* ── Password generator ── */
function generatePassword() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%&*';
    const pwd = Array.from({length: 20}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
    const inp = document.getElementById('passwordInput');
    if (!inp) return;
    inp.value = pwd;
    inp.type = 'text';
    document.getElementById('eyeIcon').className = 'fas fa-eye-slash';
    updateStrength(pwd);
}
function generateUsername() {
    const a = ['swift','bold','calm','dark','cool','bright','sharp'];
    const n = ['falcon','tiger','ocean','storm','pixel','comet','river'];
    const inp = document.getElementById('usernameInput');
    if (inp) inp.value = a[~~(Math.random()*a.length)] + '_' + n[~~(Math.random()*n.length)] + ~~(Math.random()*999);
}

/* ── Strength ── */
function updateStrength(pwd) {
    const fill = document.getElementById('strengthFill');
    const wrap = document.getElementById('strengthBarWrap');
    if (!fill) return;
    const checks = [pwd.length >= 8, pwd.length >= 16, /[A-Z]/.test(pwd) && /[a-z]/.test(pwd), /[0-9]/.test(pwd), /[^A-Za-z0-9]/.test(pwd)];
    const s = checks.filter(Boolean).length;
    fill.style.width = (s * 20) + '%';
    fill.style.background = ['#ef4444','#f97316','#eab308','#22c55e','#4dd4ac'][s - 1] || '#252d3d';
    if (wrap) wrap.style.display = pwd ? 'block' : 'none';
}
document.addEventListener('input', e => { if (e.target.name === 'password') updateStrength(e.target.value); });

/* ── Websites ── */
function addWebsite() {
    const uid = 'w' + Date.now(), row = document.createElement('div');
    row.className = 'nv-row';
    row.innerHTML = `
        <div class="nv-field">
            <input type="url" name="website_extra[]" id="${uid}" placeholder=" ">
            <label for="${uid}">Site web (URI)</label>
        </div>
        <div class="nv-actions">
            <button type="button" class="nv-btn danger" onclick="this.closest('.nv-row').remove()">
                <i class="fas fa-times"></i>
            </button>
        </div>`;
    document.getElementById('extraWebsites').appendChild(row);
}

/* ═══════════════════════════════════
   CHAMPS PERSONNALISÉS
═══════════════════════════════════ */
function addCustomField() {
    addCustomFieldWithValues('', '');
}

function addCustomFieldWithValues(name, val) {
    const u1 = 'k'+Date.now(), u2 = 'v'+Date.now()+1;
    const row = document.createElement('div');
    row.className = 'nv-row';
    row.innerHTML = `
        <div class="nv-field" style="flex:1;">
            <input type="text" name="custom_field_name[]" id="${u1}" placeholder=" " value="${name}">
            <label for="${u1}">Nom du champ</label>
        </div>
        <div class="nv-field nv-field-split" style="flex:2;">
            <input type="text" name="custom_field_value[]" id="${u2}" placeholder=" " value="${val}">
            <label for="${u2}">Valeur</label>
        </div>
        <div class="nv-actions">
            <button type="button" class="nv-btn danger" onclick="this.closest('.nv-row').remove()">
                <i class="fas fa-times"></i>
            </button>
        </div>`;
    document.getElementById('extraFields').appendChild(row);

    // Fermer la popup d'aide après insertion d'un chip
    if (name) {
        document.getElementById('customHelp')?.classList.remove('visible');
    }
    // Focus sur le champ valeur si le nom était déjà fourni
    if (name && !val) {
        setTimeout(() => document.getElementById(u2)?.focus(), 50);
    }
}

/* ── Favorite ── */
function toggleFavorite() { document.getElementById('favBtn')?.classList.toggle('active'); }

/* ═══════════════════════════════════
   PIÈCES JOINTES
   ✅ Les fichiers sont conservés dans un DataTransfer (fileStore)
      et réinjectés dans l'<input> avant chaque submit.
      Aucun FileReader n'est utilisé pour les données — seulement
      pour les miniatures d'aperçu des images.
═══════════════════════════════════ */
const MAX_FILE_SIZE = 50 * 1024 * 1024; // 50 Mo
const MAX_FILES     = 10;

// fileStore conserve les File objects natifs pour le multipart/form-data
const fileStore = new DataTransfer();

function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' Ko';
    return (bytes / (1024 * 1024)).toFixed(2) + ' Mo';
}
function isImage(file) { return file.type.startsWith('image/'); }

function handleDrop(e) {
    e.preventDefault();
    document.getElementById('attachZone').classList.remove('drag-over');
    if (e.dataTransfer.files.length) handleAttachments(e.dataTransfer.files);
}

function handleAttachments(files) {
    const list   = document.getElementById('attachList');
    const footer = document.getElementById('attachFooter');

    [...files].forEach(file => {
        // Vérifier la limite du nombre de fichiers
        if (fileStore.files.length >= MAX_FILES) {
            alert(`Maximum ${MAX_FILES} fichiers autorisés.`);
            return;
        }

        const oversized = file.size > MAX_FILE_SIZE;

        // ✅ Ajouter le fichier natif au DataTransfer (pas de FileReader)
        if (!oversized) {
            fileStore.items.add(file);
        }

        // Construire la ligne d'affichage
        const item = document.createElement('div');
        item.className = 'nv-attach-item';
        item.dataset.name = file.name; // pour retrouver le fichier si suppression

        /* Icône / miniature */
        const thumb = document.createElement('div');
        thumb.className = 'nv-attach-thumb';

        if (isImage(file)) {
            // Miniature uniquement pour les images (lecture base64 pour affichage)
            const img = document.createElement('img');
            const reader = new FileReader();
            reader.onload = ev => { img.src = ev.target.result; };
            reader.readAsDataURL(file);
            thumb.appendChild(img);
        } else if (file.type.startsWith('video/')) {
            thumb.innerHTML = '<i class="fas fa-film"></i>';
        } else if (file.name.match(/\.pdf$/i)) {
            thumb.innerHTML = '<i class="fas fa-file-pdf" style="color:#f87171;"></i>';
        } else if (file.name.match(/\.(doc|docx)$/i)) {
            thumb.innerHTML = '<i class="fas fa-file-word" style="color:#6fbfff;"></i>';
        } else if (file.name.match(/\.(ovpn|conf|key|pem|cer|p12)$/i)) {
            thumb.innerHTML = '<i class="fas fa-shield-alt" style="color:#4dd4ac;"></i>';
        } else {
            thumb.innerHTML = '<i class="fas fa-file"></i>';
        }

        /* Info */
        const info = document.createElement('div');
        info.className = 'nv-attach-info';

        const nameEl = document.createElement('div');
        nameEl.className = 'nv-attach-name';
        nameEl.textContent = file.name;

        const sizeEl = document.createElement('div');
        sizeEl.className = 'nv-attach-size';
        sizeEl.textContent = formatBytes(file.size);

        const warnEl = document.createElement('div');
        warnEl.className = 'nv-attach-warn' + (oversized ? ' show' : '');
        warnEl.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i>Fichier trop volumineux (max 50 Mo) — ignoré';

        info.appendChild(nameEl);
        info.appendChild(sizeEl);
        info.appendChild(warnEl);

        /* Bouton supprimer */
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'nv-attach-delete';
        del.title = 'Supprimer';
        del.innerHTML = '<i class="fas fa-trash"></i>';
        del.onclick = () => {
            // Retirer le fichier du DataTransfer
            const newDt = new DataTransfer();
            [...fileStore.files].forEach(f => {
                if (f.name !== file.name || f.size !== file.size) {
                    newDt.items.add(f);
                }
            });
            // Vider et reremplir fileStore
            while (fileStore.items.length > 0) fileStore.items.remove(0);
            [...newDt.files].forEach(f => fileStore.items.add(f));
            // Synchroniser l'input
            document.getElementById('attachInput').files = fileStore.files;
            item.remove();
            updateAttachCount();
        };

        item.appendChild(thumb);
        item.appendChild(info);
        item.appendChild(del);
        list.appendChild(item);
    });

    // ✅ Synchroniser l'<input file> avec fileStore — c'est ce que PHP reçoit
    document.getElementById('attachInput').files = fileStore.files;
    // NE PAS vider l'input ici !
    updateAttachCount();
    if (footer) footer.style.display = fileStore.files.length > 0 ? 'flex' : 'none';
}

function updateAttachCount() {
    const n = fileStore.files.length;
    const countEl = document.getElementById('attachCount');
    const footer  = document.getElementById('attachFooter');
    if (countEl) countEl.textContent = n + ' fichier' + (n > 1 ? 's' : '') + ' joint' + (n > 1 ? 's' : '');
    if (footer)  footer.style.display = n > 0 ? 'flex' : 'none';
}

/* ═══════════════════════════════════
   PREPARE DATA
   ⚠️  Les fichiers voyagent via multipart/form-data (input[name="attachments[]"]).
       On ne met JAMAIS de base64 dans le JSON → pas de crash max_allowed_packet.
       Le contrôleur PHP lit $request->files et sauvegarde sur disque.
═══════════════════════════════════ */
function prepareData(e) {
    const type = document.getElementById('typeSelect').value;
    let d = { type };

    if (type === 'password') {
        d.username = document.querySelector('[name="username"]')?.value || '';
        d.password = document.querySelector('[name="password"]')?.value || '';
        d.website  = document.querySelector('[name="website"]')?.value  || '';
        d.totp     = document.querySelector('[name="totp"]')?.value     || '';
    } else if (type === 'api_key') {
        d.service  = document.querySelector('[name="api_service"]')?.value   || '';
        d.key      = document.querySelector('[name="api_key_value"]')?.value || '';
        d.base_url = document.querySelector('[name="api_base_url"]')?.value  || '';
        d.env      = document.querySelector('[name="api_env"]')?.value       || '';
    } else if (type === 'identity') {
        ['id_firstname','id_lastname','id_email','id_phone','id_company','id_address','id_city','id_country']
            .forEach(f => d[f.replace('id_', '')] = document.querySelector(`[name="${f}"]`)?.value || '');
    } else if (type === 'note') {
        d.content = document.querySelector('[name="note_content"]')?.value || '';
    }

    // Champs personnalisés
    const fnames = [...document.querySelectorAll('[name="custom_field_name[]"]')].map(i => i.value);
    const fvals  = [...document.querySelectorAll('[name="custom_field_value[]"]')].map(i => i.value);
    if (fnames.length) d.custom_fields = fnames.map((k, i) => ({ key: k, value: fvals[i] }));

    d.notes = document.querySelector('[name="notes"]')?.value || '';

    // ✅ PAS de base64 ici — les fichiers sont envoyés séparément
    // via input[name="attachments[]"] en multipart/form-data.
    // Le contrôleur PHP les sauvegarde sur disque et stocke uniquement
    // les métadonnées (nom, chemin, taille) dans le JSON chiffré.
    d.attachments_count = fileStore.files.length; // nombre de fichiers réels dans l'input

    document.getElementById('hiddenData').value = JSON.stringify(d);
}

document.getElementById('secretForm')?.addEventListener('submit', function() { prepareData(); });

/* Expose to global scope */
window.onTypeChange            = onTypeChange;
window.updateDisplay           = updateDisplay;
window.updateCollectionDisplay = updateCollectionDisplay;
window.togglePwdVisibility     = togglePwdVisibility;
window.toggleApiVisibility     = toggleApiVisibility;
window.copyApiKey              = copyApiKey;
window.generatePassword        = generatePassword;
window.generateUsername        = generateUsername;
window.addWebsite              = addWebsite;
window.addCustomField          = addCustomField;
window.addCustomFieldWithValues= addCustomFieldWithValues;
window.toggleFavorite          = toggleFavorite;
window.handleAttachments       = handleAttachments;
window.handleDrop              = handleDrop;
window.prepareData             = prepareData;
window.toggleHelp              = toggleHelp;

})();
</script>

{% endblock %}
