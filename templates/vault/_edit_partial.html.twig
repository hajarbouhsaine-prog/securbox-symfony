<form method="post" action="{{ path('app_vault_edit', {id: secret.id, modal: 1}) }}"
      id="secretForm" enctype="multipart/form-data">
    <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ secret.id) }}">
    <input type="hidden" name="update_secret" value="1">
    {# Hidden field: list of stored_names the user wants to keep #}
    <input type="hidden" name="keep_attachments" id="keepAttachmentsInput" value="[]">

    <div style="margin-bottom:16px;">
        <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Nom de l'élément</label>
        <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
            <input type="text" name="name" value="{{ secret.name }}" required
                   style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Collection</label>
        <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
            <select name="collection_id" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem; cursor:pointer;">
                <option value="" style="background:var(--bg-card);">Aucune collection</option>
                {% for col in collections %}
                <option value="{{ col.id }}" style="background:var(--bg-card);"
                        {{ secret.collection and secret.collection.id == col.id ? 'selected' : '' }}>
                    {{ col.name }}
                </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {% if secret.type == 'password' %}
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Identifiant</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_username" name="username" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Mot de passe</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_password" name="password" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Site web (URL)</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_website" name="website" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <script>
        (function() {
            try {
                var raw = {{ decryptedData|json_encode|raw }};
                var d = JSON.parse(raw);
                if (d.username) document.getElementById('ep_username').value = d.username;
                if (d.password) document.getElementById('ep_password').value = d.password;
                if (d.website)  document.getElementById('ep_website').value  = d.website;
            } catch(e) {}
        })();
        </script>

    {% elseif secret.type == 'note' %}
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Contenu</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <textarea id="ep_note_content" name="data" required rows="5"
                          style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem; resize:vertical;"></textarea>
            </div>
        </div>
        <script>
        (function() {
            try {
                var raw = {{ decryptedData|json_encode|raw }};
                var d = JSON.parse(raw);
                var content = d.content || d.note || '';
                document.getElementById('ep_note_content').value = content || raw;
            } catch(e) {
                document.getElementById('ep_note_content').value = {{ decryptedData|json_encode|raw }};
            }
        })();
        </script>

    {% elseif secret.type == 'api_key' %}
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Service</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_service" name="api_service" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Clé API</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_apikey" name="api_key_value" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">URL de base</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_baseurl" name="api_base_url" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Environnement</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_env" name="api_env" value=""
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <script>
        (function() {
            try {
                var raw = {{ decryptedData|json_encode|raw }};
                var d = JSON.parse(raw);
                if (d.service)  document.getElementById('ep_service').value  = d.service;
                if (d.key)      document.getElementById('ep_apikey').value   = d.key;
                if (d.base_url) document.getElementById('ep_baseurl').value  = d.base_url;
                if (d.env)      document.getElementById('ep_env').value      = d.env;
            } catch(e) {}
        })();
        </script>

    {% elseif secret.type == 'identity' %}
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px;">
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Prénom</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_firstname" name="id_firstname" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Nom</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_lastname" name="id_lastname" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Email</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="email" id="ep_email" name="id_email" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Téléphone</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_phone" name="id_phone" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Entreprise</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_company" name="id_company" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Ville</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_city" name="id_city" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
            <div>
                <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Pays</label>
                <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                    <input type="text" id="ep_country" name="id_country" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
                </div>
            </div>
        </div>
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Adresse</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" id="ep_address" name="id_address" value="" style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
        <script>
        (function() {
            try {
                var raw = {{ decryptedData|json_encode|raw }};
                var d = JSON.parse(raw);
                if (d.firstname) document.getElementById('ep_firstname').value = d.firstname;
                if (d.lastname)  document.getElementById('ep_lastname').value  = d.lastname;
                if (d.email)     document.getElementById('ep_email').value     = d.email;
                if (d.phone)     document.getElementById('ep_phone').value     = d.phone;
                if (d.company)   document.getElementById('ep_company').value   = d.company;
                if (d.city)      document.getElementById('ep_city').value      = d.city;
                if (d.country)   document.getElementById('ep_country').value   = d.country;
                if (d.address)   document.getElementById('ep_address').value   = d.address;
            } catch(e) {}
        })();
        </script>

    {% else %}
        <div style="margin-bottom:16px;">
            <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Données</label>
            <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
                <input type="text" name="data" value="{{ decryptedData }}" required
                       style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem;">
            </div>
        </div>
    {% endif %}

    {# ── Notes ── #}
    <div style="margin-bottom:16px;">
        <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">Notes</label>
        <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:8px; padding:10px 14px;">
            <textarea id="ep_notes" name="notes" rows="3"
                      style="background:transparent; border:none; outline:none; color:var(--text-primary); width:100%; font-size:0.92rem; resize:vertical;"></textarea>
        </div>
    </div>
    <script>
    (function() {
        try {
            var raw = {{ decryptedData|json_encode|raw }};
            var d = JSON.parse(raw);
            if (d.notes) document.getElementById('ep_notes').value = d.notes;
        } catch(e) {}
    })();
    </script>

    {# ── Pièces jointes existantes ── #}
    <div style="margin-bottom:16px;" id="existingAttachmentsSection">
        <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">
            <i class="fas fa-paperclip me-1"></i>Pièces jointes existantes
        </label>
        <div id="existingAttachmentsList" style="display:flex; flex-direction:column; gap:8px;"></div>
        <div id="noAttachmentsMsg" style="color:var(--text-muted); font-size:0.83rem; display:none;">Aucune pièce jointe.</div>
    </div>

    {# ── Ajouter de nouveaux fichiers ── #}
    <div style="margin-bottom:20px;">
        <label style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; font-weight:600; display:block; margin-bottom:7px;">
            <i class="fas fa-plus me-1"></i>Ajouter des fichiers (images, PDF, vidéos…)
        </label>
        <div style="background:var(--bg-input); border:1px dashed var(--border-input); border-radius:8px; padding:14px;">
            <input type="file" name="attachments[]" id="ep_new_files" multiple
                   accept="image/*,application/pdf,video/*,.doc,.docx,.xls,.xlsx,.txt"
                   style="color:var(--text-primary); font-size:0.88rem; width:100%;">
            <div style="color:var(--text-muted); font-size:0.75rem; margin-top:6px;">Max 50 Mo par fichier. Images, PDF, vidéos, documents acceptés.</div>
        </div>
    </div>

    <div style="display:flex; gap:10px; margin-top:20px;">
        <button type="button" class="nv-cancel"
                style="flex:1; padding:10px; border-radius:8px; border:1px solid var(--border-main);
                       background:var(--bg-hover); color:var(--text-secondary); font-size:0.9rem; cursor:pointer;">
            Annuler
        </button>
        <button type="submit"
                style="flex:1; padding:10px; border-radius:8px; border:none; cursor:pointer;
                       background:linear-gradient(135deg,var(--accent-blue),var(--accent-teal));
                       color:#0f1117; font-weight:600; font-size:0.9rem;">
            <i class="fas fa-save"></i> Enregistrer
        </button>
    </div>
</form>

<script>
(function() {
    // Load existing attachments and render them with a "remove" button
    var keepList = [];

    try {
        var raw = {{ decryptedData|json_encode|raw }};
        var d = JSON.parse(raw);
        var attachments = d.attachments || [];
        var list = document.getElementById('existingAttachmentsList');
        var noMsg = document.getElementById('noAttachmentsMsg');
        var secretId = {{ secret.id }};

        if (attachments.length === 0) {
            list.style.display = 'none';
            noMsg.style.display = 'block';
        } else {
            noMsg.style.display = 'none';
            // Start with all kept
            keepList = attachments.map(function(a) { return a.stored_name; });

            attachments.forEach(function(att) {
                var attUrl = '/vault/' + secretId + '/attachment/' + encodeURIComponent(att.stored_name);
                var sizeKo = att.size ? (att.size / 1024).toFixed(1) + ' Ko' : '';

                // Icon
                var iconClass = 'fas fa-file-alt';
                var iconColor = 'var(--accent-blue,#6fbfff)';
                if (att.mime && att.mime.startsWith('image/')) { iconClass = 'fas fa-file-image'; iconColor = 'var(--accent-warn,#fbbf24)'; }
                else if (att.mime && att.mime.includes('pdf'))  { iconClass = 'fas fa-file-pdf'; iconColor = 'var(--accent-danger,#f87171)'; }
                else if (att.mime && att.mime.includes('video')){ iconClass = 'fas fa-file-video'; iconColor = '#a78bfa'; }

                var row = document.createElement('div');
                row.id = 'att-row-' + att.stored_name;
                row.style.cssText = 'display:flex; align-items:center; gap:10px; background:var(--bg-card,#141b27); border:1px solid var(--border-main,#252d3d); border-radius:8px; padding:10px 14px;';
                row.innerHTML = '<i class="' + iconClass + '" style="font-size:1.1rem; color:' + iconColor + '; flex-shrink:0;"></i>'
                    + '<div style="flex:1; min-width:0;">'
                    +   '<div style="color:var(--text-primary,#e0e0e0); font-size:0.88rem; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">' + escHtml(att.original_name) + '</div>'
                    +   '<div style="color:var(--text-muted,#4b5563); font-size:0.75rem;">' + escHtml(att.mime || '') + (sizeKo ? ' · ' + sizeKo : '') + '</div>'
                    + '</div>'
                    + '<a href="' + attUrl + '" target="_blank" style="color:var(--accent-blue,#6fbfff); font-size:0.8rem; text-decoration:none; flex-shrink:0;" title="Aperçu"><i class="fas fa-eye"></i></a>'
                    + '<button type="button" onclick="removeExistingAtt(\'' + escJs(att.stored_name) + '\')" '
                    +   'style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3); color:#f87171; border-radius:6px; padding:4px 8px; cursor:pointer; font-size:0.8rem; flex-shrink:0;" '
                    +   'title="Supprimer">'
                    +   '<i class="fas fa-trash"></i>'
                    + '</button>';
                list.appendChild(row);
            });
        }
        updateKeepInput();
    } catch(e) {
        console.error('Erreur chargement pièces jointes:', e);
    }

    window.removeExistingAtt = function(storedName) {
        var row = document.getElementById('att-row-' + storedName);
        if (row) {
            row.style.opacity = '0.4';
            row.style.pointerEvents = 'none';
            var badge = document.createElement('span');
            badge.style.cssText = 'color:#f87171; font-size:0.75rem; margin-left:6px;';
            badge.textContent = '(sera supprimé)';
            row.querySelector('div').appendChild(badge);
        }
        keepList = keepList.filter(function(n) { return n !== storedName; });
        updateKeepInput();
    };

    function updateKeepInput() {
        document.getElementById('keepAttachmentsInput').value = JSON.stringify(keepList);
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escJs(str) {
        return String(str).replace(/\\/g,'\\\\').replace(/'/g,"\\'");
    }
})();
</script>
