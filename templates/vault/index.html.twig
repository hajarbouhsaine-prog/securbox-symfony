{% extends 'base.html.twig' %}
{% block title %}Mon Coffre-Fort{% endblock %}
{% block body %}

<style>
.vault-layout {
    display: flex;
    min-height: calc(100vh - 57px);
}

/* ── FILTERS PANEL ── */
.filters-panel {
    width: 260px;
    flex-shrink: 0;
    background: var(--bg-filters);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}
.filters-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px 10px;
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
}
.filters-header span {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.filters-header button {
    background: none; border: none; color: var(--text-muted);
    cursor: pointer; font-size: 0.85rem; padding: 2px 6px;
    border-radius: 50%; transition: color 0.15s;
}
.filters-header button:hover { color: var(--accent-blue); }

.filters-search {
    margin: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-input);
    border: 1px solid var(--border-input);
    border-radius: 8px;
    padding: 8px 12px;
    flex-shrink: 0;
}
.filters-search:focus-within { border-color: var(--accent-blue); }
.filters-search input {
    background: transparent; border: none; outline: none;
    color: var(--text-primary); font-size: 0.88rem; width: 100%;
}
.filters-search input::placeholder { color: var(--text-muted); }
.filters-search i { color: var(--text-muted); font-size: 0.82rem; }

.filters-section-title {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px 4px;
    font-size: 0.72rem;
    color: var(--accent-blue);
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    user-select: none;
}
.filters-section-title i { font-size: 0.65rem; transition: transform 0.2s; }
.filters-section-title.collapsed i { transform: rotate(-90deg); }

.filters-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    color: var(--text-secondary);
    font-size: 0.87rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.12s;
    border-left: 2px solid transparent;
}
.filters-item:hover { background: var(--bg-hover); color: var(--text-primary); }
.filters-item.active { background: var(--bg-active); color: var(--text-primary); border-left-color: var(--accent-blue); }
.filters-item i { width: 18px; text-align: center; font-size: 0.82rem; flex-shrink: 0; color: inherit; }
.filters-item .f-count {
    margin-left: auto;
    font-size: 0.68rem;
    color: var(--text-muted);
    border-radius: 10px;
    padding: 1px 7px;
    flex-shrink: 0;
}
.filters-item.sub { padding-left: 32px; }

.filters-divider { border: none; border-top: 1px solid var(--border-subtle); margin: 6px 0; }

/* ── SECRETS PANEL ── */
.secrets-panel { flex: 1; min-width: 0; padding: 24px 20px; overflow-y: auto; }
.secrets-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; padding-bottom: 12px; border-bottom: 1px solid var(--border-subtle);
}
.secrets-header h1 {
    color: var(--text-primary); font-size: 1.2rem; font-weight: 600;
    margin: 0; display: flex; align-items: center; gap: 10px;
}

/* ── BANNER COLLECTION METADATA ── */
.collection-info-banner {
    background: var(--bg-filters);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 18px 20px;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
}
.collection-info-main p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    margin: 8px 0 0 0;
    line-height: 1.45;
}
.collection-info-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
}
.collection-info-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}
.btn-collection-action {
    background: var(--bg-input);
    border: 1px solid var(--border-input);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 0.82rem;
    padding: 6px 12px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.12s;
}
.btn-collection-action:hover {
    background: var(--bg-hover);
}
.btn-collection-action.delete {
    color: var(--accent-danger);
}

.secrets-table-head {
    display: grid; grid-template-columns: 2fr 1fr 1fr 50px;
    padding: 7px 14px; margin-bottom: 4px; border-bottom: 1px solid var(--border-subtle);
}
.secrets-table-head span {
    color: var(--text-muted); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;
}
.secret-row {
    display: grid; grid-template-columns: 2fr 1fr 1fr 50px;
    align-items: center; padding: 11px 14px; margin-bottom: 1px;
    border-radius: 8px; border: 1px solid transparent;
    transition: all 0.12s; cursor: pointer; position: relative;
}
.secret-row:hover { background: var(--bg-hover); border-color: var(--border-input); }
.secret-name { color: var(--text-primary); font-weight: 500; font-size: 0.9rem; }
.secret-meta { font-size: 0.7rem; color: var(--text-muted); margin-top: 1px; }
.secret-type { color: var(--text-secondary); font-size: 0.82rem; }
.secret-date { color: var(--text-secondary); font-size: 0.82rem; }
.secret-icon {
    width: 32px; height: 32px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 0.82rem;
}
.dropdown-item { color: var(--text-primary) !important; font-size: 0.87rem; text-decoration: none; }
.dropdown-item:hover { background: var(--bg-hover) !important; color: var(--text-primary) !important; }
.custom-dropdown-menu {
    background: var(--bg-card) !important;
    border: 1px solid var(--border-input) !important;
}
.dropdown-trigger-btn { color: var(--text-muted); border: none; background: transparent; cursor: pointer; padding: 4px 10px; font-size: 1rem; }
.dropdown-trigger-btn:hover { color: var(--text-primary); }
.dropdown-divider { border-color: var(--border-input) !important; }

@media (max-width: 640px) {
    .vault-layout {
        flex-direction: column;
        min-height: calc(100vh - 58px);
    }

    .filters-panel {
        width: 100%;
        height: auto;
        flex-direction: row;
        overflow-x: auto;
        overflow-y: hidden;
        border-right: none;
        border-bottom: 1px solid var(--border-subtle);
        flex-shrink: 0;
    }

    .filters-header,
    .filters-search,
    .filters-section-title,
    .filters-divider { display: none; }

    .filters-panel > div,
    .filters-panel > a,
    #vaultsSection,
    #itemsSection,
    #collectionsSection {
        display: inline-flex !important;
        flex-direction: row;
        white-space: nowrap;
    }

    .filters-item {
        border-left: none;
        border-bottom: 3px solid transparent;
        padding: 10px 14px;
        font-size: 0.8rem;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .filters-item.active {
        border-bottom-color: var(--accent-blue);
        border-left: none;
        background: transparent;
    }
    .filters-item .f-count { display: none; }

    .collection-info-banner {
        flex-direction: column;
        gap: 12px;
        padding: 12px;
    }
    .collection-info-actions {
        width: 100%;
    }
    .btn-collection-action {
        flex: 1;
        justify-content: center;
    }

    .secrets-panel { padding: 10px 8px 8px; }
    .secrets-table-head { display: none; }
    .secret-row {
        grid-template-columns: 1fr auto;
        gap: 8px;
        padding: 10px;
        min-height: 52px;
    }
    .secret-type,
    .secret-date { display: none; }
}
</style>

<div class="vault-layout">

    {# ══ FILTERS PANEL ══ #}
    <div class="filters-panel">

        <div class="filters-header">
            <span>Filtres</span>
        </div>

        <div class="filters-search">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="Rechercher dans le coffre...">
        </div>

        {# ── Tous les coffres ── #}
        <div class="filters-section-title" onclick="toggleSection('vaultsSection', this)">
            <i class="fas fa-chevron-down"></i>
            Tous les coffres
        </div>
        <div id="vaultsSection">
            <a href="{{ path('app_vault_index') }}"
               class="filters-item {{ app.request.query.get('collection') is null and app.request.query.get('type') is null and app.request.query.get('favorite') is null ? 'active' : '' }}">
                <i class="fas fa-user"></i>
                Mon Coffre-Fort
            </a>
        </div>

        <hr class="filters-divider">

        {# ── Tous les éléments ── #}
        <div class="filters-section-title" onclick="toggleSection('itemsSection', this)">
            <i class="fas fa-chevron-down"></i>
            Tous les éléments
        </div>
        <div id="itemsSection">
            <a href="{{ path('app_vault_index', {favorite: 1}) }}"
               class="filters-item {{ app.request.query.get('favorite') == 1 ? 'active' : '' }}">
                <i class="fas fa-star"></i> Favoris
            </a>
            <a href="{{ path('app_vault_index', {type: 'password'}) }}"
               class="filters-item {{ app.request.query.get('type') == 'password' ? 'active' : '' }}">
                <i class="fas fa-key"></i> Mots de passe
            </a>
            <a href="{{ path('app_vault_index', {type: 'api_key'}) }}"
               class="filters-item {{ app.request.query.get('type') == 'api_key' ? 'active' : '' }}">
                <i class="fas fa-code"></i> Clés API
            </a>
            <a href="{{ path('app_vault_index', {type: 'identity'}) }}"
               class="filters-item {{ app.request.query.get('type') == 'identity' ? 'active' : '' }}">
                <i class="fas fa-id-card"></i> Identités
            </a>
            <a href="{{ path('app_vault_index', {type: 'note'}) }}"
               class="filters-item {{ app.request.query.get('type') == 'note' ? 'active' : '' }}">
                <i class="fas fa-sticky-note"></i> Notes sécurisées
            </a>
        </div>

        <hr class="filters-divider">

        {# ── Collections ── #}
        {% set userCollections = app.user.collections %}
        <div class="filters-section-title" onclick="toggleSection('collectionsSection', this)">
            <i class="fas fa-chevron-down"></i>
            Collections
        </div>
        <div id="collectionsSection">
            {% if userCollections is empty %}
                <div style="padding:6px 14px 10px; font-size:0.78rem; color:var(--text-muted); font-style:italic;">
                    Aucune collection
                </div>
            {% else %}
                {% for col in userCollections %}
                <a href="{{ path('app_vault_index', {collection: col.id}) }}"
                   class="filters-item {{ app.request.query.get('collection') == col.id ? 'active' : '' }}">
                    <i class="fas fa-layer-group"></i>
                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ col.name }}</span>
                    <span class="f-count">{{ col.secrets|length }}</span>
                </a>
                {% endfor %}
            {% endif %}
        </div>

        <hr class="filters-divider">

        {# ── Archive & Corbeille ── #}
        <a href="{{ path('app_vault_index', {archived: 1}) }}"
           class="filters-item {{ app.request.query.get('archived') == 1 ? 'active' : '' }}">
            <i class="fas fa-archive"></i> Archive
        </a>
        <a href="{{ path('app_vault_index', {bin: 1}) }}"
           class="filters-item {{ app.request.query.get('bin') == 1 ? 'active' : '' }}">
            <i class="fas fa-trash"></i> Corbeille
        </a>

    </div>

    {# ══ SECRETS PANEL ══ #}
    <div class="secrets-panel">
        {% if app.request.query.get('bin') %}
        <div style="background:rgba(249,115,22,0.1); border:1px solid #f97316; border-radius:10px; padding:12px 16px; margin-bottom:16px; display:flex; align-items:center; gap:10px; font-size:0.88rem; color:#f97316;">
            <i class="fas fa-exclamation-triangle"></i>
            <span>Les éléments dans la corbeille seront définitivement supprimés après 30 jours.</span>
        </div>
        {% endif %}

        <div class="secrets-header">
            <h1>
                {% if app.request.query.get('favorite') == 1 %}
                    <i class="fas fa-star"></i> Favoris
                {% elseif app.request.query.get('collection') %}
                    {% for col in collections %}
                        {% if col.id == app.request.query.get('collection')|number_format %}
                            <i class="fas fa-layer-group" style="color:var(--accent-blue);"></i> {{ col.name }}
                        {% endif %}
                    {% endfor %}
                {% elseif app.request.query.get('type') == 'password' %}
                    <i class="fas fa-key"></i> Mots de passe
                {% elseif app.request.query.get('type') == 'api_key' %}
                    <i class="fas fa-code"></i> Clés API
                {% elseif app.request.query.get('type') == 'note' %}
                    <i class="fas fa-sticky-note"></i> Notes sécurisées
                {% elseif app.request.query.get('type') == 'identity' %}
                    <i class="fas fa-id-card"></i> Identités
                {% else %}
                    <i class="fas fa-vault"></i> Mon Coffre-Fort
                {% endif %}
            </h1>
            <span style="color:var(--text-muted); font-size:0.82rem;">{{ secrets|length }} élément(s)</span>
        </div>

        {# ── BANDEAU METADONNÉES DE LA COLLECTION ACTIVE ── #}
        {% if activeCollection is defined and activeCollection is not null %}
            <div class="collection-info-banner">
                <div class="collection-info-main">
                    <p>{{ activeCollection.description ?: 'Aucune description fournie.' }}</p>
                    <div class="collection-info-date">
                        <i class="far fa-calendar-alt"></i>
                        <span>Créée le : <span style="color: var(--text-primary);">{{ activeCollection.createdAt|date('d/m/Y à H:i') }}</span></span>
                    </div>
                </div>
                <div class="collection-info-actions">
                    <a href="{{ path('app_collection_edit', {id: activeCollection.id}) }}" class="btn-collection-action">
                        <i class="fas fa-edit" style="color: var(--accent-blue);"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('app_collection_delete', {id: activeCollection.id}) }}"
                  onsubmit="return confirm('Attention ! Supprimer cette collection supprimera également TOUS les secrets qu\'elle contient de manière définitive. Confirmer ?')" style="margin: 0;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_collection' ~ activeCollection.id) }}">
                <button type="submit" class="btn-collection-action delete">
                            <i class="fas fa-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}

        {% if secrets is empty %}
    <div style="text-align:center; padding:80px 20px; color:var(--text-muted);">
        <i class="fas fa-box-open fa-3x" style="opacity:0.12; margin-bottom:16px; display:block;"></i>
        <p style="font-size:0.95rem; margin-bottom:6px;">Aucun secret ici</p>
        <p style="font-size:0.82rem; margin-bottom:20px;">Ajoutez votre premier secret dans cette collection</p>
       <div style="text-align:center; margin-top:16px;">
    <a href="{{ path('app_vault_new', {'type': 'password', 'collection': app.request.query.get('collection')}) }}"
       data-modal-url="{{ path('app_vault_new', {'type': 'password', 'modal': '1', 'collection': app.request.query.get('collection')}) }}"
       data-modal-title="🔑 Nouveau Secret"
       class="modal-trigger btn-collection-action"
       style="text-decoration:none; display:inline-flex;">
        <i class="fas fa-plus" style="color:var(--accent-blue);"></i> Nouveau secret
    </a>
</div>
    </div>
{% else %}
            <div class="secrets-table-head">
                <span>Nom</span>
                <span>Type</span>
                <span>Date</span>
                <span style="text-align:center;">Actions</span>
            </div>
            <div id="secretsList">
                {% for secret in secrets %}
                <div class="secret-row" data-id="{{ secret.id }}" data-url="{{ path('app_vault_show', {id: secret.id, modal: 1}) }}" data-name="{{ secret.name|lower }}">
                    <div style="display:flex; align-items:center; gap:11px;">
                        <div class="secret-icon
                            {% if secret.type == 'password' %}icon-password
                            {% elseif secret.type == 'api_key' %}icon-api
                            {% elseif secret.type == 'note' %}icon-note
                            {% else %}icon-identity{% endif %}">
                            {% if secret.type == 'password' %}<i class="fas fa-key"></i>
                            {% elseif secret.type == 'api_key' %}<i class="fas fa-code"></i>
                            {% elseif secret.type == 'note' %}<i class="fas fa-sticky-note"></i>
                            {% else %}<i class="fas fa-id-card"></i>{% endif %}
                        </div>
                        <div>
                            <div class="secret-name">
                                {{ secret.name }}
                                {% if secret.isFavorite %}
                                <i class="fas fa-star" style="color:#fbbf24; font-size:0.7rem; margin-left:4px;"></i>
                                {% endif %}
                            </div>
                            {% if secret.collection %}
                            <div class="secret-meta">
                                <i class="fas fa-layer-group" style="font-size:0.6rem;"></i>
                                {{ secret.collection.name }}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <span class="secret-type">{{ secret.type }}</span>
                    <span class="secret-date">{{ secret.createdAt|date('d/m/Y') }}</span>
                    <div style="text-align:center; position:relative;">
                        <button class="custom-dropdown-trigger dropdown-trigger-btn" type="button">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                        <ul class="custom-dropdown-menu shadow"
                            style="display:none; position:absolute; right:0; top:100%;
                                   min-width:180px; padding:6px 0;
                                   z-index:1000; border-radius:8px; list-style:none; margin:4px 0 0 0;">
                            <li>
    <a href="#"
       data-modal-url="{{ path('app_vault_show', {id: secret.id, modal: 1}) }}"
       data-modal-title="{{ secret.name }}"
       class="dropdown-item d-flex align-items-center gap-2 py-2 px-3"
       onclick="event.preventDefault(); event.stopPropagation(); openVaultModal(this.dataset.modalUrl, this.dataset.modalTitle); this.closest('.custom-dropdown-menu').style.display='none';">
        <i class="fas fa-eye" style="width:15px; color:var(--text-muted);"></i> Afficher
    </a>
</li>
<li>
    <a href="#"
       data-modal-url="{{ path('app_vault_edit', {id: secret.id, modal: 1}) }}"
       data-modal-title="✏️ Modifier — {{ secret.name }}"
       class="dropdown-item d-flex align-items-center gap-2 py-2 px-3"
       onclick="event.preventDefault(); event.stopPropagation(); openVaultModal(this.dataset.modalUrl, this.dataset.modalTitle); this.closest('.custom-dropdown-menu').style.display='none';">
        <i class="fas fa-edit" style="width:15px; color:var(--text-muted);"></i> Modifier
    </a>
</li>
                            <li>
                                <form method="post" action="{{ path('app_vault_favorite', {id: secret.id}) }}" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ secret.id) }}">
                                    <button type="submit"
                                            class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 w-100 text-start"
                                            style="color:{% if secret.isFavorite %}#fbbf24{% else %}var(--text-primary){% endif %}; background:transparent; border:none; cursor:pointer;">
                                        <i class="fas fa-star" style="width:15px;"></i>
                                        {% if secret.isFavorite %}Retirer des favoris{% else %}Ajouter aux favoris{% endif %}
                                    </button>
                                </form>
                            </li>
                            <li>
                                <form method="post" action="{{ path('app_vault_archive', {id: secret.id}) }}" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ secret.id) }}">
                                    <button type="submit"
                                            class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 w-100 text-start"
                                            style="background:transparent; border:none; cursor:pointer;">
                                        <i class="fas fa-archive" style="width:15px; color:var(--text-muted);"></i>
                                        {% if secret.isArchived %}Désarchiver{% else %}Archiver{% endif %}
                                    </button>
                                </form>
                            </li>
                            <li><hr class="dropdown-divider" style="margin:4px 0;"></li>
                            {% if app.request.query.get('bin') %}
                            <li>
                                <form method="post" action="{{ path('app_vault_restore', {id: secret.id}) }}" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('restore' ~ secret.id) }}">
                                    <button type="submit"
                                            class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 w-100 text-start"
                                            style="color:var(--accent-teal); background:transparent; border:none; cursor:pointer;">
                                        <i class="fas fa-undo" style="width:15px;"></i> Restaurer
                                    </button>
                                </form>
                            </li>
                            {% else %}
                            <li>
                                <form method="post" action="{{ path('app_vault_trash', {id: secret.id}) }}"
                                      onsubmit="return confirm('Déplacer vers la corbeille ?')" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('trash' ~ secret.id) }}">
                                    <button type="submit"
                                            class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 w-100 text-start"
                                            style="color:var(--accent-danger); background:transparent; border:none; cursor:pointer;">
                                        <i class="fas fa-trash" style="width:15px;"></i> Corbeille
                                    </button>
                                </form>
                            </li>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') or secret.deletedAt is not null %}
                            <li>
                                <form method="post" action="{{ path('app_vault_delete', {id: secret.id}) }}"
                                      onsubmit="return confirm('Supprimer définitivement ?')" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ secret.id) }}">
                                    <button type="submit"
                                            class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 w-100 text-start"
                                            style="color:var(--accent-danger); background:transparent; border:none; cursor:pointer;">
                                        <i class="fas fa-times-circle" style="width:15px;"></i> Supprimer définitivement
                                    </button>
                                </form>
                            </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>

<script>
function toggleSection(id, titleEl) {
  var section = document.getElementById(id);
  var isHidden = section.style.display === 'none';
  section.style.display = isHidden ? 'block' : 'none';
  titleEl.classList.toggle('collapsed', !isHidden);
}

document.addEventListener('DOMContentLoaded', function() {

  /* ── Dropdown menus ── */
  document.querySelectorAll('.custom-dropdown-trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function(e) {
      e.stopPropagation();
      var menu = this.nextElementSibling;
      document.querySelectorAll('.custom-dropdown-menu').forEach(function(m) {
        if (m !== menu) m.style.display = 'none';
      });
      menu.style.display = (!menu.style.display || menu.style.display === 'none') ? 'block' : 'none';
    });
  });

  /* Ferme les menus si on clique ailleurs — mais pas sur un élément du menu */
  document.addEventListener('click', function(e) {
    if (e.target.closest('.custom-dropdown-menu')) return;
    document.querySelectorAll('.custom-dropdown-menu').forEach(function(m) {
      m.style.display = 'none';
    });
  });

});

/* ── Search ── */
document.getElementById('searchInput')?.addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.secret-row').forEach(function(row) {
    row.style.display = row.dataset.name.includes(q) ? 'grid' : 'none';
  });
});

/* ── Row click → open vault modal ── */
document.addEventListener('click', function(e) {
  var row = e.target.closest('.secret-row');
  if (!row) return;
  if (
    e.target.closest('.custom-dropdown-trigger') ||
    e.target.closest('.custom-dropdown-menu') ||
    e.target.tagName === 'BUTTON' ||
    e.target.tagName === 'A'
  ) return;

  var url = row.dataset.url;
  var name = row.dataset.name;
  if (!url) return;

  window._spSourceUrl = url;
  window._modalSourceUrl = url;

  if (typeof openVaultModal === 'function') {
    openVaultModal(url, name);
  }
});
</script>

{% endblock %}
