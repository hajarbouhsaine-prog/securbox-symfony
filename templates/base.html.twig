<!DOCTYPE html>
<html lang="{{ app.request.locale }}"
      dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}SecurBox{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    {# ══════════════════════════════════════════════════════════
       THEME SCRIPT — doit être AVANT le CSS pour éviter le flash
       ══════════════════════════════════════════════════════════ #}
    <script>
        (function() {
            var saved = localStorage.getItem('securboxTheme');
            var theme = 'dark'; // défaut

            if (saved === 'light' || saved === 'dark') {
                theme = saved;
            } else if (saved === 'system' || !saved) {
                theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            }

            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        /* ══════════════════════════════════════════════════════
           CSS CUSTOM PROPERTIES — DARK MODE (défaut)
           ══════════════════════════════════════════════════════ */
        :root,
        [data-theme="dark"] {
            /* Fonds */
            --bg-body:        #0f1117;
            --bg-sidebar:     #1a2035;
            --bg-topbar:      #1a2035;
            --bg-card:        #141b27;
            --bg-card-alt:    #161b27;
            --bg-input:       #1e2535;
            --bg-filters:     #131929;
            --bg-hover:       #1e2535;
            --bg-active:      #1e3a5f;
            --bg-modal:       #161b27;
            --bg-summary:     #0f1724;

            /* Bordures */
            --border-main:    #252d3d;
            --border-input:   #2a2f3e;
            --border-subtle:  #1f2937;

            /* Textes */
            --text-primary:   #e0e0e0;
            --text-secondary: #9ca3af;
            --text-muted:     #4b5563;
            --text-accent:    #6fbfff;
            --text-accent2:   #4dd4ac;

            /* Accentuation */
            --accent-blue:    #6fbfff;
            --accent-teal:    #4dd4ac;
            --accent-danger:  #f87171;
            --accent-warn:    #fbbf24;
            --accent-purple:  #c084fc;

            /* Sidebar collapse toggle */
            --sidebar-edge-bg:   #131929;
            --sidebar-edge-border: #2a2f3e;

            /* Notification dot ring */
            --notif-ring:     #1a2035;

            /* Scrollbar */
            --scrollbar-thumb: #252d3d;

            /* Brand */
            --brand-gradient: linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);

            /* Sidebar width (inchangé) */
            --sidebar-width: 240px;
            --sidebar-collapsed-width: 72px;
        }

        /* ══════════════════════════════════════════════════════
           CSS CUSTOM PROPERTIES — LIGHT MODE
           ══════════════════════════════════════════════════════ */
        [data-theme="light"] {
            /* Fonds */
            --bg-body:        #f0f4f8;
            --bg-sidebar:     #ffffff;
            --bg-topbar:      #ffffff;
            --bg-card:        #ffffff;
            --bg-card-alt:    #f8fafc;
            --bg-input:       #f1f5f9;
            --bg-filters:     #f8fafc;
            --bg-hover:       #e8f0fe;
            --bg-active:      #dbeafe;
            --bg-modal:       #ffffff;
            --bg-summary:     #f1f5f9;

            /* Bordures */
            --border-main:    #e2e8f0;
            --border-input:   #cbd5e1;
            --border-subtle:  #e2e8f0;

            /* Textes */
            --text-primary:   #1e293b;
            --text-secondary: #475569;
            --text-muted:     #94a3b8;
            --text-accent:    #2563eb;
            --text-accent2:   #0d9488;

            /* Accentuation */
            --accent-blue:    #2563eb;
            --accent-teal:    #0d9488;
            --accent-danger:  #ef4444;
            --accent-warn:    #f59e0b;
            --accent-purple:  #7c3aed;

            /* Sidebar collapse toggle */
            --sidebar-edge-bg:   #f8fafc;
            --sidebar-edge-border: #e2e8f0;

            /* Notification dot ring */
            --notif-ring:     #ffffff;

            /* Scrollbar */
            --scrollbar-thumb: #cbd5e1;

            /* Brand — identique */
            --brand-gradient: linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);
        }

        /* ══════════════════════════════════════════════════════
           RESET & BASE
           ══════════════════════════════════════════════════════ */
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-body);
            color: var(--text-primary);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            transition: background-color 0.25s ease, color 0.25s ease;
        }

        /* ══ SIDEBAR ══ */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0; top: 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border-main);
            z-index: 100;
            transition: width 0.25s ease, background-color 0.25s ease;
        }
        .sidebar.collapsed { width: var(--sidebar-collapsed-width); }

        .sidebar-logo {
            padding: 20px 20px 18px;
            border-bottom: 1px solid var(--border-main);
            flex-shrink: 0;
            min-height: 85px;
            overflow: hidden;
            white-space: nowrap;
            transition: padding 0.25s ease;
        }
        .brand-lockup { display: flex; align-items: center; gap: 12px; min-width: 0; }
        .brand-mark {
            width: 42px; height: 48px;
            display: grid; place-items: center;
            flex-shrink: 0;
            color: #dff3ff;
            font-size: 1.15rem;
            background: radial-gradient(circle at 50% 28%, rgba(116,255,221,0.25), transparent 34%),
                        var(--brand-gradient);
            clip-path: polygon(50% 0, 92% 18%, 82% 82%, 50% 100%, 18% 82%, 8% 18%);
            box-shadow: 0 12px 30px rgba(48,107,255,0.28), inset 0 0 0 2px rgba(255,255,255,0.18);
        }
        .brand-copy { min-width: 0; }
        .sidebar-logo h4 { color: var(--accent-blue); font-weight: 700; font-size: 1.15rem; margin: 0; }
        .sidebar-logo .brand-text  { color: var(--accent-blue); }
        .sidebar-logo .brand-accent { color: var(--accent-teal); }
        .sidebar-logo small { color: var(--text-muted); font-size: 0.72rem; display: block; margin-top: 2px; }

        .sidebar.collapsed .sidebar-logo {
            display: flex; align-items: center; justify-content: center; padding: 20px 0 18px;
        }
        .sidebar.collapsed .brand-lockup { justify-content: center; }
        .sidebar.collapsed .brand-mark { width: 42px; height: 48px; }
        .sidebar.collapsed .brand-copy { display: none; }

        /* Main nav */
        .sidebar-main-nav { flex: 1; overflow-y: auto; padding: 12px 0; }
        .sidebar-main-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-main-nav::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 2px; }

        /* Nav items */
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 20px;
            color: var(--text-secondary);
            text-decoration: none; font-size: 0.92rem;
            cursor: pointer; transition: all 0.15s;
            border: none; background: none; width: 100%;
            text-align: left; border-radius: 0;
            user-select: none; min-height: 42px;
        }
        .nav-item:hover  { background: var(--bg-hover); color: var(--text-primary); }
        .nav-item.active { background: var(--bg-active); color: var(--accent-blue); }
        .nav-item i.nav-icon { width: 18px; text-align: center; font-size: 0.9rem; flex-shrink: 0; }

        .nav-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .nav-item .nav-arrow { margin-left: auto; font-size: 0.7rem; color: var(--text-muted); transition: transform 0.2s; }
        .nav-item.open .nav-arrow { transform: rotate(90deg); }

        /* Sub items */
        .nav-sub { overflow: hidden; max-height: 0; transition: max-height 0.25s ease; }
        .nav-sub.open { max-height: 300px; }
        .sidebar.collapsed .nav-sub { display: none; }

        .nav-sub-item {
            display: flex; align-items: center;
            padding: 7px 20px 7px 48px;
            color: var(--text-muted); text-decoration: none;
            font-size: 0.88rem; cursor: pointer; transition: all 0.15s;
        }
        .nav-sub-item:hover { background: var(--bg-hover); color: var(--text-primary); }
        .nav-sub-item.active { color: var(--accent-blue); background: var(--bg-hover); }
        .nav-sub-item.coming-soon { opacity: 0.4; cursor: default; pointer-events: none; }

        /* Bottom section */
        .sidebar-bottom { border-top: 1px solid var(--border-main); padding: 8px 0; flex-shrink: 0; }
        .sidebar-bottom-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 20px;
            color: var(--text-secondary); text-decoration: none;
            font-size: 0.88rem; cursor: pointer; transition: all 0.15s;
            border-radius: 8px; margin: 2px 8px; min-height: 42px;
        }
        .sidebar-bottom-item:hover  { background: var(--bg-hover); color: var(--text-primary); }
        .sidebar-bottom-item.active { background: var(--bg-active); color: var(--accent-blue); }
        .sidebar-bottom-item i { width: 18px; text-align: center; }
        .sidebar-bottom-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .sidebar.collapsed .nav-item,
        .sidebar.collapsed .sidebar-bottom-item {
            justify-content: center; gap: 0;
            padding-left: 0; padding-right: 0;
            margin-left: 12px; margin-right: 12px;
            border-radius: 16px;
        }
        .sidebar.collapsed .nav-item.active,
        .sidebar.collapsed .sidebar-bottom-item.active {
            background: var(--bg-active);
            box-shadow: inset 0 0 0 1px rgba(111,191,255,0.16);
        }
        .sidebar.collapsed .nav-item i.nav-icon,
        .sidebar.collapsed .sidebar-bottom-item i { width: 24px; font-size: 1.05rem; }
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .sidebar-bottom-label,
        .sidebar.collapsed .nav-arrow { display: none; }

        .sidebar-collapse-btn {
            display: flex; align-items: center; justify-content: flex-start;
            padding: 8px 20px; color: var(--text-muted);
            font-size: 0.85rem; cursor: pointer; transition: color 0.15s;
            border: none; background: none; width: 100%;
        }
        .sidebar-collapse-btn:hover { color: var(--accent-blue); }
        .sidebar.collapsed .sidebar-collapse-btn { justify-content: center; padding-left: 0; padding-right: 0; }

        .sidebar-edge-toggle {
            position: absolute; right: -14px; top: 50%;
            transform: translateY(-50%);
            width: 28px; height: 58px;
            border: 1px solid var(--sidebar-edge-border);
            border-left-color: var(--bg-sidebar);
            border-radius: 0 14px 14px 0;
            background: var(--sidebar-edge-bg);
            color: var(--accent-blue);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 110;
            box-shadow: 8px 0 22px rgba(0,0,0,0.12);
            transition: color 0.15s, background 0.15s;
        }
        .sidebar-edge-toggle:hover { background: var(--bg-hover); color: var(--text-primary); }

        /* ══ MAIN CONTENT ══ */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            background-color: var(--bg-body);
            transition: margin-left 0.25s ease, background-color 0.25s ease;
            overflow-x: hidden;
        }
        .main-content.vault .top-bar { padding-left: 28px; }
        .main-content.expanded { margin-left: var(--sidebar-collapsed-width); }

        /* Top bar */
        .top-bar {
            background: var(--bg-topbar);
            border-bottom: 1px solid var(--border-main);
            padding: 10px 28px;
            display: flex; align-items: center;
            justify-content: space-between; gap: 12px;
            position: sticky; top: 0; z-index: 50;
            transition: background-color 0.25s ease;
            min-height: 87px;
        }
        .top-bar-actions { display: flex; align-items: center; gap: 12px; }

        .top-icon-btn {
            width: 40px; height: 40px;
            border-radius: 12px;
            border: 1px solid transparent;
            background: transparent;
            color: var(--text-secondary);
            display: grid; place-items: center;
            cursor: pointer; position: relative;
            transition: background 0.15s, border-color 0.15s, color 0.15s;
        }
        .top-icon-btn:hover { background: var(--bg-hover); border-color: var(--border-input); color: var(--text-primary); }
        .top-icon-btn.secure { color: var(--accent-teal); }
        .top-icon-btn .notification-dot {
            position: absolute; top: 5px; right: 5px;
            min-width: 16px; height: 16px; padding: 0 4px;
            border-radius: 999px; background: var(--accent-danger);
            color: #fff; font-size: 0.62rem; font-weight: 700;
            line-height: 16px; text-align: center;
            box-shadow: 0 0 0 2px var(--notif-ring);
        }
        .top-separator { width: 1px; height: 28px; background: var(--border-input); }

        /* User pill */
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            border: none; background: transparent;
            color: var(--text-primary);
            padding: 4px 2px 4px 4px;
            cursor: pointer; min-width: 0;
        }
        .user-pill:hover .user-avatar { box-shadow: 0 0 0 4px rgba(111,191,255,0.12); }
        .user-avatar {
            width: 42px; height: 42px; border-radius: 50%;
            display: grid; place-items: center;
            background: linear-gradient(135deg,#5c4dff,#7c3aed);
            font-weight: 800; color: #fff; font-size: 0.95rem;
            flex-shrink: 0; transition: box-shadow 0.15s;
        }
        .user-meta { display: flex; flex-direction: column; align-items: flex-start; line-height: 1.1; min-width: 0; }
        .user-name { max-width: 170px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 700; font-size: 0.92rem; }
        .user-plan { color: var(--text-secondary); font-size: 0.74rem; margin-top: 4px; }
        .user-chevron { color: var(--text-muted); font-size: 0.76rem; }

        /* ══ CONTENT AREA ══ */
        .content-area { padding: 24px 28px 28px; min-height: calc(100vh - 57px); }
        .content-area--vault { padding-left: 0; padding-top: 0; }

        /* ══ BUTTONS ══ */
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            border: none; color: #0f1117; font-weight: 600;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, var(--accent-teal), var(--accent-blue));
            color: #0f1117;
        }

        /* ══ FORMS ══ */
        .form-control, .form-select {
            background-color: var(--bg-input);
            border: 1px solid var(--border-input);
            color: var(--text-primary); border-radius: 8px;
        }
        .form-control:focus, .form-select:focus {
            background-color: var(--bg-input);
            border-color: var(--accent-blue);
            color: var(--text-primary);
            box-shadow: 0 0 0 3px rgba(111,191,255,0.15);
        }
        .form-control::placeholder { color: var(--text-muted); }
        .form-label { color: var(--text-secondary); font-size: 0.9rem; }

        /* ══ ALERTS ══ */
        .alert-success { background-color: #1a3a2a; border-color: var(--accent-teal); color: var(--accent-teal); }
        .alert-danger  { background-color: #3a1a1a; border-color: var(--accent-danger); color: var(--accent-danger); }
        .alert-info    { background-color: var(--bg-input); border-color: var(--accent-blue); color: var(--accent-blue); }

        /* ══ TABLE ══ */
        .table { color: var(--text-secondary); }
        .table-dark th { background-color: var(--bg-input) !important; color: var(--accent-blue); border-color: var(--border-input); }
        .table td { border-color: var(--border-input); }
        .table-hover tbody tr:hover { background-color: var(--bg-hover); color: var(--text-primary); }

        /* ══ MISC ══ */
        .empty-state {
            text-align: center; padding: 60px 20px;
            background-color: var(--bg-card);
            border: 2px dashed var(--border-input); border-radius: 12px;
        }
        .empty-state i { color: var(--border-input); margin-bottom: 16px; }
        .empty-state h4 { color: var(--text-muted); }

        .auth-page {
            min-height: 100vh; background-color: var(--bg-body);
            display: flex; align-items: center; justify-content: center;
        }
        .auth-card {
            background-color: var(--bg-card); border: 1px solid var(--border-input);
            border-radius: 16px; padding: 40px; width: 100%; max-width: 420px;
        }
        .auth-logo { color: var(--accent-blue); font-weight: 700; font-size: 1.8rem; }
        .auth-logo span { color: var(--accent-teal); }

        .icon-password { background-color: var(--bg-active); color: var(--accent-blue); }
        .icon-api      { background-color: #1a3a2a; color: var(--accent-teal); }
        .icon-note     { background-color: #3a2e10; color: var(--accent-warn); }
        .icon-identity { background-color: #2a1a3a; color: var(--accent-purple); }

        /* ══ SETTINGS PAGE ══ */
        .settings-page { max-width: 1160px; margin: 0 auto; padding-bottom: 32px; }
        .settings-hero { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 24px; align-items: flex-start; margin-bottom: 28px; }
        .hero-copy h1 { font-size: clamp(2rem, 2.5vw, 2.7rem); color: var(--text-primary); margin-bottom: 10px; line-height: 1.05; }
        .hero-copy p  { color: var(--text-secondary); max-width: 560px; margin: 0; }
        .profile-widget { min-width: 320px; width: 100%; }
        .profile-card { background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 20px; padding: 22px; }
        .profile-header { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
        .profile-avatar {
            width: 56px; height: 56px; border-radius: 50%;
            display: grid; place-items: center;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            color: var(--bg-body); font-weight: 700; font-size: 1.2rem;
        }
        .profile-name  { color: var(--text-primary); font-weight: 700; }
        .profile-email { color: var(--text-secondary); font-size: 0.92rem; }
        .profile-button {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 16px; border-radius: 12px;
            border: 1px solid var(--border-input);
            background: var(--bg-hover);
            color: var(--text-primary); font-size: 0.92rem; cursor: pointer;
        }
        .fingerprint-block { margin-top: 20px; background: var(--bg-summary); border: 1px solid var(--border-main); border-radius: 16px; padding: 18px; }
        .fingerprint-label { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 10px; }
        .fingerprint-block code { color: #d4a574; font-size: 0.95rem; word-break: break-all; }

        .settings-panel { display: grid; grid-template-columns: minmax(0,1fr); gap: 24px; align-items: start; }
        .settings-card { background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 20px; padding: 24px; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03); }
        .settings-card h3 { display: flex; align-items: center; gap: 12px; color: var(--accent-blue); margin-bottom: 24px; font-size: 1rem; font-weight: 700; }
        .settings-group { margin-bottom: 20px; }
        .settings-group label { display: block; margin-bottom: 10px; color: var(--text-secondary); font-size: 0.95rem; }
        .settings-card .form-control { background: var(--bg-body); border: 1px solid var(--border-input); color: var(--text-primary); border-radius: 12px; min-height: 48px; padding: 12px 14px; }
        .settings-card .form-control:focus { border-color: var(--accent-blue); box-shadow: 0 0 0 0.15rem rgba(111,191,255,0.15); }
        .settings-card .btn-primary { min-width: 160px; padding: 10px 18px; }

        .lang-option { display: inline-flex; align-items: center; gap: 8px; padding: 11px 18px; border-radius: 12px; border: 1px solid var(--border-input); background: var(--bg-body); color: var(--text-primary); text-decoration: none; font-size: 0.93rem; transition: all 0.15s ease; }
        .lang-option.active { background: var(--bg-active); border-color: var(--accent-blue); }

        .danger-zone { background: rgba(248,113,113,0.08); border: 1px solid #f87171; }
        .danger-zone h3 { color: #f87171; }
        .danger-zone p { color: var(--text-primary); margin: 0; }
        .danger-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }
        .btn-danger { background: #f87171; border: none; color: #0f1117; min-width: 140px; }

        .summary-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 14px; background: var(--bg-summary); margin-bottom: 12px; }
        .summary-row:last-child { margin-bottom: 0; }
        .summary-row .label { color: var(--text-secondary); }
        .summary-row .value { color: var(--text-primary); }

        /* ══ MODAL ══ */
        #vaultModal { display: none; position: fixed; inset: 0; z-index: 9999; align-items: flex-start; justify-content: center; padding: 40px 20px; overflow-y: auto; }
        #vaultModal.open { display: flex; }
        #vaultModalBackdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(3px); z-index: 9998; opacity: 0; transition: opacity 0.25s ease; }
        #vaultModal.open #vaultModalBackdrop { opacity: 1; }
        #vaultModalDialog { position: relative; z-index: 9999; background: var(--bg-modal); border: 1px solid var(--border-input); border-radius: 16px; width: 100%; max-width: 720px; box-shadow: 0 24px 80px rgba(0,0,0,0.6); transform: translateY(24px) scale(0.98); opacity: 0; transition: transform 0.28s cubic-bezier(0.34,1.2,0.64,1), opacity 0.22s ease; overflow: hidden; }
        #vaultModal.open #vaultModalDialog { transform: translateY(0) scale(1); opacity: 1; }
        #vaultModalHeader { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid var(--border-input); background: var(--bg-topbar); }
        #vaultModalTitle { font-size: 1.05rem; font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }
        #vaultModalClose { width: 32px; height: 32px; background: none; border: none; border-radius: 8px; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1rem; transition: all 0.15s; }
        #vaultModalClose:hover { background: var(--bg-hover); color: var(--text-primary); }
        #vaultModalBody { padding: 28px 24px 24px; max-height: calc(100vh - 160px); overflow-y: auto; }
        #vaultModalBody::-webkit-scrollbar { width: 6px; }
        #vaultModalBody::-webkit-scrollbar-thumb { background: var(--border-input); border-radius: 3px; }
        #vaultModalLoading { display: flex; align-items: center; justify-content: center; padding: 60px 20px; gap: 12px; color: var(--text-muted); }
        .modal-spinner { width: 20px; height: 20px; border: 2px solid var(--border-input); border-top-color: var(--accent-blue); border-radius: 50%; animation: spin 0.7s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        #vaultModalBody .nv-wrap { padding: 0; margin: 0; max-width: 100%; }
        #vaultModalBody .nv-cancel { cursor: pointer; }

        /* ══ RESPONSIVE ══ */
        @media (max-width: 720px) {
            .top-bar { padding-right: 16px; }
            .top-bar-actions { gap: 6px; }
            .user-meta, .user-chevron, .top-icon-btn.secure { display: none; }
        }
        @media (max-width: 860px) {
            :root { --sidebar-width: 220px; --sidebar-collapsed-width: 64px; }
            .sidebar:not(.collapsed) { box-shadow: 16px 0 48px rgba(0,0,0,0.35); }
            .main-content { margin-left: var(--sidebar-collapsed-width); }
            .sidebar:not(.collapsed) + .main-content { margin-left: var(--sidebar-width); }
        }

        /* ══ SETTINGS SB (partagé par les 3 pages settings) ══ */
        .sb-settings { max-width: 860px; margin: 0 auto; padding: 32px 28px 64px; }
        .sb-flash { display: flex; align-items: center; gap: 10px; padding: 14px 18px; border-radius: 12px; margin-bottom: 20px; font-size: 0.92rem; font-weight: 500; }
        .sb-flash--success { background: #1a2e1a; border: 1px solid var(--accent-teal); color: var(--accent-teal); }
        .sb-flash--danger  { background: #2e1a1a; border: 1px solid var(--accent-danger); color: var(--accent-danger); }

        .sb-hero { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; margin-bottom: 28px; }
        .sb-hero__title { font-size: 2.2rem; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.1; }
        .sb-hero__badge { display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; color: var(--accent-blue); background: rgba(111,191,255,0.1); border: 1px solid rgba(111,191,255,0.2); border-radius: 6px; padding: 3px 10px; margin-bottom: 10px; }
        .sb-hero__sub { color: var(--text-secondary); font-size: 0.94rem; margin: 6px 0 0; }
        .sb-hero__left {}

        .sb-profile-card { background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 16px; padding: 20px; min-width: 260px; max-width: 340px; width: 100%; }
        .sb-profile-card__top { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
        .sb-profile-card__name  { color: var(--text-primary); font-weight: 700; font-size: 1rem; }
        .sb-profile-card__email { color: var(--text-secondary); font-size: 0.83rem; }
        .sb-profile-card__actions { display: flex; justify-content: flex-end; }
        .sb-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal)); display: flex; align-items: center; justify-content: center; color: var(--bg-body); font-weight: 700; font-size: 1.15rem; flex-shrink: 0; }

        .sb-section { background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 16px; padding: 24px 28px; margin-bottom: 20px; }
        .sb-section--danger { background: rgba(248,113,113,0.04); border-color: rgba(248,113,113,0.25); }
        .sb-section__title { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0 0 4px; display: flex; align-items: center; gap: 8px; }
        .sb-section__title--danger { color: var(--accent-danger); margin-bottom: 6px; }
        .sb-section__desc { color: var(--text-muted); font-size: 0.87rem; margin: 0 0 18px; line-height: 1.55; }
        .sb-section__row { display: grid; grid-template-columns: 1fr 1fr auto; align-items: end; gap: 16px; }
        .sb-field--inline { margin-bottom: 0; }
        .sb-section__action { display: flex; align-items: center; }
        .sb-field { margin-bottom: 16px; }
        .sb-field label { display: block; color: var(--text-secondary); font-size: 0.82rem; font-weight: 500; margin-bottom: 7px; }
        .sb-required { color: var(--accent-danger); font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.78rem; }
        .sb-field__err { display: block; color: var(--accent-danger); font-size: 0.8rem; margin-top: 5px; min-height: 16px; }
        .sb-input { width: 100%; padding: 11px 14px; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary); border-radius: 10px; font-size: 0.92rem; outline: none; transition: border-color 0.15s, box-shadow 0.15s; box-sizing: border-box; }
        .sb-input:focus { border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(111,191,255,0.12); }
        .sb-input[readonly] { opacity: 0.45; cursor: not-allowed; }
        .sb-input::placeholder { color: var(--text-muted); }
        .sb-input-wrap { position: relative; }
        .sb-input-wrap .sb-input { padding-right: 44px; }
        .sb-eye { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.88rem; padding: 4px; transition: color 0.15s; }
        .sb-eye:hover { color: var(--accent-blue); }
        .sb-step2 { overflow: hidden; max-height: 0; opacity: 0; transition: max-height 0.35s ease, opacity 0.3s ease, margin 0.3s ease; margin-top: 0; }
        .sb-step2.revealed { max-height: 120px; opacity: 1; margin-top: 4px; }
        .sb-hidden { display: none !important; }
        .sb-danger-desc { color: #9a7060; font-size: 0.88rem; margin-bottom: 20px; line-height: 1.6; }
        .sb-danger-desc strong { color: var(--accent-danger); }
        .sb-danger-inline { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }

        .sb-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 10px; font-size: 0.88rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; text-decoration: none; white-space: nowrap; }
        .sb-btn--primary { background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal)); color: #0f1117; }
        .sb-btn--primary:hover { opacity: 0.85; transform: translateY(-1px); }
        .sb-btn--secondary { background: var(--bg-hover); color: var(--text-secondary); border: 1px solid var(--border-input); }
        .sb-btn--secondary:hover { color: var(--text-primary); border-color: var(--accent-blue); }
        .sb-btn--ghost { background: transparent; color: #9a7a60; border: 1px solid #3a2e1a; }
        .sb-btn--ghost:hover { color: #E8D5B5; border-color: #C97B2E; }
        .sb-btn--outline-danger { background: transparent; color: var(--accent-danger); border: 1px solid rgba(248,113,113,0.4); }
        .sb-btn--outline-danger:hover { background: rgba(248,113,113,0.08); border-color: var(--accent-danger); }
        .sb-btn--solid-danger { background: rgba(248,113,113,0.15); color: var(--accent-danger); border: 1px solid rgba(248,113,113,0.5); }
        .sb-btn--solid-danger:hover { background: rgba(248,113,113,0.25); }

        .sb-modal { display: none; position: fixed; inset: 0; z-index: 9999; align-items: center; justify-content: center; padding: 20px; }
        .sb-modal.open { display: flex; }
        .sb-modal__backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.78); backdrop-filter: blur(4px); }
        .sb-modal__dialog { position: relative; z-index: 1; background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 18px; width: 100%; max-width: 460px; box-shadow: 0 28px 80px rgba(0,0,0,0.6); animation: modalIn 0.22s ease; }
        @keyframes modalIn { from { transform: translateY(18px) scale(0.97); opacity: 0; } to { transform: none; opacity: 1; } }
        .sb-modal__header { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid rgba(248,113,113,0.2); color: #E8D5B5; font-weight: 700; font-size: 0.93rem; }
        .sb-modal__close { background: none; border: none; color: #9a7a60; cursor: pointer; font-size: 1rem; padding: 4px 8px; border-radius: 6px; transition: color 0.15s; }
        .sb-modal__close:hover { color: #E8D5B5; }
        .sb-modal__body { padding: 24px; }
        .sb-modal__desc { color: #9a7060; font-size: 0.9rem; margin-bottom: 20px; line-height: 1.6; }
        .sb-modal__footer { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 24px; border-top: 1px solid rgba(248,113,113,0.15); }

        /* ══ SB CARDS (Appearance + Security) ══ */
        .sb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .sb-card { background: var(--bg-card); border: 1px solid var(--border-main); border-radius: 16px; padding: 24px; }
        .sb-card--danger { border-color: rgba(248,113,113,0.2); background: rgba(248,113,113,0.03); }
        .sb-card__header { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; }
        .sb-card__header h3 { color: var(--text-primary); font-size: 0.97rem; font-weight: 700; margin: 0 0 4px; }
        .sb-card__desc { color: var(--text-secondary); font-size: 0.83rem; margin: 0; line-height: 1.5; }
        .sb-card__icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; flex-shrink: 0; }
        .sb-card__icon--blue { background: rgba(111,191,255,0.12); color: var(--accent-blue); }
        .sb-card__icon--red  { background: rgba(248,113,113,0.12); color: var(--accent-danger); }

        @media (max-width: 640px) {
            .sb-settings { padding: 20px 16px 48px; }
            .sb-section { padding: 18px 16px; }
            .sb-section__row { grid-template-columns: 1fr; }
            .sb-danger-inline { flex-direction: column; align-items: stretch; }
            .sb-danger-inline .sb-btn { justify-content: center; }
            .sb-hero__title { font-size: 1.7rem; }
            .sb-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
{% block full_page %}
{% if app.user %}

{# ══════════════ SIDEBAR ══════════════ #}
<div class="sidebar collapsed" id="sidebar">
    <button class="sidebar-edge-toggle" type="button" onclick="toggleSidebar()" title="Réduire / agrandir le menu">
        <i class="fas fa-chevron-left sidebar-toggle-icon"></i>
    </button>
    <div class="sidebar-logo">
        <div class="brand-lockup">
            <div class="brand-mark" aria-hidden="true">
                <i class="fas fa-lock"></i>
            </div>
            <div class="brand-copy">
                <h4>Secur<span class="brand-accent">Box</span></h4>
                <small>Coffre-fort numérique</small>
            </div>
        </div>
    </div>

    <div class="sidebar-main-nav">

        {# Coffres #}
        <a href="{{ path('app_vault_index') }}"
           class="nav-item {{ app.request.get('_route') starts with 'app_vault' ? 'active' : '' }}"
           title="Coffres">
            <i class="fas fa-vault nav-icon"></i>
            <span class="nav-label">Coffres</span>
        </a>

        {#  Envoyer — placeholder 
        <a href="#" class="nav-item" style="opacity:0.45; pointer-events:none; cursor:default;" title="Envoyer">
            <i class="far fa-paper-plane nav-icon"></i>
            <span class="nav-label">Envoyer</span>
        </a>#}

        {# Outils #}
        <button class="nav-item" onclick="toggleNav('toolsNav', this)" id="toolsBtn" title="Outils">
            <i class="fas fa-wrench nav-icon"></i>
            <span class="nav-label">Outils</span>
            <i class="fas fa-chevron-right nav-arrow"></i>
        </button>
        <div class="nav-sub" id="toolsNav">
            <a href="{{ path('tools_generator') }}" class="nav-sub-item">
                <i class="fas fa-magic me-2" style="font-size:0.8rem;"></i> Générateur
            </a>
            <a href="{{ path('tools_import') }}" class="nav-sub-item">
                <i class="fas fa-file-import me-2" style="font-size:0.8rem;"></i> Import
            </a>
            <a href="{{ path('tools_export') }}" class="nav-sub-item">
                <i class="fas fa-file-export me-2" style="font-size:0.8rem;"></i> Export
            </a>
        </div>

        {# Paramètres #}
        <button class="nav-item {{ app.request.get('_route') starts with 'app_settings' or app.request.get('_route') starts with 'app_admin' ? 'open' : '' }}"
                onclick="toggleNav('settingsNav', this)" id="settingsBtn" title="Paramètres">
            <i class="fas fa-cog nav-icon"></i>
            <span class="nav-label">Paramètres</span>
            <i class="fas fa-chevron-right nav-arrow"></i>
        </button>
        <div class="nav-sub {{ app.request.get('_route') starts with 'app_settings' or app.request.get('_route') starts with 'app_admin' ? 'open' : '' }}"
             id="settingsNav">
            <a href="{{ path('app_settings') }}"
               class="nav-sub-item {{ app.request.get('_route') == 'app_settings' ? 'active' : '' }}">
                <i class="fas fa-user me-2" style="font-size:0.8rem;"></i> Mon compte
            </a>
            <a href="{{ path('app_settings_security') }}"
               class="nav-sub-item {{ app.request.get('_route') == 'app_settings_security' ? 'active' : '' }}">
                <i class="fas fa-shield-alt me-2" style="font-size:0.8rem;"></i> Sécurité
            </a>
            <a href="{{ path('app_settings_appearance') }}"
               class="nav-sub-item {{ app.request.get('_route') == 'app_settings_appearance' ? 'active' : '' }}">
                <i class="fas fa-palette me-2" style="font-size:0.8rem;"></i> Apparence
            </a>
        </div>
    </div>

    {# Bottom section #}
    <div class="sidebar-bottom">
        <a href="{{ path('app_vault_index') }}"
           class="sidebar-bottom-item {{ app.request.get('_route') starts with 'app_vault' ? 'active' : '' }}"
           title="Gestionnaire de mots de passe">
            <i class="fas fa-lock"></i>
            <span class="sidebar-bottom-label">Gestionnaire de mots de passe</span>
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_admin_index') }}"
           class="sidebar-bottom-item {{ app.request.get('_route') starts with 'app_admin' ? 'active' : '' }}"
           title="Console d'administration">
            <i class="fas fa-th"></i>
            <span class="sidebar-bottom-label">Console d'administration</span>
        </a>
        {% endif %}
        <button class="sidebar-collapse-btn" onclick="toggleSidebar()" title="Réduire / agrandir le menu">
            <i class="fas fa-chevron-left sidebar-toggle-icon"></i>
        </button>
    </div>
</div>

{# ══════════════ MAIN ══════════════ #}
<div class="main-content expanded {{ app.request.get('_route') starts with 'app_vault' ? 'vault' : '' }}" id="mainContent">

    {# TOP BAR #}
    <div class="top-bar">
        {# Nouveau dropdown #}
        <div style="position:relative;">
            <button onclick="toggleNewMenu()" class="btn btn-primary px-4"
                    style="display:flex; align-items:center; gap:8px;">
                <i class="fas fa-plus"></i> Nouveau
                <i class="fas fa-chevron-down" style="font-size:0.75rem;"></i>
            </button>
            <div id="newMenu" style="display:none; position:absolute; top:48px; left:0;
                 width:230px; background:var(--bg-input); border:1px solid var(--border-input); border-radius:10px;
                 overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.25); z-index:999;">
                <a href="{{ path('app_vault_new', {'type': 'password'}) }}"
                   data-modal-url="{{ path('app_vault_new', {'type': 'password', 'modal': '1'}) }}"
                   data-modal-title="🔑 Nouveau Mot de passe"
                   class="modal-trigger"
                   style="display:flex; align-items:center; gap:12px; padding:11px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                   onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                   onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                    <i class="fas fa-key fa-fw" style="color:var(--accent-blue);"></i> Mot de passe
                </a>
                <a href="{{ path('app_vault_new', {'type': 'api_key'}) }}"
                   data-modal-url="{{ path('app_vault_new', {'type': 'api_key', 'modal': '1'}) }}"
                   data-modal-title="⚙️ Nouvelle Clé API"
                   class="modal-trigger"
                   style="display:flex; align-items:center; gap:12px; padding:11px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                   onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                   onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                    <i class="fas fa-code fa-fw" style="color:var(--accent-teal);"></i> Clé API
                </a>
                <a href="{{ path('app_vault_new', {'type': 'identity'}) }}"
                   data-modal-url="{{ path('app_vault_new', {'type': 'identity', 'modal': '1'}) }}"
                   data-modal-title="👤 Nouvelle Identité"
                   class="modal-trigger"
                   style="display:flex; align-items:center; gap:12px; padding:11px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                   onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                   onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                    <i class="fas fa-id-card fa-fw" style="color:var(--accent-purple);"></i> Identité
                </a>
                <a href="{{ path('app_vault_new', {'type': 'note'}) }}"
                   data-modal-url="{{ path('app_vault_new', {'type': 'note', 'modal': '1'}) }}"
                   data-modal-title="📝 Nouvelle Note sécurisée"
                   class="modal-trigger"
                   style="display:flex; align-items:center; gap:12px; padding:11px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                   onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                   onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                    <i class="fas fa-sticky-note fa-fw" style="color:var(--accent-warn);"></i> Note sécurisée
                </a>
                <div style="border-top:1px solid var(--border-input); margin:4px 0;"></div>
                <a href="{{ path('app_collection_new') }}"
                   style="display:flex; align-items:center; gap:12px; padding:11px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                   onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                   onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                    <i class="fas fa-layer-group fa-fw" style="color:var(--accent-blue);"></i> Nouvelle collection
                </a>
            </div>
        </div>

        {% set displayName = app.user.email|split('@')[0]|replace({'.': ' ', '_': ' ', '-': ' '})|title %}
        <div class="top-bar-actions">
            {# Notifications #}
             <div style="position:relative;">
        <button class="top-icon-btn" type="button" onclick="toggleNotifications()" title="Notifications">
        <i class="far fa-bell"></i>
        <span class="notification-dot" id="notifBadge" style="display:none;">0</span>
    </button>
    <div id="notifPanel" style="display:none; position:absolute; top:48px; right:0;
         width:320px; background:var(--bg-card); border:1px solid var(--border-input);
         border-radius:12px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.3); z-index:999;">
        <div style="padding:12px 16px; border-bottom:1px solid var(--border-input); display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:0.85rem; font-weight:700; color:var(--text-primary);">Notifications</span>
        </div>
        <div id="notifBody" style="max-height:360px; overflow-y:auto;"></div>
    </div>
</div>
            

            {# ══ TOGGLE DARK / LIGHT ══ #}
            <button class="top-icon-btn" type="button" onclick="toggleTheme()" id="themeToggleBtn" title="Changer le thème">
                <i id="themeIcon" class="far fa-moon"></i>
            </button>

            <div class="top-separator"></div>

            {# User profile #}
            <div style="position:relative;">
                <button class="user-pill" type="button" onclick="toggleMenu()" data-user-menu-trigger>
                    <span class="user-avatar">{{ displayName|first|upper }}</span>
                    <span class="user-meta">
                        <span class="user-name">{{ displayName }}</span>
                        <span class="user-plan">{% if is_granted('ROLE_ADMIN') %}Administrateur{% else %}Premium{% endif %}</span>
                    </span>
                    <i class="fas fa-chevron-down user-chevron"></i>
                </button>
                <div id="userMenu"
                     style="display:none; position:absolute; top:48px; right:0;
                            width:260px; background:var(--bg-input); border:1px solid var(--border-input);
                            border-radius:10px; overflow:hidden;
                            box-shadow:0 8px 30px rgba(0,0,0,0.25); z-index:999;">
                    <div style="padding:14px 16px; border-bottom:1px solid var(--border-input);">
                        <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">
                            Connecté en tant que
                        </div>
                        <div style="color:var(--accent-blue); font-weight:700; font-size:0.92rem;">{{ displayName }}</div>
                        <div style="color:var(--text-muted); font-size:0.78rem;">{{ app.user.email }}</div>
                    </div>
                    <a href="{{ path('app_settings') }}"
                       style="display:flex; align-items:center; gap:12px; padding:10px 16px; color:var(--text-secondary); text-decoration:none; font-size:0.88rem;"
                       onmouseenter="this.style.background='var(--bg-hover)'; this.style.color='var(--text-primary)';"
                       onmouseleave="this.style.background='transparent'; this.style.color='var(--text-secondary)';">
                        <i class="fas fa-user-cog fa-fw"></i> Mon compte
                    </a>
                    <div style="border-top:1px solid var(--border-input);">
                        <a href="{{ path('app_logout') }}"
                           style="display:flex; align-items:center; gap:12px; padding:10px 16px; color:var(--accent-danger); text-decoration:none; font-size:0.88rem;"
                           onmouseenter="this.style.background='rgba(248,113,113,0.08)';"
                           onmouseleave="this.style.background='transparent';">
                            <i class="fas fa-sign-out-alt fa-fw"></i> Déconnexion
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>{# /top-bar #}

    <div class="content-area {{ app.request.get('_route') starts with 'app_vault' ? 'content-area--vault' : '' }}">
        {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" style="margin:16px 28px 0; border-radius:10px;">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" style="margin:16px 28px 0; border-radius:10px;">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
</div>

{# ══ MODAL ══ #}
<div id="vaultModal">
    <div id="vaultModalBackdrop" onclick="closeVaultModal()"></div>
    <div id="vaultModalDialog" role="dialog" aria-modal="true">
        <div id="vaultModalHeader">
            <div id="vaultModalTitle">Nouveau Secret</div>
            <button id="vaultModalClose" onclick="closeVaultModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="vaultModalBody">
            <div id="vaultModalLoading">
                <div class="modal-spinner"></div>
                <span style="font-size:0.88rem;">Chargement…</span>
            </div>
        </div>
    </div>
</div>

{% else %}
    {{ block('body') }}
{% endif %}
{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ══════════════════════════════════════════════════════
   SYSTÈME DE THÈME — Dark / Light
   ══════════════════════════════════════════════════════ */

/**
 * Applique le thème résolu ('dark' ou 'light') au document
 * et met à jour l'icône de la topbar.
 */
function applyTheme(resolved) {
    document.documentElement.setAttribute('data-theme', resolved);
    const icon = document.getElementById('themeIcon');
    if (icon) {
        icon.className = resolved === 'light' ? 'far fa-sun' : 'far fa-moon';
    }
}

/**
 * Résout la valeur brute ('dark'|'light'|'system') en 'dark'/'light'.
 */
function resolveTheme(raw) {
    if (raw === 'light' || raw === 'dark') return raw;
    // 'system' ou null
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
}

/**
 * Appelé par le bouton lune/soleil de la topbar.
 * Bascule dark ↔ light et sauvegarde en localStorage.
 */
function toggleTheme() {
    var current = document.documentElement.getAttribute('data-theme');
    var next = current === 'light' ? 'dark' : 'light';
    applyTheme(next);
    localStorage.setItem('securboxTheme', next);
    // Synchronise le select de la page Apparence si elle est ouverte
    var sel = document.getElementById('themeSelect');
    if (sel) sel.value = next;
}

/**
 * Appelé par le select de la page Apparence.
 * @param {string} value - 'dark' | 'light' | 'system'
 */
function applyThemeFromSelect(value) {
    localStorage.setItem('securboxTheme', value);
    applyTheme(resolveTheme(value));
}

/* Initialisation au chargement */
document.addEventListener('DOMContentLoaded', function () {
    var saved = localStorage.getItem('securboxTheme') || 'dark';
    applyTheme(resolveTheme(saved));

    /* Sidebar */
    var savedSidebar = localStorage.getItem('securboxSidebarCollapsedV2');
    setSidebarCollapsed(savedSidebar === null ? true : savedSidebar === '1');

    /* Écoute les changements système (pour le mode 'system') */
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function () {
        if (localStorage.getItem('securboxTheme') === 'system') {
            applyTheme(resolveTheme('system'));
        }
    });
});

/* ══════════════════════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════════════════════ */
function setSidebarCollapsed(collapsed) {
    var sidebar = document.getElementById('sidebar');
    var main    = document.getElementById('mainContent');
    var icons   = document.querySelectorAll('.sidebar-toggle-icon');
    if (!sidebar || !main || !icons.length) return;
    sidebar.classList.toggle('collapsed', collapsed);
    main.classList.toggle('expanded', collapsed);
    icons.forEach(function(icon) {
        icon.className = collapsed
            ? 'fas fa-chevron-right sidebar-toggle-icon'
            : 'fas fa-chevron-left sidebar-toggle-icon';
    });
    localStorage.setItem('securboxSidebarCollapsedV2', collapsed ? '1' : '0');
}

function toggleSidebar() {
    var sidebar = document.getElementById('sidebar');
    if (!sidebar) return;
    setSidebarCollapsed(!sidebar.classList.contains('collapsed'));
}

/* ══════════════════════════════════════════════════════
   NAV EXPANDABLE
   ══════════════════════════════════════════════════════ */
function toggleNav(id, btn) {
    var sidebar = document.getElementById('sidebar');
    if (sidebar && sidebar.classList.contains('collapsed')) {
        setSidebarCollapsed(false);
    }
    var sub    = document.getElementById(id);
    var isOpen = sub.classList.contains('open');
    sub.classList.toggle('open', !isOpen);
    btn.classList.toggle('open', !isOpen);
}

/* ══════════════════════════════════════════════════════
   DROPDOWNS
   ══════════════════════════════════════════════════════ */
function toggleNewMenu() {
    var m = document.getElementById('newMenu');
    if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
}
function toggleMenu() {
    var m = document.getElementById('userMenu');
    if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
}

document.addEventListener('click', function(e) {
    var userMenu = document.getElementById('userMenu');
    var newMenu  = document.getElementById('newMenu');
    if (userMenu && !e.target.closest('[data-user-menu-trigger]') && !e.target.closest('#userMenu'))
        userMenu.style.display = 'none';
    if (newMenu  && !e.target.closest('[onclick="toggleNewMenu()"]') && !e.target.closest('#newMenu'))
        newMenu.style.display  = 'none';
});

/* ══════════════════════════════════════════════════════
   MODAL VAULT
   ══════════════════════════════════════════════════════ */
var vaultModal      = document.getElementById('vaultModal');
var vaultModalBody  = document.getElementById('vaultModalBody');
var vaultModalTitle = document.getElementById('vaultModalTitle');

function openVaultModal(url, title) {
    if (!vaultModal) return;
    vaultModalBody.innerHTML = '<div id="vaultModalLoading"><div class="modal-spinner"></div><span style="font-size:0.88rem;">Chargement…</span></div>';
    vaultModalTitle.textContent = title || 'Nouveau Secret';
    vaultModal.classList.add('open');
    document.body.style.overflow = 'hidden';
    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.text(); })
        .then(function(html) {
            vaultModalBody.innerHTML = html;
            vaultModalBody.querySelectorAll('script').forEach(function(old) {
                var s = document.createElement('script');
                s.textContent = old.textContent;
                old.replaceWith(s);
            });
            wireModalForm();
        })
        .catch(function() {
            vaultModalBody.innerHTML = '<p style="color:var(--accent-danger);padding:20px;">Erreur de chargement.</p>';
        });
}

function closeVaultModal() {
    if (!vaultModal) return;
    vaultModal.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(function() { vaultModalBody.innerHTML = ''; }, 280);
}

document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeVaultModal(); });

document.addEventListener('click', function(e) {
    var trigger = e.target.closest('.modal-trigger');
    if (!trigger) return;
    e.preventDefault();
    var newMenu = document.getElementById('newMenu');
    if (newMenu) newMenu.style.display = 'none';
    var url = trigger.dataset.modalUrl;
    var collectionId = new URLSearchParams(window.location.search).get('collection');
    if (collectionId) {
        var u = new URL(url, window.location.origin);
        u.searchParams.set('collection', collectionId);
        url = u.toString();
    }
    openVaultModal(url, trigger.dataset.modalTitle);
});

function wireModalForm() {
    var form      = vaultModalBody.querySelector('#secretForm');
    if (!form) return;
    var cancelBtn = vaultModalBody.querySelector('.nv-cancel');
    if (cancelBtn) cancelBtn.addEventListener('click', function(e) { e.preventDefault(); closeVaultModal(); });
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (typeof prepareData === 'function') prepareData(e);
        var formData = new FormData(form);
        fetch(form.action || window.location.href, {
            method: 'POST', body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) {
            if (r.redirected || r.ok) {
                closeVaultModal();
                showInlineFlash('Secret sauvegardé avec succès !', 'success');
                setTimeout(function() { window.location.reload(); }, 800);
            } else {
                return r.text().then(function(html) {
                    vaultModalBody.innerHTML = html;
                    vaultModalBody.querySelectorAll('script').forEach(function(old) {
                        var s = document.createElement('script');
                        s.textContent = old.textContent;
                        old.replaceWith(s);
                    });
                    wireModalForm();
                });
            }
        })
        .catch(function() { showInlineFlash('Erreur réseau.', 'error'); });
    });
}

function showInlineFlash(message, type) {
    var el = document.createElement('div');
    el.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
    el.style.cssText = 'position:fixed;top:24px;right:24px;z-index:99999;min-width:280px;border-radius:10px;font-size:0.88rem;padding:12px 16px;';
    el.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + ' me-2"></i>' + message;
    document.body.appendChild(el);
    setTimeout(function() { el.remove(); }, 3000);
}
/* ══ NOTIFICATIONS ══ */
function toggleNotifications() {
    const panel = document.getElementById('notifPanel');
    const userMenu = document.getElementById('userMenu');
    const newMenu = document.getElementById('newMenu');
    if (userMenu) userMenu.style.display = 'none';
    if (newMenu) newMenu.style.display = 'none';
    if (!panel) return;
    const isOpen = panel.style.display !== 'none';
    panel.style.display = isOpen ? 'none' : 'block';
    if (!isOpen) loadNotifications();
}

function loadNotifications() {
    const body = document.getElementById('notifBody');
    if (!body) return;
    body.innerHTML = '<div style="padding:20px; text-align:center; color:var(--text-muted); font-size:0.85rem;"><i class="fas fa-spinner fa-spin"></i> Chargement...</div>';
    fetch('/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            updateNotifBadge(data.count);
            if (!data.notifications || data.notifications.length === 0) {
                body.innerHTML = '<div style="padding:24px 16px; text-align:center; color:var(--text-muted); font-size:0.85rem;"><i class="fas fa-check-circle" style="font-size:1.5rem; display:block; margin-bottom:8px; color:var(--accent-teal);"></i>Tout est en ordre !</div>';
                return;
            }
            body.innerHTML = data.notifications.map(n => `
                <div style="display:flex; align-items:flex-start; gap:10px; padding:12px 16px; border-bottom:1px solid var(--border-subtle); transition:background 0.12s;" onmouseenter="this.style.background='var(--bg-hover)'" onmouseleave="this.style.background='transparent'">
                    <div style="width:32px; height:32px; border-radius:8px; background:${n.bg}; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:0.85rem; color:${n.color};">
                        <i class="${n.icon}"></i>
                    </div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:0.85rem; color:var(--text-primary); font-weight:500; margin-bottom:2px;">${n.title}</div>
                        <div style="font-size:0.78rem; color:var(--text-muted); line-height:1.4;">${n.message}</div>
                    </div>
                </div>
            `).join('');
        })
        .catch(() => {
            body.innerHTML = '<div style="padding:16px; text-align:center; color:var(--text-muted); font-size:0.85rem;">Erreur de chargement</div>';
        });
}

function updateNotifBadge(count) {
    const badge = document.getElementById('notifBadge');
    if (!badge) return;
    badge.textContent = count;
    badge.style.display = count > 0 ? 'flex' : 'none';
}

document.addEventListener('click', function(e) {
    const panel = document.getElementById('notifPanel');
    if (panel && panel.style.display !== 'none') {
        if (!e.target.closest('#notifPanel') && !e.target.closest('[onclick="toggleNotifications()"]')) {
            panel.style.display = 'none';
        }
    }
});
</script>
</body>
</html>
