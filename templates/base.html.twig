<style>
/* ══════════════════════════════════════════════════════
   LOCK SCREEN — full-page takeover, NO app visible
   ══════════════════════════════════════════════════════ */
#vaultLockScreen {
    position: fixed;
    inset: 0;
    z-index: 999999;          /* above everything */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

/* Plain gradient background — NO blur, NO app peeking through */
.vls-bg {
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 80% 60% at 30% 20%, rgba(48,107,255,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 75% 75%, rgba(77,212,172,0.12) 0%, transparent 55%),
        #0a0d14;               /* solid dark — app content is HIDDEN, not blurred */
}

/* Card */
.vls-card {
    position: relative;
    z-index: 1;
    background: rgba(20, 27, 39, 0.97);
    border: 1px solid rgba(111,191,255,0.15);
    border-radius: 24px;
    padding: 36px 36px 28px;
    width: 100%;
    max-width: 400px;
    text-align: center;
    box-shadow:
        0 40px 100px rgba(0,0,0,0.7),
        0 0 0 1px rgba(255,255,255,0.04) inset;
    animation: vlsIn 0.35s cubic-bezier(0.34, 1.2, 0.64, 1) both;
}
@keyframes vlsIn {
    from { transform: scale(0.9) translateY(28px); opacity: 0; }
    to   { transform: scale(1)   translateY(0);    opacity: 1; }
}

/* Brand */
.vls-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 28px;
}
.vls-brand-mark {
    width: 36px; height: 40px;
    display: grid; place-items: center;
    font-size: 1rem; color: #dff3ff;
    background:
        radial-gradient(circle at 50% 28%, rgba(116,255,221,0.25), transparent 34%),
        linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);
    clip-path: polygon(50% 0,92% 18%,82% 82%,50% 100%,18% 82%,8% 18%);
    box-shadow: 0 8px 20px rgba(48,107,255,0.3);
}
.vls-brand-name {
    font-size: 1.1rem; font-weight: 700; color: #6fbfff; letter-spacing: 0.02em;
}
.vls-brand-name span { color: #4dd4ac; }

/* Lock ring icon */
.vls-lock-ring {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(248,113,113,0.1);
    border: 2px solid rgba(248,113,113,0.25);
    color: #f87171;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    margin: 0 auto 18px;
    box-shadow: 0 0 0 6px rgba(248,113,113,0.06);
}

/* Text */
.vls-title {
    font-size: 1.25rem; font-weight: 700;
    color: #e0e0e0; margin: 0 0 10px;
}
.vls-sub {
    font-size: 0.82rem; color: #6b7280;
    line-height: 1.6; margin: 0 0 26px;
}

/* Field */
.vls-field { margin-bottom: 12px; text-align: left; }
.vls-input-wrap { position: relative; }
.vls-input {
    width: 100%;
    padding: 13px 46px 13px 16px;
    background: #0f1724;
    border: 1px solid #2a3040;
    border-radius: 12px;
    color: #e0e0e0;
    font-size: 0.95rem;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s, box-shadow 0.15s;
}
.vls-input:focus {
    border-color: #6fbfff;
    box-shadow: 0 0 0 3px rgba(111,191,255,0.12);
}
.vls-input.error {
    border-color: #f87171;
    box-shadow: 0 0 0 3px rgba(248,113,113,0.1);
}
.vls-input::placeholder { color: #374151; }

.vls-eye {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: #4b5563;
    cursor: pointer; padding: 4px; font-size: 0.9rem;
    transition: color 0.15s;
}
.vls-eye:hover { color: #6fbfff; }

.vls-error {
    font-size: 0.78rem; color: #f87171;
    margin-top: 6px; min-height: 18px;
    display: flex; align-items: center; gap: 6px;
}

/* Button */
.vls-btn {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #6fbfff, #4dd4ac);
    border: none; border-radius: 12px;
    color: #0f1117; font-weight: 700; font-size: 0.95rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: opacity 0.15s, transform 0.1s;
    margin-bottom: 18px;
    letter-spacing: 0.01em;
}
.vls-btn:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
.vls-btn:active:not(:disabled) { transform: translateY(0); }
.vls-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.vls-spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(15,17,23,0.25);
    border-top-color: #0f1117;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    display: inline-block; flex-shrink: 0;
}

/* Logout link */
.vls-logout-link {
    display: inline-flex; align-items: center; gap: 7px;
    color: #4b5563; font-size: 0.8rem; text-decoration: none;
    transition: color 0.15s;
}
.vls-logout-link:hover { color: #f87171; }

/* Hide the sidebar and main-content when locked */
body.vault-locked #sidebar,
body.vault-locked #mainContent {
    visibility: hidden !important;
    pointer-events: none !important;
}
</style>

<script>
/* ══════════════════════════════════════════════════════════════════
   VAULT INACTIVITY LOCK SYSTEM
   ══════════════════════════════════════════════════════════════════ */
(function () {
    var TIMEOUT_MS     = (window.SECURBOX_TIMEOUT_MINUTES || 15) * 60 * 1000;
    var TIMEOUT_ACTION = window.SECURBOX_TIMEOUT_ACTION  || 'lock';
    var lockTimer      = null;
    var isLocked       = false;

    // 0 = never lock
    if (TIMEOUT_MS === 0) return;

    function resetTimer() {
        if (isLocked) return;
        clearTimeout(lockTimer);
        lockTimer = setTimeout(triggerLock, TIMEOUT_MS);
    }

    ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click'].forEach(function (ev) {
        document.addEventListener(ev, resetTimer, { passive: true });
    });

    // Start timer on page load
    resetTimer();

    function triggerLock() {
        if (isLocked) return;
        if (TIMEOUT_ACTION === 'logout') {
            window.location.href = window.SECURBOX_LOGOUT_URL;
            return;
        }
        showLockScreen();
    }

    window.showLockScreen = function () {
        if (isLocked) return;
        isLocked = true;

        // Hide app content — body class covers sidebar + mainContent via CSS
        document.body.classList.add('vault-locked');

        var screen = document.getElementById('vaultLockScreen');
        if (screen) screen.style.display = 'flex';

        // Notify server
        fetch(window.SECURBOX_LOCK_URL, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).catch(function () {});

        // Focus input
        setTimeout(function () {
            var inp = document.getElementById('vlsMasterPwd');
            if (inp) inp.focus();
        }, 80);
    };

    window._securboxSetUnlocked = function () {
        isLocked = false;
        document.body.classList.remove('vault-locked');
        resetTimer();
    };
})();

/* ── Unlock form submission ── */
async function unlockVault(e) {
    e.preventDefault();

    var inp   = document.getElementById('vlsMasterPwd');
    var btn   = document.getElementById('vlsSubmitBtn');
    var errEl = document.getElementById('vlsError');
    var txt   = document.getElementById('vlsBtnText');
    var spin  = document.getElementById('vlsBtnSpinner');

    errEl.textContent = '';
    inp.classList.remove('error');
    btn.disabled = true;
    txt.style.display  = 'none';
    spin.style.display = 'flex';

    try {
        var fd = new FormData();
        fd.append('master_password', inp.value);

        var res  = await fetch(window.SECURBOX_UNLOCK_URL, {
            method:  'POST',
            body:    fd,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        var data = await res.json();

        if (data.ok) {
            // Animate card out
            var card = document.querySelector('.vls-card');
            if (card) {
                card.style.transition = 'transform 0.2s ease, opacity 0.2s ease';
                card.style.transform  = 'scale(0.95)';
                card.style.opacity    = '0';
            }

            setTimeout(function () {
                var screen = document.getElementById('vaultLockScreen');
                if (screen) screen.style.display = 'none';
                // Show the app again
                if (typeof window._securboxSetUnlocked === 'function') {
                    window._securboxSetUnlocked();
                }
                inp.value = '';
                if (card) { card.style.transform = ''; card.style.opacity = ''; }
            }, 200);
        } else {
            errEl.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + (data.error || 'Mot de passe incorrect.');
            inp.classList.add('error');
            // Shake animation
            inp.style.animation = 'none';
            inp.offsetHeight; // reflow
            inp.style.animation = 'vlsShake 0.35s ease';
            inp.value = '';
            inp.focus();
        }
    } catch (err) {
        errEl.textContent = 'Erreur réseau. Réessayez.';
    } finally {
        btn.disabled = false;
        txt.style.display  = 'flex';
        spin.style.display = 'none';
    }
}

function toggleVlsPwd() {
    var inp  = document.getElementById('vlsMasterPwd');
    var icon = document.getElementById('vlsEyeIcon');
    if (!inp) return;
    inp.type = inp.type === 'password' ? 'text' : 'password';
    icon.className = inp.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
    inp.focus();
}

/* Shake keyframe (added dynamically so it doesn't conflict) */
(function () {
    var style = document.createElement('style');
    style.textContent = '@keyframes vlsShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-8px)} 40%{transform:translateX(8px)} 60%{transform:translateX(-6px)} 80%{transform:translateX(4px)} }';
    document.head.appendChild(style);
})();
</script>
{% else %}
    {{ block('body') }}
{% endif %}
{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ══════════════════════════════════════════════════════
   SYSTÈME DE THÈME — Dark / Light
   ══════════════════════════════════════════════════════ */

/**
 * Applique le thème résolu ('dark' ou 'light') au document
 * et met à jour l'icône de la topbar.
 */
function applyTheme(resolved) {
    document.documentElement.setAttribute('data-theme', resolved);
    const icon = document.getElementById('themeIcon');
    if (icon) {
        icon.className = resolved === 'light' ? 'far fa-sun' : 'far fa-moon';
    }
}

/**
 * Résout la valeur brute ('dark'|'light'|'system') en 'dark'/'light'.
 */
function resolveTheme(raw) {
    if (raw === 'light' || raw === 'dark') return raw;
    // 'system' ou null
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
}

/**
 * Appelé par le bouton lune/soleil de la topbar.
 * Bascule dark ↔ light et sauvegarde en localStorage.
 */
function toggleTheme() {
    var current = document.documentElement.getAttribute('data-theme');
    var next = current === 'light' ? 'dark' : 'light';
    applyTheme(next);
    localStorage.setItem('securboxTheme', next);
    // Synchronise le select de la page Apparence si elle est ouverte
    var sel = document.getElementById('themeSelect');
    if (sel) sel.value = next;
}

/**
 * Appelé par le select de la page Apparence.
 * @param {string} value - 'dark' | 'light' | 'system'
 */
function applyThemeFromSelect(value) {
    localStorage.setItem('securboxTheme', value);
    applyTheme(resolveTheme(value));
}

/* Initialisation au chargement */
document.addEventListener('DOMContentLoaded', function () {
    var saved = localStorage.getItem('securboxTheme') || 'dark';
    applyTheme(resolveTheme(saved));

    /* Sidebar */
    var savedSidebar = localStorage.getItem('securboxSidebarCollapsedV2');
    setSidebarCollapsed(savedSidebar === null ? true : savedSidebar === '1');

    /* Écoute les changements système (pour le mode 'system') */
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function () {
        if (localStorage.getItem('securboxTheme') === 'system') {
            applyTheme(resolveTheme('system'));
        }
    });
});

/* ══════════════════════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════════════════════ */
function setSidebarCollapsed(collapsed) {
    var sidebar = document.getElementById('sidebar');
    var main    = document.getElementById('mainContent');
    var icons   = document.querySelectorAll('.sidebar-toggle-icon');
    if (!sidebar || !main || !icons.length) return;
    sidebar.classList.toggle('collapsed', collapsed);
    main.classList.toggle('expanded', collapsed);
    icons.forEach(function(icon) {
        icon.className = collapsed
            ? 'fas fa-chevron-right sidebar-toggle-icon'
            : 'fas fa-chevron-left sidebar-toggle-icon';
    });
    localStorage.setItem('securboxSidebarCollapsedV2', collapsed ? '1' : '0');
}

function toggleSidebar() {
    var sidebar = document.getElementById('sidebar');
    if (!sidebar) return;
    setSidebarCollapsed(!sidebar.classList.contains('collapsed'));
}

/* ══════════════════════════════════════════════════════
   NAV EXPANDABLE
   ══════════════════════════════════════════════════════ */
function toggleNav(id, btn) {
    var sidebar = document.getElementById('sidebar');
    if (sidebar && sidebar.classList.contains('collapsed')) {
        setSidebarCollapsed(false);
    }
    var sub    = document.getElementById(id);
    var isOpen = sub.classList.contains('open');
    sub.classList.toggle('open', !isOpen);
    btn.classList.toggle('open', !isOpen);
}

/* ══════════════════════════════════════════════════════
   DROPDOWNS
   ══════════════════════════════════════════════════════ */
function toggleNewMenu() {
    var m = document.getElementById('newMenu');
    if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
}
function toggleMenu() {
    var m = document.getElementById('userMenu');
    if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
}

document.addEventListener('click', function(e) {
    var userMenu = document.getElementById('userMenu');
    var newMenu  = document.getElementById('newMenu');
    if (userMenu && !e.target.closest('[data-user-menu-trigger]') && !e.target.closest('#userMenu'))
        userMenu.style.display = 'none';
    if (newMenu  && !e.target.closest('[onclick="toggleNewMenu()"]') && !e.target.closest('#newMenu'))
        newMenu.style.display  = 'none';
});

/* ══════════════════════════════════════════════════════
   MODAL VAULT
   ══════════════════════════════════════════════════════ */
var vaultModal      = document.getElementById('vaultModal');
var vaultModalBody  = document.getElementById('vaultModalBody');
var vaultModalTitle = document.getElementById('vaultModalTitle');

function openVaultModal(url, title) {
    if (!vaultModal) return;
    vaultModalBody.innerHTML = '<div id="vaultModalLoading"><div class="modal-spinner"></div><span style="font-size:0.88rem;">Chargement…</span></div>';
    vaultModalTitle.textContent = title || 'Nouveau Secret';
    vaultModal.classList.add('open');
    document.body.style.overflow = 'hidden';
    fetch(url, {
    headers: { 'X-Requested-With': 'XMLHttpRequest' },
    cache: 'no-store'
})
        .then(function(r) { return r.text(); })
        .then(function(html) {
            vaultModalBody.innerHTML = html;
            vaultModalBody.querySelectorAll('script').forEach(function(old) {
                var s = document.createElement('script');
                s.textContent = old.textContent;
                old.replaceWith(s);
            });
            wireModalForm();
        })
        .catch(function() {
            vaultModalBody.innerHTML = '<p style="color:var(--accent-danger);padding:20px;">Erreur de chargement.</p>';
        });
}

function closeVaultModal() {
    if (!vaultModal) return;
    vaultModal.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(function() { vaultModalBody.innerHTML = ''; }, 280);
}

document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeVaultModal(); });

document.addEventListener('click', function(e) {
    var trigger = e.target.closest('.modal-trigger');
    if (!trigger) return;
    e.preventDefault();
    e.stopPropagation();
    // Ferme tous les menus ouverts
    var newMenu = document.getElementById('newMenu');
    if (newMenu) newMenu.style.display = 'none';
    document.querySelectorAll('.custom-dropdown-menu').forEach(function(m) {
        m.style.display = 'none';
    });
    var url = trigger.dataset.modalUrl;
    if (!url) return;
    var collectionId = new URLSearchParams(window.location.search).get('collection');
    if (collectionId && url.indexOf('vault/new') !== -1) {
        var u = new URL(url, window.location.origin);
        u.searchParams.set('collection', collectionId);
        url = u.toString();
    }
    openVaultModal(url, trigger.dataset.modalTitle);
});

function wireModalForm() {
    var form      = vaultModalBody.querySelector('#secretForm');
    if (!form) return;
    var cancelBtn = vaultModalBody.querySelector('.nv-cancel');
    if (cancelBtn) cancelBtn.addEventListener('click', function(e) { e.preventDefault(); closeVaultModal(); });
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (typeof prepareData === 'function') prepareData(e);
        var formData = new FormData(form);
        fetch(form.action || window.location.href, {
            method: 'POST', body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) {
            if (r.redirected || r.ok) {
                closeVaultModal();
                showInlineFlash('Secret sauvegardé avec succès !', 'success');
                setTimeout(function() { window.location.reload(); }, 800);
            } else {
                return r.text().then(function(html) {
                    vaultModalBody.innerHTML = html;
                    vaultModalBody.querySelectorAll('script').forEach(function(old) {
                        var s = document.createElement('script');
                        s.textContent = old.textContent;
                        old.replaceWith(s);
                    });
                });
            }
        })
        .catch(function() { showInlineFlash('Erreur réseau.', 'error'); });
    });
}

function showInlineFlash(message, type) {
    var el = document.createElement('div');
    el.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
    el.style.cssText = 'position:fixed;top:24px;right:24px;z-index:99999;min-width:280px;border-radius:10px;font-size:0.88rem;padding:12px 16px;';
    el.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + ' me-2"></i>' + message;
    document.body.appendChild(el);
    setTimeout(function() { el.remove(); }, 3000);
}
//* ══ NOTIFICATIONS ══ */
let _notifData     = [];
let _notifFilter   = 'all';
let _notifLoaded   = false;

function toggleNotifications() {
    const panel    = document.getElementById('notifPanel');
    const userMenu = document.getElementById('userMenu');
    const newMenu  = document.getElementById('newMenu');
    if (userMenu) userMenu.style.display = 'none';
    if (newMenu)  newMenu.style.display  = 'none';
    if (!panel)   return;

    const isOpen = panel.style.display !== 'none';
    panel.style.display = isOpen ? 'none' : 'block';
    if (!isOpen) loadNotifications();
}

function loadNotifications() {
    const body = document.getElementById('notifBody');
    if (!body) return;
    body.innerHTML = '<div style="padding:28px; text-align:center; color:var(--text-muted); font-size:0.85rem;"><i class="fas fa-spinner fa-spin" style="font-size:1.2rem; margin-bottom:8px; display:block;"></i>Chargement...</div>';

    fetch('/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            _notifData   = data.notifications || [];
            _notifLoaded = true;
            updateNotifBadge(data.count);
            // Update unread tab count
            const ub = document.getElementById('filterUnreadCount');
            if (ub) ub.textContent = data.count > 0 ? `(${data.count})` : '';
            renderNotifications();
        })
        .catch(() => {
            body.innerHTML = '<div style="padding:20px; text-align:center; color:var(--text-muted); font-size:0.85rem;">Erreur de chargement</div>';
        });
}

function renderNotifications() {
    const body = document.getElementById('notifBody');
    if (!body) return;

    const list = _notifFilter === 'unread'
        ? _notifData.filter(n => n.unread)
        : _notifData;

    if (list.length === 0) {
        body.innerHTML = `
            <div style="padding:40px 20px; text-align:center; color:var(--text-muted);">
                <i class="fas fa-check-circle" style="font-size:2rem; color:var(--accent-teal); display:block; margin-bottom:12px;"></i>
                <div style="font-size:0.88rem; font-weight:600; color:var(--text-secondary); margin-bottom:4px;">
                    ${_notifFilter === 'unread' ? 'Aucune notification non lue' : 'Aucune notification'}
                </div>
                <div style="font-size:0.78rem;">Tout est en ordre !</div>
            </div>`;
        return;
    }

    body.innerHTML = list.map(n => `
        <div onclick="handleNotifClick('${n.id}', '${n.link}')"
             style="display:flex; align-items:flex-start; gap:12px; padding:14px 16px;
                    border-bottom:1px solid var(--border-subtle); cursor:pointer;
                    transition:background 0.12s; position:relative;
                    background:${n.unread ? 'rgba(111,191,255,0.04)' : 'transparent'};"
             onmouseenter="this.style.background='var(--bg-hover)'"
             onmouseleave="this.style.background='${n.unread ? 'rgba(111,191,255,0.04)' : 'transparent'}'">

            <!-- Icon -->
            <div style="width:38px; height:38px; border-radius:10px; flex-shrink:0;
                        background:${n.bg}; display:flex; align-items:center; justify-content:center;
                        font-size:0.92rem; color:${n.color}; margin-top:2px;">
                <i class="${n.icon}"></i>
            </div>

            <!-- Content -->
            <div style="flex:1; min-width:0;">
                <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:3px;">
                    <span style="font-size:0.85rem; font-weight:${n.unread ? '700' : '600'};
                                 color:var(--text-primary); line-height:1.3;">
                        ${n.title}
                    </span>
                    ${n.unread ? '<span style="width:8px; height:8px; border-radius:50%; background:#6fbfff; flex-shrink:0; margin-top:4px;"></span>' : ''}
                </div>
                <div style="font-size:0.80rem; color:var(--text-secondary); margin-bottom:4px; line-height:1.4;">
                    ${n.message}
                </div>
                <div style="font-size:0.75rem; color:var(--text-muted); line-height:1.3;">
                    ${n.detail}
                </div>
                <div style="font-size:0.72rem; color:var(--text-muted); margin-top:5px; display:flex; align-items:center; gap:4px;">
                    <i class="far fa-clock" style="font-size:0.65rem;"></i>
                    ${n.relative} · ${n.date}
                </div>
            </div>
        </div>
    `).join('');
}

function handleNotifClick(id, link) {
    // Mark as read
    fetch('/notifications/mark-one-read', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: 'id=' + encodeURIComponent(id)
    });
    // Update local state
    const n = _notifData.find(x => x.id === id);
    if (n) n.unread = false;
    updateNotifBadge(_notifData.filter(x => x.unread).length);
    const ub = document.getElementById('filterUnreadCount');
    const unreadCount = _notifData.filter(x => x.unread).length;
    if (ub) ub.textContent = unreadCount > 0 ? `(${unreadCount})` : '';
    renderNotifications();
    // Navigate
    if (link) {
        document.getElementById('notifPanel').style.display = 'none';
        window.location.href = link;
    }
}

function markAllRead() {
    const ids = _notifData.map(n => n.id);
    const body = ids.map(id => `ids[]=${encodeURIComponent(id)}`).join('&');

    fetch('/notifications/mark-read', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: body
    }).then(() => {
        _notifData.forEach(n => n.unread = false);
        updateNotifBadge(0);
        const ub = document.getElementById('filterUnreadCount');
        if (ub) ub.textContent = '';
        renderNotifications();
    });
}
function setNotifFilter(filter) {
    _notifFilter = filter;
    const btnAll    = document.getElementById('filterAll');
    const btnUnread = document.getElementById('filterUnread');
    if (filter === 'all') {
        if (btnAll)    { btnAll.style.background = 'var(--accent-blue)'; btnAll.style.color = '#0f1117'; btnAll.style.border = 'none'; }
        if (btnUnread) { btnUnread.style.background = 'transparent'; btnUnread.style.color = 'var(--text-secondary)'; btnUnread.style.border = '1px solid var(--border-input)'; }
    } else {
        if (btnUnread) { btnUnread.style.background = 'var(--accent-blue)'; btnUnread.style.color = '#0f1117'; btnUnread.style.border = 'none'; }
        if (btnAll)    { btnAll.style.background = 'transparent'; btnAll.style.color = 'var(--text-secondary)'; btnAll.style.border = '1px solid var(--border-input)'; }
    }
    renderNotifications();
}

function updateNotifBadge(count) {
    const badge = document.getElementById('notifBadge');
    if (!badge) return;
    badge.textContent = count;
    badge.style.display = count > 0 ? 'flex' : 'none';
}

// Close on outside click
document.addEventListener('click', function(e) {
    const panel  = document.getElementById('notifPanel');
    const btn    = document.getElementById('notifBtn');
    if (panel && panel.style.display !== 'none') {
        if (!e.target.closest('#notifPanel') && !e.target.closest('#notifBtn')) {
            panel.style.display = 'none';
        }
    }
});
/* ══ MOBILE DRAWER ══ */
function toggleMobileDrawer() {
    var drawer  = document.getElementById('mobileDrawer');
    var overlay = document.getElementById('mobileDrawerOverlay');
    if (!drawer) return;
    var isOpen = drawer.classList.contains('open');
    drawer.classList.toggle('open', !isOpen);
    overlay.classList.toggle('open', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
}

function closeMobileDrawer() {
    var drawer  = document.getElementById('mobileDrawer');
    var overlay = document.getElementById('mobileDrawerOverlay');
    if (!drawer) return;
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
}
// ════════ AUTOMATIC FLASH ALERTS DISMISSAL (INSTANT AT 5 SECONDS) ════════
document.addEventListener('DOMContentLoaded', function() {
    const alerts = document.querySelectorAll('.alert, .sb-flash');
    alerts.forEach(function(alert) {
        setTimeout(function() {
            // Remove from DOM instantly without waiting for animations
            alert.remove();
        }, 3000);
    });
});
</script>
</body>
</html>
