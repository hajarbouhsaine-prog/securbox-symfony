{% extends 'base.html.twig' %}
{% block title %}Collections{% endblock %}
{% block body %}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:28px;">
    <h1 style="color:#e0e0e0; font-size:1.6rem; font-weight:600; margin:0;">
        <i class="fas fa-layer-group" style="color:#6fbfff;"></i> Collections
    </h1>
    <a href="{{ path('app_collection_new') }}"
       style="background:linear-gradient(135deg,#6fbfff,#4dd4ac); border:none; border-radius:8px;
              color:#0f1117; font-weight:700; font-size:0.88rem; padding:9px 20px; text-decoration:none;">
        <i class="fas fa-plus me-1"></i> Nouvelle collection
    </a>
</div>

{% if collections is empty %}
    <div style="text-align:center; padding:60px 0; color:#4b5563;">
        <i class="fas fa-layer-group fa-3x" style="opacity:0.2; margin-bottom:16px; display:block;"></i>
        <p>Aucune collection pour l'instant.</p>
        <a href="{{ path('app_collection_new') }}" style="color:#6fbfff;">Créer votre première collection</a>
    </div>
{% else %}
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:16px;">
        {% for col in collections %}
        <div style="background:#161b27; border:1px solid #252d3d; border-radius:12px; padding:20px; position:relative; transition:border-color 0.2s;"
             onmouseover="this.style.borderColor='#374151'" onmouseout="this.style.borderColor='#252d3d'">

            <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                <div style="width:38px; height:38px; background:#1e3a5f; border-radius:9px;
                            display:flex; align-items:center; justify-content:center; color:#6fbfff;">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div>
                    <div style="color:#e0e0e0; font-weight:600; font-size:0.98rem;">{{ col.name }}</div>
                    <div style="color:#4b5563; font-size:0.75rem;">{{ col.secrets|length }} secret(s)</div>
                </div>
            </div>

            {% if col.description %}
            <p style="color:#6b7280; font-size:0.82rem; margin:8px 0 12px; line-height:1.5;">
                {{ col.description }}
            </p>
            {% endif %}

            <div style="display:flex; gap:8px; margin-top:12px;">
                <a href="{{ path('app_vault_index', {collection: col.id}) }}"
                   style="flex:1; text-align:center; background:#1a2035; border:1px solid #252d3d;
                          border-radius:7px; color:#e0e0e0; font-size:0.82rem; padding:7px; text-decoration:none;">
                    <i class="fas fa-eye me-1"></i> Voir
                </a>
                <form method="post" action="{{ path('app_collection_delete', {id: col.id}) }}"
                      onsubmit="return confirm('Supprimer cette collection ? Les secrets ne seront pas supprimés.')" style="margin:0;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_collection' ~ col.id) }}">
                    <button type="submit"
                            style="background:#1a2035; border:1px solid #252d3d; border-radius:7px;
                                   color:#f87171; font-size:0.82rem; padding:7px 12px; cursor:pointer;">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}