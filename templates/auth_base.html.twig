<!DOCTYPE html>
<html lang="{{ app.request.locale }}"
      dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    {# Anti-flash theme script — identique à base.html.twig #}
    <script>
        (function() {
            var saved = localStorage.getItem('securboxTheme');
            var theme = 'dark';
            if (saved === 'light' || saved === 'dark') {
                theme = saved;
            } else if (saved === 'system' || !saved) {
                theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            }
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        /* ══ CSS VARIABLES DARK (défaut) ══ */
        :root, [data-theme="dark"] {
            --bg-body:        #0f1117;
            --bg-card:        #141b27;
            --bg-input:       #1e2535;
            --bg-hover:       #1e2535;
            --border-main:    #252d3d;
            --border-input:   #2a2f3e;
            --text-primary:   #e0e0e0;
            --text-secondary: #9ca3af;
            --text-muted:     #4b5563;
            --accent-blue:    #6fbfff;
            --accent-teal:    #4dd4ac;
            --accent-danger:  #f87171;
            --brand-gradient: linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);
        }

        /* ══ CSS VARIABLES LIGHT ══ */
        [data-theme="light"] {
            --bg-body:        #f0f4f8;
            --bg-card:        #ffffff;
            --bg-input:       #f1f5f9;
            --bg-hover:       #e8f0fe;
            --border-main:    #e2e8f0;
            --border-input:   #cbd5e1;
            --text-primary:   #1e293b;
            --text-secondary: #475569;
            --text-muted:     #94a3b8;
            --accent-blue:    #2563eb;
            --accent-teal:    #0d9488;
            --accent-danger:  #ef4444;
            --brand-gradient: linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);
        }

        /* ══ RESET & BASE ══ */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: var(--bg-body);
            color: var(--text-primary);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            transition: background-color 0.25s ease, color 0.25s ease;
        }

        /* ══ AUTH PAGE ══ */
        .auth-page {
            min-height: 100vh;
            background-color: var(--bg-body);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-input);
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 600px;
        }

        /* ══ BRAND MARK (hexagone) ══ */
        .brand-mark {
            width: 42px; height: 48px;
            display: grid; place-items: center;
            flex-shrink: 0;
            color: #dff3ff;
            font-size: 1.15rem;
            background: radial-gradient(circle at 50% 28%, rgba(116,255,221,0.25), transparent 34%),
                        var(--brand-gradient);
            clip-path: polygon(50% 0, 92% 18%, 82% 82%, 50% 100%, 18% 82%, 8% 18%);
            box-shadow: 0 12px 30px rgba(48,107,255,0.28), inset 0 0 0 2px rgba(255,255,255,0.18);
        }

        /* ══ FORMS ══ */
        .form-control, .form-select {
            background-color: var(--bg-input);
            border: 1px solid var(--border-input);
            color: var(--text-primary);
            border-radius: 8px;
        }
        .form-control:focus, .form-select:focus {
            background-color: var(--bg-input);
            border-color: var(--accent-blue);
            color: var(--text-primary);
            box-shadow: 0 0 0 3px rgba(111,191,255,0.15);
        }
        .form-control::placeholder { color: var(--text-muted); }
        .form-label { color: var(--text-secondary); font-size: 0.9rem; }

        /* ══ BUTTONS ══ */
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            border: none; color: #0f1117; font-weight: 600;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, var(--accent-teal), var(--accent-blue));
            color: #0f1117;
        }

        /* ══ ALERTS ══ */
        .alert-success { background-color: #1a3a2a; border-color: var(--accent-teal); color: var(--accent-teal); }
        .alert-danger  { background-color: #3a1a1a; border-color: var(--accent-danger); color: var(--accent-danger); }
        .alert-info    { background-color: var(--bg-input); border-color: var(--accent-blue); color: var(--accent-blue); }

        /* ══ BRAND COLORS (paramètrées via AppSettings) ══ */
        :root {
            --brand-primary: {{ app_primary }};
            --brand-accent:  {{ app_accent }};
        }
    </style>
</head>
<body>
    {% block body %}{% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /* Applique le thème sauvegardé au chargement */
        (function() {
            var saved = localStorage.getItem('securboxTheme') || 'dark';
            var resolved = saved;
            if (saved === 'system' || (saved !== 'light' && saved !== 'dark')) {
                resolved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            }
            document.documentElement.setAttribute('data-theme', resolved);
        })();
    </script>
</body>
</html>
