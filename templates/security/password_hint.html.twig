{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}
{% block body %}
<div class="auth-page">
    <div class="auth-card">

        {# ── Brand lockup — même structure que le sidebar vault, centré ── #}
        <div style="display: flex; justify-content: center;
                    padding-bottom: 24px; border-bottom: 1px solid var(--border-input); margin-bottom: 24px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                {% if app_logo_url %}
                    <img src="{{ app_logo_url }}" alt="{{ app_name }}"
                         style="width:38px; height:38px; object-fit:contain; border-radius:6px; flex-shrink:0;">
                {% else %}
                    <div class="brand-mark" aria-hidden="true" style="flex-shrink:0;">
                        <i class="fas fa-lock"></i>
                    </div>
                {% endif %}
                <div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: {{ app_primary }};
                                line-height: 1.1; letter-spacing: -0.01em;">
                        {{ app_name }}
                    </div>
                    <div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 2px;">
                        {{ app_slogan }}
                    </div>
                </div>
            </div>
        </div>

        {% if success %}
            <div class="alert alert-success mb-3">
                <i class="fas fa-check-circle me-2"></i>
                Un email contenant votre indice a été envoyé à votre adresse.
            </div>
        {% endif %}

        {% if error %}
            <div class="alert alert-danger mb-3">
                <i class="fas fa-exclamation-circle me-2"></i>
                {{ error }}
            </div>
        {% endif %}

        {% if not success %}
            <div style="margin-bottom: 20px;">
                <h2 style="color: var(--text-primary); font-size: 1.4rem; font-weight: 700; margin: 0 0 8px 0;">
                    <i class="fas fa-key me-2" style="color:{{ app_primary }};"></i>Mot de passe oublié ?
                </h2>
                <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
                    Entrez votre adresse email pour recevoir votre indice de mot de passe maître.
                </p>
            </div>
            <form method="post">
                <div class="mb-4">
                    <label class="form-label">Adresse email</label>
                    <input type="email" name="email" class="form-control"
                           required placeholder="votre@email.com">
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="fas fa-paper-plane me-2"></i>Recevoir mon indice
                </button>
            </form>
        {% endif %}

        <hr style="border-color:#2a2f3e; margin: 24px 0;">
        <div class="text-center">
            <a href="{{ path('app_login') }}" style="color:{{ app_primary }}; text-decoration:none;">
                <i class="fas fa-arrow-left me-1"></i>Retour à la connexion
            </a>
        </div>
    </div>
</div>
{% endblock %}
