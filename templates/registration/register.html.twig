{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}
{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-logo">🔐 Coffre<span>-Fort</span></div>
            <p style="color:#4b5563; font-size:0.9rem; margin-top:8px;">Créez votre coffre-fort sécurisé</p>
        </div>
        {{ form_errors(registrationForm) }}
        {{ form_start(registrationForm) }}
            <div class="mb-3">
                <label class="form-label">Adresse email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.com'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>
            <div class="mb-3">
                <label class="form-label">Mot de passe maître</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 8 caractères'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
                <small style="color:#4b5563;">Ce mot de passe servira à chiffrer vos secrets</small>
            </div>
            <div class="mb-4" style="display:flex; align-items:center; gap:10px;">
                {{ form_widget(registrationForm.agreeTerms) }}
                <label style="color:#9ca3af; font-size:0.9rem;">J'accepte les conditions d'utilisation</label>
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fas fa-user-plus me-2"></i>Créer mon compte
            </button>
        {{ form_end(registrationForm) }}
        <hr style="border-color:#2a2f3e; margin: 24px 0;">
        <div class="text-center">
            <a href="{{ path('app_login') }}" style="color:#6fbfff; text-decoration:none;">
                Déjà un compte ? Se connecter
            </a>
        </div>
    </div>
</div>
{% endblock %}