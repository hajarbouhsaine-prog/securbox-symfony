{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}
{% block body %}
<div class="auth-page">
    <div class="auth-card">

        {# ── Brand lockup — même structure que le sidebar vault, centré ── #}
        <div style="display: flex; justify-content: center;
                    padding-bottom: 24px; border-bottom: 1px solid var(--border-input); margin-bottom: 24px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                {% if app_logo_url %}
                    <img src="{{ app_logo_url }}" alt="{{ app_name }}"
                         style="width:38px; height:38px; object-fit:contain; border-radius:6px; flex-shrink:0;">
                {% else %}
                    <div class="brand-mark" aria-hidden="true" style="flex-shrink:0;">
                        <i class="fas fa-lock"></i>
                    </div>
                {% endif %}
                <div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: {{ app_primary }};
                                line-height: 1.1; letter-spacing: -0.01em;">
                        {{ app_name }}
                    </div>
                    <div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 2px;">
                        {{ app_slogan }}
                    </div>
                </div>
            </div>
        </div>

        {{ form_errors(registrationForm) }}
        {{ form_start(registrationForm) }}

            <div class="mb-3">
                <label class="form-label">Adresse email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.com'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="mb-3">
                <label class="form-label">Mot de passe maître</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 8 caractères'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
                <small style="color:#4b5563;">Ce mot de passe servira à chiffrer vos secrets</small>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-shield-alt me-1" style="color:{{ app_primary }};"></i>
                    Question de sécurité
                </label>
                {{ form_widget(registrationForm.securityQuestion, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.securityQuestion) }}
                <small style="color:#4b5563;">Utilisée si vous oubliez votre mot de passe maître</small>
            </div>

            <div class="mb-4">
                <label class="form-label">Réponse à la question de sécurité</label>
                {{ form_widget(registrationForm.securityAnswer, {'attr': {'class': 'form-control', 'placeholder': 'Votre réponse'}}) }}
                {{ form_errors(registrationForm.securityAnswer) }}
                <small style="color:#4b5563;">Mémorisez bien cette réponse</small>
                <div style="margin-top: 10px; padding: 14px 16px; background: #1e293b; border-left: 3px solid #f59e0b; border-radius: 6px;">
                    <p style="margin: 0; color: #fbbf24; font-size: 0.82rem; line-height: 1.6;">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        <strong>NB :</strong> Votre réponse sera envoyée par email comme indice pour retrouver votre mot de passe maître.
                        Choisissez une réponse qui vous rappelle de votre mot de passe.
                        La réponse vous aidera à vous en souvenir.
                        Évitez d'écrire votre mot de passe directement en clair.
                    </p>
                </div>
            </div>

            <div class="mb-4" style="display:flex; align-items:center; gap:10px;">
                {{ form_widget(registrationForm.agreeTerms) }}
                <label style="color:#9ca3af; font-size:0.9rem;">J'accepte les conditions d'utilisation</label>
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fas fa-user-plus me-2"></i>Créer mon compte
            </button>

        {{ form_end(registrationForm) }}

        <hr style="border-color:#2a2f3e; margin: 24px 0;">
        <div class="text-center">
            <a href="{{ path('app_login') }}" style="color:{{ app_primary }}; text-decoration:none;">
                Déjà un compte ? Se connecter
            </a>
        </div>
    </div>
</div>
{% endblock %}
