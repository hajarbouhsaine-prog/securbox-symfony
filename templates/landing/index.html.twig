<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Navbar: shrink + solidify on scroll ── */
    function initNavScroll() {
        var nav = document.querySelector('.landing-nav');
        if (!nav) return;
        function onScroll() {
            nav.classList.toggle('is-scrolled', window.scrollY > 10);
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }

    /* ── Hero title: cascading "decrypt" reveal ── */
    function initDecryptTitle() {
        var el = document.getElementById('heroTitle');
        if (!el) return;
        var finalText = el.textContent;
        if (reduceMotion) return;

        var glyphs = '01#%&$ABCDEF*+/\\<>';
        var letters = finalText.split('');
        el.textContent = '';
        var items = letters.map(function (ch) {
            var span = document.createElement('span');
            span.style.display = 'inline-block';
            span.textContent = ch === ' ' ? '\u00A0' : ch;
            el.appendChild(span);
            return { span: span, ch: ch };
        });

        items.forEach(function (item, idx) {
            if (item.ch === ' ') return;
            var frame = 0;
            var totalFrames = 9 + Math.floor(Math.random() * 6);
            var delay = idx * 26;
            setTimeout(function () {
                var interval = setInterval(function () {
                    frame++;
                    if (frame >= totalFrames) {
                        item.span.textContent = item.ch;
                        clearInterval(interval);
                    } else {
                        item.span.textContent = glyphs[Math.floor(Math.random() * glyphs.length)];
                    }
                }, 34);
            }, delay);
        });
    }

    /* ── Hero background: drifting encrypted-data particle network ── */
    function initVaultCanvas() {
        var canvas = document.getElementById('vaultCanvas');
        if (!canvas || reduceMotion) return;
        var ctx = canvas.getContext('2d');
        var particles = [];
        var w, h, dpr;

        function resize() {
            var rect = canvas.parentElement.getBoundingClientRect();
            dpr = Math.min(window.devicePixelRatio || 1, 2);
            w = rect.width;
            h = rect.height;
            canvas.width = w * dpr;
            canvas.height = h * dpr;
            canvas.style.width = w + 'px';
            canvas.style.height = h + 'px';
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            initParticles();
        }

        function initParticles() {
            var count = w < 640 ? 16 : (w < 1100 ? 26 : 40);
            particles = [];
            for (var i = 0; i < count; i++) {
                particles.push({
                    x: Math.random() * w,
                    y: Math.random() * h,
                    vx: (Math.random() - 0.5) * 0.25,
                    vy: (Math.random() - 0.5) * 0.25,
                    r: Math.random() * 1.6 + 0.6
                });
            }
        }

        function step() {
            ctx.clearRect(0, 0, w, h);
            var maxDist = Math.min(w, h) * 0.18;
            var i, j, a, b, dx, dy, dist;

            for (i = 0; i < particles.length; i++) {
                a = particles[i];
                a.x += a.vx;
                a.y += a.vy;
                if (a.x < 0 || a.x > w) a.vx *= -1;
                if (a.y < 0 || a.y > h) a.vy *= -1;
            }
            for (i = 0; i < particles.length; i++) {
                for (j = i + 1; j < particles.length; j++) {
                    a = particles[i];
                    b = particles[j];
                    dx = a.x - b.x;
                    dy = a.y - b.y;
                    dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < maxDist) {
                        ctx.strokeStyle = 'rgba(111,191,255,' + ((1 - dist / maxDist) * 0.18) + ')';
                        ctx.lineWidth = 1;
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y);
                        ctx.lineTo(b.x, b.y);
                        ctx.stroke();
                    }
                }
            }
            for (i = 0; i < particles.length; i++) {
                a = particles[i];
                ctx.beginPath();
                ctx.fillStyle = 'rgba(77,212,172,0.55)';
                ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
                ctx.fill();
            }
            requestAnimationFrame(step);
        }

        window.addEventListener('resize', resize);
        resize();
        requestAnimationFrame(step);
    }

    /* ── Scroll reveal for cards, stats and the final CTA ── */
    function initRevealOnScroll() {
        var items = document.querySelectorAll('.reveal-up');
        if (!items.length) return;

        if (reduceMotion || typeof IntersectionObserver === 'undefined') {
            items.forEach(function (el) { el.classList.add('is-visible'); });
            return;
        }

        items.forEach(function (el, i) {
            var delay = (i % 4) * 0.12 + 's';
            el.style.transitionDelay = delay;
            el.style.animationDelay = delay;
        });

        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        items.forEach(function (el) { observer.observe(el); });
    }

    /* ── Stat numbers count up when scrolled into view ── */
    function initStatCounters() {
        var counters = document.querySelectorAll('.stat-number[data-target]');
        if (!counters.length) return;

        function animateCounter(el) {
            var target = parseInt(el.getAttribute('data-target'), 10) || 0;
            var suffix = el.getAttribute('data-suffix') || '';
            if (reduceMotion || target === 0) {
                el.textContent = target + suffix;
                return;
            }
            var duration = 1400;
            var start = null;
            function tick(now) {
                if (start === null) start = now;
                var progress = Math.min((now - start) / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(eased * target) + suffix;
                if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        }

        if (typeof IntersectionObserver === 'undefined') {
            counters.forEach(animateCounter);
            return;
        }

        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    animateCounter(entry.target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.4 });

        counters.forEach(function (el) { observer.observe(el); });
    }

    /* ── Final CTA: the vault clicks shut once it comes into view ── */
    function initFinalLock() {
        var lock = document.getElementById('finalLock');
        var section = document.querySelector('.final-cta-section');
        if (!lock || !section) return;

        if (reduceMotion || typeof IntersectionObserver === 'undefined') {
            lock.classList.add('is-locked');
            return;
        }

        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    setTimeout(function () { lock.classList.add('is-locked'); }, 250);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        observer.observe(section);
    }

    initNavScroll();
    initDecryptTitle();
    initVaultCanvas();
    initRevealOnScroll();
    initStatCounters();
    initFinalLock();
});
</script>
</body>
