<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ app_name }} — Gestionnaire de secrets sécurisé</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #0f1117;
            color: #e0e0e0;
            overflow-x: hidden;
        }

        /* ── NAVBAR ── */
        .landing-nav {
            position: fixed; top: 0; left: 0; right: 0;
            z-index: 999;
            background: rgba(15, 17, 23, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #2a2f3e;
            padding: 14px 0;
            animation: fadeInDown 0.7s ease both;
            transition: padding 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
        }
        .landing-nav.is-scrolled {
            padding: 8px 0;
            background: rgba(15, 17, 23, 0.96);
            box-shadow: 0 10px 30px rgba(0,0,0,0.35);
        }
        .landing-nav .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .nav-logo {
            font-size: 1.4rem;
            font-weight: 700;
            color: #6fbfff;
            text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .nav-links { display: flex; align-items: center; gap: 32px; }
        .nav-links a {
            color: #9ca3af; text-decoration: none;
            font-size: 0.9rem; transition: color 0.2s;
        }
        .nav-links a:hover { color: #e0e0e0; }

        /* ── BRAND / LOGO (navbar + footer share this) ── */
        .brand-link { text-decoration: none; display: flex; align-items: center; gap: 12px; }
        .logo-orb { position: relative; width: 42px; height: 48px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
        .logo-orb::before {
            content: "";
            position: absolute; inset: -9px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(111,191,255,0.4), transparent 72%);
            animation: pulseGlow 3.2s ease-in-out infinite;
            will-change: transform, opacity;
        }
        .logo-orb.is-small { width: 34px; height: 38px; }
        .logo-orb.is-small::before { inset: -7px; }
        .logo-img, .logo-shield { position: relative; z-index: 1; width: 42px; height: 48px; flex-shrink: 0; }
        .logo-img { object-fit: contain; }
        .logo-shield {
            display: grid; place-items: center;
            color: #dff3ff; font-size: 1.15rem;
            background: radial-gradient(circle at 50% 28%, rgba(116,255,221,0.25), transparent 34%),
                        linear-gradient(150deg, #306bff, #7d3cff 58%, #15d1ba);
            clip-path: polygon(50% 0, 92% 18%, 82% 82%, 50% 100%, 18% 82%, 8% 18%);
            box-shadow: 0 12px 30px rgba(48,107,255,0.28), inset 0 0 0 2px rgba(255,255,255,0.18);
        }
        .logo-img.is-small, .logo-shield.is-small { width: 34px; height: 38px; font-size: 0.95rem; box-shadow: 0 8px 20px rgba(48,107,255,0.28); }
        .brand-name { font-size: 1.3rem; font-weight: 700; color: var(--brand-primary, #6fbfff); line-height: 1; }
        .brand-slogan { color: #6b7280; font-size: 0.75rem; margin-top: 2px; }
        .brand-name.is-small { font-size: 1.1rem; }
        .brand-slogan.is-small { font-size: 0.72rem; }
        .nav-cta {
            display: flex; gap: 12px; align-items: center;
        }
        .btn-nav-login {
            color: #9ca3af; text-decoration: none;
            font-size: 0.9rem; padding: 8px 16px;
            border-radius: 8px; transition: all 0.2s;
        }
        .btn-nav-login:hover { color: #e0e0e0; background: #1e2535; }
        .btn-nav-register {
            background: linear-gradient(135deg, #6fbfff, #4dd4ac);
            color: #0f1117; font-weight: 600;
            text-decoration: none; padding: 8px 20px;
            border-radius: 8px; font-size: 0.9rem;
            transition: opacity 0.2s;
            position: relative; overflow: hidden;
        }
        .btn-nav-register::before {
            content: "";
            position: absolute; top: 0; left: -60%;
            width: 45%; height: 100%;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.5), transparent);
            transform: skewX(-20deg);
            transition: left 0.55s ease;
        }
        .btn-nav-register:hover::before { left: 130%; }
        .btn-nav-register:hover { opacity: 0.88; color: #0f1117; }

        /* ── HERO ── */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 140px 0 80px;
            position: relative;
            overflow: hidden;
            text-align: center;
        }
        .hero-bg {
            position: absolute; inset: 0; z-index: 0;
            overflow: hidden;
            background: radial-gradient(ellipse 60% 60% at 50% 30%, rgba(111,191,255,0.15) 0%, transparent 70%),
                        radial-gradient(ellipse 50% 50% at 50% 70%, rgba(77,212,172,0.08) 0%, transparent 60%);
        }

        /* ── VAULT DECORATION (signature hero element) ── */
        .vault-dial {
            position: absolute; top: 50%; left: 50%;
            width: 760px; height: 760px; margin: -380px;
            border-radius: 50%;
            background: repeating-conic-gradient(rgba(111,191,255,0.14) 0deg 1.6deg, transparent 1.6deg 10deg);
            -webkit-mask: radial-gradient(circle, transparent 56%, #000 58%, #000 63%, transparent 65%);
                    mask: radial-gradient(circle, transparent 56%, #000 58%, #000 63%, transparent 65%);
            animation: rotateSlow 110s linear infinite;
            will-change: transform;
        }
        .vault-dial--inner {
            width: 540px; height: 540px; margin: -270px;
            background: repeating-conic-gradient(rgba(77,212,172,0.18) 0deg 2deg, transparent 2deg 14deg);
            -webkit-mask: radial-gradient(circle, transparent 48%, #000 51%, #000 58%, transparent 61%);
                    mask: radial-gradient(circle, transparent 48%, #000 51%, #000 58%, transparent 61%);
            animation: rotateSlow 75s linear infinite reverse;
        }
        .vault-core {
            position: absolute; top: 50%; left: 50%;
            width: 170px; height: 170px; margin: -85px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(111,191,255,0.42), rgba(77,212,172,0.18) 55%, transparent 76%);
            filter: blur(1px);
            animation: pulseGlow 4.5s ease-in-out infinite;
        }
        .vault-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
        .ambient-icons { position: absolute; inset: 0; overflow: hidden; }
        .ambient-icon {
            position: absolute; bottom: -60px;
            color: rgba(111,191,255,0.18);
            font-size: 1.3rem;
            animation: floatUp 16s linear infinite;
        }
        .ambient-icon.i1 { left: 8%;  font-size: 1rem;   color: rgba(77,212,172,0.18);  animation-delay: 0s; }
        .ambient-icon.i2 { left: 22%; font-size: 1.5rem;                                 animation-delay: 3.2s; }
        .ambient-icon.i3 { left: 40%; font-size: 0.95rem; color: rgba(192,132,252,0.16); animation-delay: 6.4s; }
        .ambient-icon.i4 { left: 60%; font-size: 1.25rem;                                animation-delay: 2.1s; }
        .ambient-icon.i5 { left: 76%; font-size: 1rem;   color: rgba(77,212,172,0.16);  animation-delay: 9s; }
        .ambient-icon.i6 { left: 90%; font-size: 1.4rem;                                 animation-delay: 5s; }

        .hero .container { position: relative; z-index: 1; max-width: 900px; }

        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(111,191,255,0.1); border: 1px solid rgba(111,191,255,0.3);
            color: #6fbfff; font-size: 0.82rem; font-weight: 600;
            padding: 6px 14px; border-radius: 20px; margin-bottom: 24px;
            letter-spacing: 0.03em;
            animation: scaleIn 0.6s ease 0.1s both, badgePulse 2.8s ease-in-out 0.9s infinite;
        }

        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4.2rem);
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 24px;
            background: linear-gradient(135deg, #e0e0e0, #6fbfff, #4dd4ac, #e0e0e0);
            background-size: 300% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 9s ease-in-out infinite;
        }

        .hero p {
            font-size: 1.2rem;
            color: #9ca3af;
            max-width: 650px;
            margin: 0 auto 40px auto;
            line-height: 1.7;
            animation: fadeInUp 0.8s ease 0.25s both;
        }
        .hero-actions {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
            animation: fadeInUp 0.8s ease 0.4s both;
        }
        .btn-hero-primary {
            background: linear-gradient(135deg, #6fbfff, #4dd4ac);
            color: #0f1117; font-weight: 700;
            text-decoration: none; padding: 16px 36px;
            border-radius: 10px; font-size: 1.05rem;
            display: inline-flex; align-items: center; gap: 8px;
            transition: opacity 0.2s, transform 0.2s;
            box-shadow: 0 8px 30px rgba(111,191,255,0.25);
            position: relative; overflow: hidden;
        }
        .btn-hero-primary::before {
            content: "";
            position: absolute; top: 0; left: -60%;
            width: 45%; height: 100%;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.55), transparent);
            transform: skewX(-20deg);
            transition: left 0.65s ease;
        }
        .btn-hero-primary:hover::before { left: 130%; }
        .btn-hero-primary:hover { opacity: 0.9; transform: translateY(-2px); color: #0f1117; }
        .btn-hero-secondary {
            background: transparent;
            color: #9ca3af; font-weight: 600;
            text-decoration: none; padding: 16px 32px;
            border-radius: 10px; font-size: 1.05rem;
            border: 1px solid #2a2f3e;
            display: inline-flex; align-items: center; gap: 8px;
            transition: all 0.2s;
        }
        .btn-hero-secondary:hover { background: #1e2535; color: #e0e0e0; border-color: #6fbfff; transform: translateY(-2px); }

        /* ── STATS ── */
        .stats-section {
            padding: 60px 0;
            border-top: 1px solid #1c2233;
            border-bottom: 1px solid #1c2233;
        }
        /* ── SCROLL REVEAL ── */
        .reveal-up {
            opacity: 0;
            transform: translateY(28px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal-up.is-visible { opacity: 1; transform: translateY(0); }

        .stat-item { text-align: center; }
        .stat-number {
            font-size: 2.5rem; font-weight: 800;
            background: linear-gradient(135deg, #6fbfff, #4dd4ac);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .stat-label { color: #6b7280; font-size: 0.88rem; margin-top: 4px; }

        /* ── FEATURES ── */
        .features-section { padding: 100px 0; }
        .section-tag {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(77,212,172,0.1); border: 1px solid rgba(77,212,172,0.3);
            color: #4dd4ac; font-size: 0.78rem; font-weight: 600;
            padding: 5px 12px; border-radius: 20px; margin-bottom: 16px;
            letter-spacing: 0.05em; text-transform: uppercase;
        }
        .section-title {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 700; color: #e0e0e0;
            margin-bottom: 16px; line-height: 1.2;
        }
        .section-sub { color: #6b7280; font-size: 1rem; line-height: 1.7; max-width: 500px; }

        .feature-card {
            background: #161b27;
            border: 1px solid #2a2f3e;
            border-radius: 12px; padding: 28px;
            height: 100%;
            transition: all 0.25s;
        }
        .feature-card:hover {
            border-color: #6fbfff;
            background: #1a2035;
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(111,191,255,0.1);
        }
        .feature-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; margin-bottom: 18px;
        }
        .feature-title { font-size: 1rem; font-weight: 600; color: #e0e0e0; margin-bottom: 10px; }
        .feature-desc { color: #6b7280; font-size: 0.88rem; line-height: 1.65; }

        /* ── COMMENT CA MARCHE ── */
        .how-section {
            padding: 100px 0; background: #0a0d13;
            background-image:
                linear-gradient(rgba(111,191,255,0.045) 1px, transparent 1px),
                linear-gradient(90deg, rgba(111,191,255,0.045) 1px, transparent 1px);
            background-size: 42px 42px;
        }
        .step-number {
            width: 40px; height: 40px; border-radius: 50%;
            background: linear-gradient(135deg, #6fbfff, #4dd4ac);
            color: #0f1117; font-weight: 800; font-size: 1rem;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 16px; flex-shrink: 0;
        }
        .reveal-up.is-visible .step-number { animation: stepPulse 0.7s ease; }
        .step-card {
            background: #161b27; border: 1px solid #2a2f3e;
            border-radius: 12px; padding: 28px; height: 100%;
        }
        .step-title { font-size: 1rem; font-weight: 600; color: #e0e0e0; margin-bottom: 8px; }
        .step-desc { color: #6b7280; font-size: 0.88rem; line-height: 1.65; }

        /* ── FINAL CTA ── */
        .final-cta-section {
            background: #0f1117;
            padding: 160px 0 180px 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .final-cta-section::before {
            content: "";
            position: absolute; inset: 0;
            background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(77,212,172,0.08), transparent 70%);
            pointer-events: none;
        }
        .final-cta-section .container { position: relative; z-index: 1; }
        .final-cta-section h2 {
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 20px;
        }
        .final-cta-section p {
            color: #9ca3af;
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 40px auto;
        }
        .vault-lock-final {
            display: block;
            margin: 0 auto 28px;
            filter: drop-shadow(0 10px 25px rgba(111,191,255,0.25));
        }
        .vault-lock-final .shackle {
            transform: rotate(-48deg);
            transform-origin: 38px 62px;
            transition: transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .vault-lock-final.is-locked .shackle { transform: rotate(0deg); }
        .vault-lock-final.is-locked { animation: lockFlash 0.8s ease 0.5s; }

        /* ── FOOTER ── */
        .landing-footer {
            padding: 40px 0;
            border-top: 1px solid #1c2233;
            background: #0f1117;
        }
        .footer-logo { color: #6fbfff; font-weight: 700; font-size: 1.1rem; }
        .footer-links a {
            color: #4b5563; text-decoration: none;
            font-size: 0.82rem; margin-left: 20px;
            transition: color 0.2s;
        }
        .footer-links a:hover { color: #9ca3af; }

        /* ── KEYFRAMES ── */
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-16px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInUp   { from { opacity: 0; transform: translateY(20px); }  to { opacity: 1; transform: translateY(0); } }
        @keyframes scaleIn    { from { opacity: 0; transform: scale(0.85); }       to { opacity: 1; transform: scale(1); } }
        @keyframes pulseGlow  { 0%, 100% { transform: scale(1); opacity: 0.7; } 50% { transform: scale(1.12); opacity: 1; } }
        @keyframes rotateSlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes gradientShift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
        @keyframes badgePulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(111,191,255,0); }
            50%      { box-shadow: 0 0 16px 3px rgba(111,191,255,0.35); }
        }
        @keyframes stepPulse {
            0%   { box-shadow: 0 0 0 0 rgba(111,191,255,0.55); }
            60%  { box-shadow: 0 0 0 14px rgba(111,191,255,0); }
            100% { box-shadow: 0 0 0 0 rgba(111,191,255,0); }
        }
        @keyframes lockFlash {
            0%, 100% { filter: drop-shadow(0 10px 25px rgba(111,191,255,0.25)); }
            50%      { filter: drop-shadow(0 0 35px rgba(77,212,172,0.85)); }
        }
        @keyframes floatUp {
            0%   { transform: translateY(0) rotate(0deg); opacity: 0; }
            10%  { opacity: 1; }
            90%  { opacity: 1; }
            100% { transform: translateY(-780px) rotate(20deg); opacity: 0; }
        }

        /* ── ACCESSIBILITY: respect reduced motion ── */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }
    </style>
</head>
<body>

{# ══════════════════════════════════════════════════════
   NAVBAR
   ══════════════════════════════════════════════════════ #}
<nav class="landing-nav">
    <div class="container">
        <a href="{{ path('app_landing') }}" class="brand-link">

            {# ── Logo dynamique (navbar) ── #}
            <div class="logo-orb">
                {% if app_logo is defined and app_logo is not empty %}
                    <img src="{{ asset('uploads/logos/' ~ app_logo) }}"
                         alt="{{ app_name }}"
                         class="logo-img">
                {% else %}
                    <div class="logo-shield">
                        <i class="fas fa-lock"></i>
                    </div>
                {% endif %}
            </div>

            <div>
                <div class="brand-name">{{ app_name }}</div>
                <div class="brand-slogan">{{ app_slogan }}</div>
            </div>
        </a>

        <div class="nav-links d-none d-md-flex">
            <a href="#features">Fonctionnalités</a>
            <a href="#how">Comment ça marche</a>
        </div>
        <div class="nav-cta">
            <a href="{{ path('app_login') }}" class="btn-nav-login">Connexion</a>
            <a href="{{ path('app_register') }}" class="btn-nav-register">
                <i class="fas fa-rocket me-1"></i> Commencer
            </a>
        </div>
    </div>
</nav>

{# ══════════════════════════════════════════════════════
   HERO
   ══════════════════════════════════════════════════════ #}
<section class="hero">
    <div class="hero-bg" aria-hidden="true">
        <div class="vault-dial"></div>
        <div class="vault-dial vault-dial--inner"></div>
        <div class="vault-core"></div>
        <canvas id="vaultCanvas" class="vault-canvas"></canvas>
        <div class="ambient-icons">
            <i class="fas fa-key ambient-icon i1"></i>
            <i class="fas fa-lock ambient-icon i2"></i>
            <i class="fas fa-fingerprint ambient-icon i3"></i>
            <i class="fas fa-shield-halved ambient-icon i4"></i>
            <i class="fas fa-key ambient-icon i5"></i>
            <i class="fas fa-lock ambient-icon i6"></i>
        </div>
    </div>
    <div class="container">
        <div class="hero-badge">
            <i class="fas fa-shield-alt"></i> Architecture Zero-Knowledge
        </div>
        <h1 id="heroTitle">Un seul endroit pour tout ce que vous ne pouvez pas
        perdre</h1>
        <p>Vos accès, vos mots de passe et vos données privées — stockés en sécurité absolue et accessibles partout à la demande.</p>
        <div class="hero-actions">
            <a href="{{ path('app_register') }}" class="btn-hero-primary">
                <i class="fas fa-lock"></i> Créer mon coffre-fort
            </a>
            <a href="{{ path('app_login') }}" class="btn-hero-secondary">
                <i class="fas fa-sign-in-alt"></i> Se connecter
            </a>
        </div>
    </div>
</section>

{# ══════════════════════════════════════════════════════
   STATS
   ══════════════════════════════════════════════════════ #}
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item reveal-up">
                    <div class="stat-number" data-target="256">0</div>
                    <div class="stat-label">Chiffrement de pointe</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item reveal-up">
                    <div class="stat-number" data-target="4">0</div>
                    <div class="stat-label">Types de secrets gérés</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item reveal-up">
                    <div class="stat-number" data-target="0">0</div>
                    <div class="stat-label">Connaissance de vos données</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item reveal-up">
                    <div class="stat-number" data-target="100" data-suffix="%">0</div>
                    <div class="stat-label">Transparent & Sécurisé</div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ══════════════════════════════════════════════════════
   FEATURES
   ══════════════════════════════════════════════════════ #}
<section class="features-section" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-tag"><i class="fas fa-star"></i> Fonctionnalités</div>
            <h2 class="section-title">Une infrastructure robuste pour vos données</h2>
            <p class="section-sub mx-auto">Une suite complète d'outils pour protéger votre vie numérique.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card reveal-up">
                    <div class="feature-icon" style="background:#1e3a5f; color:#6fbfff;">
                        <i class="fas fa-lock"></i>
                    </div>
                    <div class="feature-title">Chiffrement Zero-Knowledge</div>
                    <div class="feature-desc">Vos données sont verrouillées localement avant d'être envoyées. Personne d'autre que vous, pas même nous, ne peut les lire.</div>
                </div>
            </div>
