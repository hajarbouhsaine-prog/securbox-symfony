{% extends 'base.html.twig' %}
{% block title %}Journaux d'accès{% endblock %}
{% block body %}

<div class="adm-wrap">

    {# ── En-tête ── #}
    <div class="adm-hero">
        <div style="display:flex; align-items:center; gap:14px;">
            <a href="{{ path('app_admin_index') }}" class="adm-back-btn">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="adm-hero__title">
                    <i class="fas fa-history"></i> Journaux d'accès
                </h1>
                <p class="adm-hero__sub">{{ logs|length }} entrée(s) — actions les plus récentes en premier</p>
            </div>
        </div>
    </div>

    {# ── Tableau des logs ── #}
    <div class="adm-card">
        <div class="adm-card__head">
            <div class="adm-card__title">
                <i class="fas fa-list"></i> Historique complet
            </div>
            <span class="adm-pill">{{ logs|length }} entrée(s)</span>
        </div>

        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Action</th>
                        <th>Détails</th>
                        <th>IP</th>
                        <th>Navigateur</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr>
                        <td>
                            <div class="adm-user-cell">
                                <div class="adm-avatar adm-avatar--sm">{{ log.user.email|first|upper }}</div>
                                <span class="adm-user-email" style="font-size:0.83rem;">{{ log.user.email }}</span>
                            </div>
                        </td>
                        <td>
                            <span class="adm-action-badge adm-action--{{ log.action|lower|replace({'_':'-'}) }}">
                                {{ log.action }}
                            </span>
                        </td>
                        <td class="adm-date" style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            {{ log.details ?? (log.secret ? log.secret.name : '—') }}
                        </td>
                        <td class="adm-mono">{{ log.ipAddress }}</td>
                        <td class="adm-date" style="max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:0.75rem;">
                            {{ log.userAgent ? log.userAgent|slice(0, 45) ~ '…' : '—' }}
                        </td>
                        <td class="adm-date" style="white-space:nowrap;">
                            {{ log.createdAt|date('d/m/Y H:i:s') }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center; padding:32px; color:var(--text-muted); font-size:0.88rem;">
                            <i class="fas fa-history" style="font-size:1.5rem; display:block; margin-bottom:8px; opacity:0.3;"></i>
                            Aucun journal enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

<style>
.adm-wrap { max-width: 1200px; margin: 0 auto; padding: 0 0 40px; }
.adm-hero { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
.adm-hero__title { font-size: 1.45rem; font-weight: 700; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 10px; }
.adm-hero__title i { color: var(--accent-blue); }
.adm-hero__sub { color: var(--text-muted); font-size: 0.85rem; margin: 3px 0 0; }
.adm-back-btn {
    width: 36px; height: 36px; border-radius: 9px; background: var(--bg-input);
    border: 1px solid var(--border-input); color: var(--text-secondary);
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; transition: all 0.15s; flex-shrink: 0;
}
.adm-back-btn:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
.adm-card { background: var(--bg-card); border: 1px solid var(--border-input); border-radius: 12px; overflow: hidden; }
.adm-card__head { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border-input); }
.adm-card__title { color: var(--text-primary); font-weight: 600; font-size: 0.92rem; display: flex; align-items: center; gap: 8px; }
.adm-card__title i { color: var(--accent-blue); }
.adm-pill { background: var(--bg-input); color: var(--text-muted); font-size: 0.75rem; padding: 3px 10px; border-radius: 20px; }
.adm-table-wrap { overflow-x: auto; }
.adm-table { width: 100%; border-collapse: collapse; }
.adm-table thead tr { border-bottom: 1px solid var(--border-input); }
.adm-table th { padding: 10px 16px; color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 700; text-align: left; }
.adm-table tbody tr { border-bottom: 1px solid var(--border-subtle); transition: background 0.12s; }
.adm-table tbody tr:last-child { border-bottom: none; }
.adm-table tbody tr:hover { background: var(--bg-hover); }
.adm-table td { padding: 11px 16px; vertical-align: middle; }
.adm-user-cell { display: flex; align-items: center; gap: 8px; }
.adm-avatar { width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.78rem; }
.adm-avatar--sm { background: var(--bg-input); color: var(--accent-blue); }
.adm-user-email { color: var(--text-primary); }
.adm-date { color: var(--text-muted); font-size: 0.82rem; }
.adm-mono { color: var(--text-muted); font-size: 0.8rem; font-family: 'Courier New', monospace; }
.adm-action-badge { font-size: 0.72rem; font-weight: 700; padding: 3px 9px; border-radius: 20px; display: inline-block; white-space: nowrap; }
.adm-action--login               { background: rgba(77,212,172,0.12);  color: var(--accent-teal); }
.adm-action--logout              { background: rgba(111,191,255,0.12); color: var(--accent-blue); }
.adm-action--delete              { background: rgba(248,113,113,0.12); color: #f87171; }
.adm-action--view                { background: var(--bg-input);        color: var(--accent-blue); }
.adm-action--create              { background: rgba(77,212,172,0.08);  color: var(--accent-teal); }
.adm-action--update              { background: rgba(192,132,252,0.1);  color: var(--accent-purple); }
.adm-action--export              { background: rgba(251,191,36,0.1);   color: #fbbf24; }
.adm-action--import              { background: rgba(192,132,252,0.1);  color: var(--accent-purple); }
.adm-action--admin-delete-user   { background: rgba(248,113,113,0.15); color: #f87171; }
.adm-action--admin-toggle-user   { background: rgba(251,191,36,0.1);   color: #fbbf24; }
.adm-action--webauthn-registered { background: rgba(77,212,172,0.1);   color: var(--accent-teal); }
.adm-action--password-changed    { background: rgba(192,132,252,0.1);  color: var(--accent-purple); }
.adm-action--email-changed       { background: rgba(111,191,255,0.1);  color: var(--accent-blue); }
</style>

{% endblock %}
