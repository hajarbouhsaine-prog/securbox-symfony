{% extends 'base.html.twig' %}
{% block title %}Journaux d'accès{% endblock %}
{% block body %}
<div class="mb-4 d-flex align-items-center gap-3">
    <a href="{{ path('app_admin_index') }}" style="color:#9ca3af; text-decoration:none; font-size:0.9rem;">
        <i class="fas fa-arrow-left me-1"></i>Retour
    </a>
    <h1 style="color:#e0e0e0; font-size:1.6rem; font-weight:600; margin:0;">
        <i class="fas fa-history me-2" style="color:#6fbfff;"></i>Journaux d'accès complets
    </h1>
</div>

<div style="background:#161b27; border:1px solid #2a2f3e; border-radius:10px; overflow:hidden;">
    <table class="table table-hover mb-0">
        <thead>
            <tr class="table-dark">
                <th>Utilisateur</th>
                <th>Action</th>
                <th>Secret</th>
                <th>IP</th>
                <th>Navigateur</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
            <tr>
                <td style="color:#e0e0e0;">{{ log.user.email }}</td>
                <td>
                    <span style="padding:3px 10px; border-radius:20px; font-size:0.8rem;
                        {% if log.action == 'LOGIN' %}background:#1a3a2a; color:#4dd4ac;
                        {% elseif log.action == 'DELETE' %}background:#3a1a1a; color:#f87171;
                        {% elseif log.action == 'VIEW' %}background:#1e2535; color:#6fbfff;
                        {% else %}background:#1e3a5f; color:#6fbfff;{% endif %}">
                        {{ log.action }}
                    </span>
                </td>
                <td style="color:#9ca3af;">{{ log.secret ? log.secret.name : '-' }}</td>
                <td style="color:#4b5563;">{{ log.ipAddress }}</td>
                <td style="color:#4b5563; font-size:0.8rem;">{{ log.userAgent|slice(0,40) }}...</td>
                <td style="color:#4b5563;">{{ log.createdAt|date('d/m/Y H:i:s') }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}